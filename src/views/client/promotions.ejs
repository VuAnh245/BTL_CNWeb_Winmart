<div class="bg-gray-50 min-h-screen pt-8 pb-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <!-- Breadcrumb -->
        <nav class="flex items-center gap-2 text-xs font-semibold text-gray-500 mb-8">
            <a href="/" class="hover:text-winmart-red transition-colors flex items-center gap-1.5"><i data-lucide="home" class="w-3.5 h-3.5"></i> Trang chủ</a>
            <i data-lucide="chevron-right" class="w-3.5 h-3.5"></i>
            <span class="text-winmart-dark font-bold">Khuyến mãi</span>
        </nav>

        <div class="mb-10">
            <h1 class="text-3xl font-black text-winmart-dark tracking-tight mb-2">Chương trình Khuyến mãi</h1>
            <p class="text-gray-500 font-semibold">Cập nhật những ưu đãi hấp dẫn nhất từ WinMart mỗi ngày</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
            
            <!-- Promo 1 -->
            <div class="bento-card overflow-hidden group relative">
                <div class="aspect-[16/9] w-full bg-winmart-red relative overflow-hidden">
                    <!-- Background Decoration -->
                    <div class="absolute inset-0 bg-gradient-to-tr from-black/60 to-transparent z-10"></div>
                    <div class="absolute -right-20 -top-20 w-64 h-64 bg-white/10 blur-3xl rounded-full"></div>
                    <div class="absolute -left-20 -bottom-20 w-64 h-64 bg-black/20 blur-3xl rounded-full"></div>
                    
                    <img src="https://images.unsplash.com/photo-1542838132-92c53300491e?auto=format&fit=crop&q=80&w=800" 
                         alt="Khuyến mãi" 
                         class="absolute inset-0 w-full h-full object-cover mix-blend-overlay group-hover:scale-105 transition-transform duration-700">

                    <div class="absolute inset-0 z-20 p-8 flex flex-col justify-end">
                        <span class="bg-winmart-yellow text-winmart-dark text-[10px] font-black px-3 py-1.5 rounded-xl uppercase tracking-widest w-fit mb-3 shadow-lg shadow-winmart-yellow/20">HOT DEAL</span>
                        <h2 class="text-2xl lg:text-3xl font-black text-white leading-tight mb-2">Giảm giá cuối tuần<br>Lên đến 50%</h2>
                        <p class="text-gray-200 text-sm font-semibold mb-6 max-w-sm">Áp dụng cho các sản phẩm thịt cá tươi sống và rau củ quả. Số lượng có hạn!</p>
                        <a href="/products" class="w-fit bg-white text-winmart-dark hover:bg-gray-100 font-bold px-6 py-3 rounded-xl transition-colors shadow-lg">
                            Mua ngay
                        </a>
                    </div>
                </div>
            </div>

            <!-- Promo 2 -->
            <div class="bento-card overflow-hidden group relative">
                <div class="aspect-[16/9] w-full bg-emerald-600 relative overflow-hidden">
                    <div class="absolute inset-0 bg-gradient-to-tr from-black/50 to-transparent z-10"></div>
                    <img src="https://images.unsplash.com/photo-1610348725531-843dff563e2c?auto=format&fit=crop&q=80&w=800" 
                         alt="Khuyến mãi" 
                         class="absolute inset-0 w-full h-full object-cover mix-blend-overlay group-hover:scale-105 transition-transform duration-700">

                    <div class="absolute inset-0 z-20 p-8 flex flex-col justify-end">
                        <span class="bg-white text-emerald-600 text-[10px] font-black px-3 py-1.5 rounded-xl uppercase tracking-widest w-fit mb-3">MEMBER ONLY</span>
                        <h2 class="text-2xl lg:text-3xl font-black text-white leading-tight mb-2">Tích điểm x2<br>Hội viên WinMart+</h2>
                        <p class="text-gray-200 text-sm font-semibold mb-6 max-w-sm">Nhân đôi điểm tích lũy vào thứ 6 hàng tuần cho tất cả thẻ thành viên từ hạng VIP.</p>
                        <a href="/profile" class="w-fit bg-winmart-dark text-white hover:bg-gray-800 font-bold px-6 py-3 rounded-xl transition-colors shadow-lg">
                            Kiểm tra hạng
                        </a>
                    </div>
                </div>
            </div>

        </div>

        <!-- Mã Giảm Giá Của Bạn -->
        <% if (typeof vouchers !== 'undefined' && vouchers && vouchers.length > 0) { %>
        <div class="mt-16">
            <div class="flex items-center gap-3 mb-8">
                <div class="w-1.5 h-8 bg-winmart-red rounded-full"></div>
                <h2 class="text-2xl font-black text-winmart-dark tracking-tight">Mã Giảm Giá Của Bạn</h2>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                <% vouchers.forEach(voucher => { %>
                <div class="bg-white border-2 border-dashed border-winmart-red/30 rounded-2xl p-6 relative group hover:border-winmart-red transition-colors shadow-sm hover:shadow-xl">
                    <div class="absolute -top-3 -right-3 w-10 h-10 bg-winmart-red text-white rounded-full flex items-center justify-center shadow-lg transform rotate-12">
                        <i data-lucide="ticket" class="w-5 h-5"></i>
                    </div>
                    
                    <h3 class="font-black text-winmart-dark text-lg mb-1"><%= voucher.TenMaGiamGia %></h3>
                    <div class="text-sm font-semibold text-winmart-red mb-4">
                        <% if (voucher.LoaiGiamGia === 'Percent') { %>
                            Giảm <%= voucher.GiaTri %>% 
                            <% if (voucher.PhanTramToiDa > 0) { %> (Tối đa <%= Number(voucher.PhanTramToiDa).toLocaleString('vi-VN') %>đ) <% } %>
                        <% } else { %>
                            Giảm <%= Number(voucher.GiaTri).toLocaleString('vi-VN') %>đ
                        <% } %>
                    </div>
                    
                    <div class="text-xs text-gray-500 mb-6 space-y-1">
                        <% if (voucher.GiaTriDonHangToiThieu > 0) { %>
                        <p><i data-lucide="check-circle-2" class="w-3.5 h-3.5 inline-block text-emerald-500 mr-1"></i> Đơn tối thiểu: <%= Number(voucher.GiaTriDonHangToiThieu).toLocaleString('vi-VN') %>đ</p>
                        <% } %>
                        <p><i data-lucide="clock" class="w-3.5 h-3.5 inline-block text-amber-500 mr-1"></i> HSD: <%= new Date(voucher.NgayKetThuc).toLocaleString('vi-VN') %></p>
                    </div>
                    
                    <div class="bg-gray-50 rounded-xl p-3 flex items-center justify-between border border-gray-100">
                        <span class="font-mono font-black text-winmart-dark tracking-widest text-lg" id="voucher-code-<%= voucher.MaCode %>"><%= voucher.MaCode %></span>
                        <button onclick="copyVoucher('<%= voucher.MaCode %>')" class="bg-winmart-dark hover:bg-winmart-red text-white px-4 py-2 rounded-lg font-bold text-xs transition-colors shadow-md">
                            Copy
                        </button>
                    </div>
                </div>
                <% }) %>
            </div>
        </div>
        <% } %>

        <div class="mt-16 bento-card p-8 lg:p-12 text-center bg-gradient-to-br from-gray-50 to-white relative overflow-hidden">
            <div class="absolute -top-10 -right-10 w-40 h-40 bg-winmart-red/5 rounded-full blur-2xl"></div>
            <div class="w-20 h-20 bg-winmart-red/10 rounded-2xl flex items-center justify-center mx-auto mb-6 relative z-10">
                <i data-lucide="gift" class="w-10 h-10 text-winmart-red"></i>
            </div>
            <h2 class="text-2xl font-black text-winmart-dark mb-4 relative z-10">Đăng ký nhận thông tin khuyến mãi</h2>
            <p class="text-gray-500 font-semibold mb-8 max-w-md mx-auto relative z-10">Đừng bỏ lỡ những voucher siêu hấp dẫn gửi trực tiếp qua email của bạn mỗi tuần.</p>
            
            <form class="max-w-md mx-auto relative z-10 flex gap-2">
                <input type="email" placeholder="Nhập địa chỉ email của bạn..." class="flex-1 bg-white border border-gray-200 rounded-xl px-4 py-3 text-sm font-bold focus:outline-none focus:border-winmart-red transition-all">
                <button type="button" class="bg-winmart-red hover:bg-red-700 text-white font-bold px-6 py-3 rounded-xl transition-colors shadow-lg shadow-winmart-red/20 shrink-0">
                    Đăng ký
                </button>
            </form>
        </div>

    </div>
</div>

<script>
function copyVoucher(code) {
    navigator.clipboard.writeText(code).then(() => {
        showWmToast('Đã sao chép mã: ' + code);
    }).catch(err => {
        console.error('Lỗi khi copy', err);
    });
}
</script>
