<div class="min-h-[80vh] flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-md w-full space-y-8 bg-white p-10 rounded-[32px] shadow-2xl border border-gray-100">
        <div class="text-center">
            <div class="mx-auto h-16 w-16 bg-winmart-red/10 rounded-full flex items-center justify-center mb-4">
                <i data-lucide="smartphone" class="h-8 w-8 text-winmart-red"></i>
            </div>
            <h2 class="text-3xl font-black text-winmart-dark tracking-tight">Chào mừng bạn! 🎉</h2>
            <p class="mt-3 text-sm text-gray-500 font-medium leading-relaxed">
                Xin chào <strong class="text-winmart-dark"><%= user.name %></strong>,<br>
                Để tích điểm WinMart+ khi mua sắm tại siêu thị, vui lòng bổ sung số điện thoại của bạn nhé!
            </p>
        </div>

        <form id="complete-profile-form" class="mt-8 space-y-6" novalidate action="/auth/complete-profile" method="POST">
            <div>
                <label class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-1.5 ml-1">Số điện thoại <span class="text-red-500">*</span></label>
                <div class="relative input-group-wm">
                    <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                        <i data-lucide="phone" class="w-5 h-5 text-gray-400 transition-colors"></i>
                    </div>
                    <input type="tel" name="phone" id="phone" required placeholder="VD: 0912345678" 
                           class="w-full pl-12 pr-4 py-3.5 bg-gray-50 border border-gray-200 rounded-2xl text-sm font-bold text-winmart-dark focus:outline-none focus:border-winmart-red focus:bg-white transition-all">
                </div>
                <p id="phone-error" class="text-red-500 text-xs font-bold mt-2 ml-1 hidden"></p>
            </div>

            <button type="submit" class="btn-primary-wm w-full text-white font-bold py-4 rounded-2xl text-sm uppercase tracking-widest flex justify-center items-center gap-2 group">
                Lưu & Bắt đầu mua sắm <i data-lucide="arrow-right" class="w-4 h-4 group-hover:translate-x-1 transition-transform"></i>
            </button>
        </form>
    </div>
</div>

<%- contentFor('scripts') %>
<script>
    document.getElementById('complete-profile-form').addEventListener('submit', async (e) => {
        e.preventDefault();
        const phone = document.getElementById('phone').value;
        const errorEl = document.getElementById('phone-error');
        
        // Validate regex Vietnam phone
        const phoneRegex = /^0[3|5|7|8|9]\d{8}$/;
        if (!phoneRegex.test(phone)) {
            errorEl.innerText = "Số điện thoại không hợp lệ (Bắt đầu bằng 0, đủ 10 số)";
            errorEl.classList.remove('hidden');
            return;
        }

        try {
            const res = await fetch('/auth/complete-profile', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ phone })
            });
            const data = await res.json();
            
            if (data.success) {
                window.location.href = data.redirectUrl || '/';
            } else {
                errorEl.innerText = data.message;
                errorEl.classList.remove('hidden');
            }
        } catch (error) {
            errorEl.innerText = "Có lỗi xảy ra, vui lòng thử lại sau";
            errorEl.classList.remove('hidden');
        }
    });

    document.getElementById('phone').addEventListener('input', () => {
        document.getElementById('phone-error').classList.add('hidden');
    });
</script>
