<%
  // Tắt layout mặc định, trang này tự render hoàn chỉnh
  layout = false;
%>
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng Nhập | WinMart</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        winmart: { red: '#E21E26', yellow: '#FFC522', dark: '#111827', slate: '#6B7280' }
                    },
                    fontFamily: { sans: ['"Plus Jakarta Sans"', 'sans-serif'] }
                }
            }
        }
    </script>
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
        .btn-primary-wm { background: linear-gradient(135deg,#E21E26 0%,#B91319 100%); box-shadow: 0 10px 25px -5px rgba(226,30,38,0.3); transition: all .3s; }
        .btn-primary-wm:hover { transform: translateY(-2px); box-shadow: 0 15px 35px -5px rgba(226,30,38,0.4); }
    </style>
</head>
<body class="min-h-screen bg-gray-50 flex items-center justify-center p-4">

    <div class="w-full max-w-[900px] bg-white rounded-[2rem] shadow-2xl flex overflow-hidden">

        <!-- Bên trái: Banner -->
        <section class="hidden lg:flex w-5/12 relative bg-winmart-dark flex-col justify-between p-10 overflow-hidden">
            <img src="https://images.unsplash.com/photo-1604719312566-8912e9227c6a?auto=format&fit=crop&q=80&w=800"
                 alt="Supermarket" class="absolute inset-0 w-full h-full object-cover opacity-30 mix-blend-overlay">
            <div class="absolute inset-0 bg-gradient-to-t from-winmart-dark via-winmart-dark/60 to-transparent"></div>

            <a href="/" class="relative z-10 flex items-center gap-2 no-underline">
                <div class="w-10 h-10 rounded-xl bg-winmart-red flex items-center justify-center text-white font-black text-lg">WM</div>
                <span class="text-lg font-black text-white tracking-tight">WinMart</span>
            </a>

            <div class="relative z-10 space-y-4">
                <h2 class="text-3xl font-black text-white leading-tight">Chào mừng<br><span class="text-winmart-yellow">quay trở lại!</span></h2>
                <p class="text-gray-300 text-xs font-medium leading-relaxed">
                    Đăng nhập để tiếp tục mua sắm, tích điểm thành viên và theo dõi đơn hàng nhanh chóng.
                </p>
                <div class="space-y-2 pt-2">
                    <div class="flex items-center gap-2 text-gray-300 text-xs font-semibold">
                        <div class="w-5 h-5 rounded-full bg-emerald-500/20 text-emerald-400 flex items-center justify-center"><i data-lucide="check" class="w-3 h-3"></i></div>
                        Giao hàng nhanh toàn quốc
                    </div>
                    <div class="flex items-center gap-2 text-gray-300 text-xs font-semibold">
                        <div class="w-5 h-5 rounded-full bg-emerald-500/20 text-emerald-400 flex items-center justify-center"><i data-lucide="check" class="w-3 h-3"></i></div>
                        Tích điểm WinMart Plus
                    </div>
                    <div class="flex items-center gap-2 text-gray-300 text-xs font-semibold">
                        <div class="w-5 h-5 rounded-full bg-emerald-500/20 text-emerald-400 flex items-center justify-center"><i data-lucide="check" class="w-3 h-3"></i></div>
                        Ưu đãi thành viên độc quyền
                    </div>
                </div>
            </div>
        </section>

        <!-- Bên phải: Form -->
        <section class="w-full lg:w-7/12 p-8 sm:p-12 flex flex-col justify-center">

            <!-- Back to home -->
            <a href="/" class="inline-flex items-center gap-1.5 text-xs font-bold text-gray-400 hover:text-winmart-dark transition-colors mb-8 no-underline">
                <i data-lucide="arrow-left" class="w-3.5 h-3.5"></i> Về trang chủ
            </a>

            <div class="mb-8">
                <h1 class="text-2xl font-black text-winmart-dark tracking-tight">Đăng nhập tài khoản</h1>
                <p class="text-sm text-gray-400 font-medium mt-1.5">Nhập thông tin để truy cập hệ thống WinMart</p>
            </div>

            <!-- Flash message -->
            <% if (typeof error !== 'undefined' && error) { %>
            <div class="flex items-center gap-3 bg-red-50 border border-red-200 text-red-600 px-4 py-3 rounded-2xl text-sm font-bold mb-5">
                <i data-lucide="alert-circle" class="w-4 h-4 shrink-0"></i> <%= error %>
            </div>
            <% } %>
            <% if (typeof success !== 'undefined' && success) { %>
            <div class="flex items-center gap-3 bg-emerald-50 border border-emerald-200 text-emerald-700 px-4 py-3 rounded-2xl text-sm font-bold mb-5">
                <i data-lucide="check-circle" class="w-4 h-4 shrink-0"></i> <%= success %>
            </div>
            <% } %>

            <form action="/auth/login" method="POST" class="space-y-5">
                <!-- Identifier -->
                <div>
                    <label class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-1.5 ml-1">Email / Số điện thoại / Tên đăng nhập</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                            <i data-lucide="user" class="w-5 h-5 text-gray-400"></i>
                        </div>
                        <input type="text" name="identifier" list="savedAccountsList" autocomplete="off" value="<%= typeof old !== 'undefined' ? old.identifier || '' : '' %>"
                               placeholder="Nhập email, SĐT hoặc tên đăng nhập..." required
                               class="w-full pl-12 pr-4 py-3.5 bg-white border border-gray-200 rounded-2xl text-sm font-bold text-winmart-dark focus:outline-none focus:border-winmart-red focus:ring-4 focus:ring-winmart-red/10 transition-all">
                        <datalist id="savedAccountsList"></datalist>
                    </div>
                </div>

                <!-- Password -->
                <div>
                    <div class="flex justify-between items-center mb-1.5 ml-1 mr-1">
                        <label class="block text-[10px] font-black text-gray-400 uppercase tracking-widest">Mật khẩu</label>
                        <a href="#" class="text-[10px] font-bold text-winmart-red hover:underline no-underline">Quên mật khẩu?</a>
                    </div>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                            <i data-lucide="lock" class="w-5 h-5 text-gray-400"></i>
                        </div>
                        <input type="password" id="password" name="password" autocomplete="off" placeholder="••••••••" required
                               class="w-full pl-12 pr-12 py-3.5 bg-white border border-gray-200 rounded-2xl text-sm font-bold text-winmart-dark focus:outline-none focus:border-winmart-red focus:ring-4 focus:ring-winmart-red/10 transition-all">
                        <button type="button" onclick="togglePwd('password','eye-login')" class="absolute inset-y-0 right-0 pr-4 flex items-center text-gray-400 hover:text-winmart-dark transition-colors">
                            <i id="eye-login" data-lucide="eye" class="w-4 h-4"></i>
                        </button>
                    </div>
                </div>

                <!-- Remember me -->
                <div class="flex items-center gap-2 ml-1">
                    <input type="checkbox" id="remember" name="rememberMe" value="1" class="w-4 h-4 accent-winmart-red cursor-pointer rounded">
                    <label for="remember" class="text-xs font-semibold text-gray-500 cursor-pointer">Ghi nhớ đăng nhập</label>
                </div>

                <button type="submit" class="btn-primary-wm w-full text-white font-bold py-3.5 rounded-2xl text-sm uppercase tracking-widest flex justify-center items-center gap-2 mt-2">
                    Đăng Nhập <i data-lucide="arrow-right" class="w-4 h-4"></i>
                </button>
            </form>

            <div class="mt-8 pt-6 border-t border-gray-100 text-center">
                <p class="text-sm text-gray-400 font-medium">
                    Chưa có tài khoản?
                    <a href="/auth/register" class="text-winmart-red font-bold hover:underline ml-1 no-underline">Đăng ký ngay</a>
                </p>
            </div>

        </section>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            lucide.createIcons();
            
            const dataList = document.getElementById('savedAccountsList');
            if (dataList) {
                let accounts = JSON.parse(localStorage.getItem('wm_saved_accounts') || '[]');
                accounts.forEach(acc => {
                    const option = document.createElement('option');
                    option.value = acc;
                    dataList.appendChild(option);
                });
            }
            
            // Save to suggestion list on form submit
            const form = document.querySelector('form');
            if (form) {
                form.addEventListener('submit', () => {
                    const enteredId = document.querySelector('input[name="identifier"]').value.trim();
                    if (enteredId) {
                        let accounts = JSON.parse(localStorage.getItem('wm_saved_accounts') || '[]');
                        if (!accounts.includes(enteredId)) {
                            accounts.push(enteredId);
                            localStorage.setItem('wm_saved_accounts', JSON.stringify(accounts));
                        }
                    }
                });
            }
        });
        
        function togglePwd(id, eyeId) {
            const el = document.getElementById(id);
            const eye = document.getElementById(eyeId);
            el.type = el.type === 'password' ? 'text' : 'password';
            eye.setAttribute('data-lucide', el.type === 'password' ? 'eye' : 'eye-off');
            lucide.createIcons();
        }
    </script>
</body>
</html>