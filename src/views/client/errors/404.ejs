<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Không tìm thấy trang' %> - WinMart</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 min-h-screen flex items-center justify-center px-4">
  <div class="max-w-lg w-full bg-white rounded-xl shadow-lg p-8 text-center">
    <div class="text-6xl mb-4">🔍</div>
    <h1 class="text-3xl font-bold text-gray-800 mb-2">404 - Không tìm thấy trang</h1>
    <p class="text-gray-600 mb-6">Trang bạn đang tìm kiếm không tồn tại hoặc đã bị di chuyển.</p>
    
    <% if (typeof url !== 'undefined' && url) { %>
      <div class="bg-gray-100 p-3 rounded mb-6">
        <p class="text-sm text-gray-500">URL: <code class="text-red-600"><%= url %></code></p>
      </div>
    <% } %>
    
    <div class="flex gap-3 justify-center">
      <button onclick="window.location.href='/'" class="px-6 py-2 bg-winmart text-white rounded-lg hover:bg-winmart-dark transition">
        Về trang chủ
      </button>
      <button onclick="window.history.back()" class="px-6 py-2 bg-gray-200 text-gray-800 rounded-lg hover:bg-gray-300 transition">
        Quay lại
      </button>
    </div>
  </div>
</body>
</html>