<script>
// Countdown Timer Logic
(function() {
    <% if (typeof activePromotions !== 'undefined' && activePromotions && activePromotions.length > 0) { %>
        const promos = <%- JSON.stringify(activePromotions.map(p => ({ end: p.NgayKetThuc }))) %>;
        
        promos.forEach((promo, index) => {
            const endTime = new Date(promo.end).getTime();
            
            const timer = setInterval(() => {
                const now = new Date().getTime();
                const distance = endTime - now;
                
                if (distance < 0) {
                    clearInterval(timer);
                    const countdownEl = document.querySelector('.countdown-timer-' + index);
                    if (countdownEl) countdownEl.innerHTML = '<span class="text-winmart-red font-bold text-sm">Đã kết thúc</span>';
                    return;
                }
                
                const d = Math.floor(distance / (1000 * 60 * 60 * 24));
                const h = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                const m = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
                const s = Math.floor((distance % (1000 * 60)) / 1000);
                
                const fmt = n => String(n).padStart(2, '0');
                
                const dEl = document.getElementById('days-' + index);
                const hEl = document.getElementById('hours-' + index);
                const mEl = document.getElementById('mins-' + index);
                const sEl = document.getElementById('secs-' + index);
                
                if (dEl) dEl.textContent = fmt(d);
                if (hEl) hEl.textContent = fmt(h);
                if (mEl) mEl.textContent = fmt(m);
                if (sEl) sEl.textContent = fmt(s);
            }, 1000);
        });
    <% } %>
})();

// Promo Popup Logic
document.addEventListener('DOMContentLoaded', () => {
    <% if (typeof activePromotions !== 'undefined' && activePromotions && activePromotions.length > 0) { %>
    // Lưu các mã vào 1 mảng
    const codes = <%- JSON.stringify(activePromotions.map(p => p.MaCode)) %>;
    // Kiểm tra xem đã thấy MỌI mã trong này chưa
    const hasSeenAll = codes.every(code => localStorage.getItem('seenPromo_' + code));
    
    if (!hasSeenAll) {
        setTimeout(() => {
            const overlay = document.getElementById('promoPopupOverlay');
            const content = document.getElementById('promoPopupContent');
            if (overlay && content) {
                overlay.classList.remove('hidden');
                overlay.style.display = 'flex';
                // Trigger reflow
                void overlay.offsetWidth;
                overlay.classList.remove('opacity-0');
                content.classList.remove('scale-95');
            }
        }, 1500);
    }
    <% } %>
});

function closePromoPopup() {
    const overlay = document.getElementById('promoPopupOverlay');
    const content = document.getElementById('promoPopupContent');
    <% if (typeof activePromotions !== 'undefined' && activePromotions && activePromotions.length > 0) { %>
    const codesToSave = <%- JSON.stringify(activePromotions.map(p => p.MaCode)) %>;
    codesToSave.forEach(code => localStorage.setItem('seenPromo_' + code, 'true'));
    <% } %>
    
    if (overlay && content) {
        overlay.classList.add('opacity-0');
        content.classList.add('scale-95');
        setTimeout(() => {
            overlay.style.display = 'none';
        }, 300);
    }
}

function copyPromoCode(code) {
    navigator.clipboard.writeText(code).then(() => {
        showWmToast('Đã copy mã: ' + code);
        setTimeout(() => closePromoPopup(), 1000);
    });
}
</script>