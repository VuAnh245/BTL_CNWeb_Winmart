                <% activePromotions.forEach((promo) => { %>
                <div class="bg-gray-50 border-2 border-dashed border-gray-300 rounded-xl p-4 relative group flex flex-col justify-center items-center text-center">
                    <div class="text-xs text-gray-500 font-bold mb-1"><%= promo.TenMaGiamGia %></div>
