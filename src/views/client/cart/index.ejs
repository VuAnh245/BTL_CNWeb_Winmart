<div class="bg-gray-50 min-h-screen pt-8 pb-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <!-- Breadcrumb -->
        <nav class="flex items-center gap-2 text-xs font-semibold text-gray-500 mb-8">
            <a href="/" class="hover:text-winmart-red transition-colors flex items-center gap-1.5"><i data-lucide="home" class="w-3.5 h-3.5"></i> Trang chủ</a>
            <i data-lucide="chevron-right" class="w-3.5 h-3.5"></i>
            <span class="text-winmart-dark font-bold">Giỏ hàng của bạn</span>
        </nav>

        <h1 class="text-2xl font-black text-winmart-dark tracking-tight mb-6">Giỏ hàng của bạn</h1>

        <% if (cart && cart.length > 0) { %>
            <div class="flex flex-col lg:flex-row gap-8">
                
                <!-- Danh sách sản phẩm -->
                <div class="flex-1 space-y-4">
                    <% let totalAmount = 0; %>
                    <% let totalVat = 0; %>
                    <% cart.forEach((item, index) => { %>
                        <% const itemTotal = Number(item.price) * Number(item.quantity); %>
                        <% const itemVat = itemTotal * ((item.vat || 0) / 100); %>
                        <% totalAmount += itemTotal; %>
                        <% totalVat += itemVat; %>
                        
                        <div class="bento-card p-4 sm:p-6 flex flex-col sm:flex-row items-center gap-4 sm:gap-6 relative group">
                            <!-- Nút xóa -->
                            <button onclick="removeFromCart('<%= item.productId %>')" class="absolute top-4 right-4 text-gray-300 hover:text-winmart-red transition-colors" title="Xóa sản phẩm">
                                <i data-lucide="trash-2" class="w-5 h-5"></i>
                            </button>

                            <!-- Ảnh SP -->
                            <div class="w-24 h-24 sm:w-28 sm:h-28 bg-white border border-gray-100 rounded-2xl flex-shrink-0 flex items-center justify-center p-2 overflow-hidden relative">
                                <img src="<%= item.image || '/images/products/placeholder.png' %>" alt="<%= item.name %>" class="w-full h-full object-contain group-hover:scale-110 transition-transform duration-300">
                            </div>

                            <!-- Thông tin -->
                            <div class="flex-1 w-full flex flex-col justify-between h-full">
                                <div>
                                    <h3 class="text-sm sm:text-base font-bold text-winmart-dark line-clamp-2 mb-1 pr-8"><%= item.name %></h3>
                                    <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-3">ID: <%= item.productId %></p>
                                </div>
                                
                                <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 mt-auto">
                                    <div class="text-lg font-black text-winmart-red">
                                        <%= Number(item.price).toLocaleString('vi-VN') %>đ
                                    </div>
                                    
                                    <div class="flex items-center gap-4">
                                        <!-- Số lượng -->
                                        <div class="flex items-center bg-gray-50 border border-gray-200 rounded-xl h-10 w-28 shrink-0">
                                            <button onclick="updateCartQuantity('<%= item.productId %>', -1)" class="w-8 h-full flex items-center justify-center text-gray-500 hover:text-winmart-dark transition-colors">
                                                <i data-lucide="minus" class="w-3.5 h-3.5"></i>
                                            </button>
                                            <input type="number" min="1" value="<%= item.quantity %>" 
                                                   onchange="handleQuantityInput(this, '<%= item.productId %>', <%= item.quantity %>)" 
                                                   class="w-full bg-transparent text-center text-sm font-black text-winmart-dark focus:outline-none [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none">
                                            <button onclick="updateCartQuantity('<%= item.productId %>', 1)" class="w-8 h-full flex items-center justify-center text-gray-500 hover:text-winmart-dark transition-colors">
                                                <i data-lucide="plus" class="w-3.5 h-3.5"></i>
                                            </button>
                                        </div>
                                        
                                        <!-- Thành tiền -->
                                        <div class="text-right hidden sm:block w-24">
                                            <p class="text-[10px] text-gray-400 font-bold uppercase tracking-widest mb-0.5">Thành tiền</p>
                                            <p class="text-sm font-bold text-winmart-dark"><%= itemTotal.toLocaleString('vi-VN') %>đ</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>

                <!-- Tổng kết đơn hàng -->
                <div class="w-full lg:w-96 shrink-0">
                    <div class="bento-card p-6 lg:p-8 sticky top-24">
                        <h2 class="text-lg font-black text-winmart-dark mb-6 flex items-center gap-2">
                            <div class="w-1.5 h-5 bg-winmart-red rounded-full"></div>
                            Tổng kết đơn hàng
                        </h2>
                        
                        <div class="space-y-4 mb-6 pb-6 border-b border-gray-100">
                            <div class="flex justify-between items-center text-sm">
                                <span class="text-gray-500 font-semibold">Tạm tính (chưa VAT):</span>
                                <span class="font-bold text-winmart-dark"><%= totalAmount.toLocaleString('vi-VN') %>đ</span>
                            </div>
                            <% if (totalVat > 0) { %>
                            <div class="flex justify-between items-center text-sm">
                                <span class="text-gray-500 font-semibold">Thuế GTGT (VAT):</span>
                                <span class="font-bold text-blue-600"><%= totalVat.toLocaleString('vi-VN') %>đ</span>
                            </div>
                            <% } %>
                            <div class="flex justify-between items-center text-sm">
                                <span class="text-gray-500 font-semibold">Phí vận chuyển:</span>
                                <% if ((totalAmount + totalVat) >= 300000) { %>
                                    <span class="font-bold text-emerald-500">Miễn phí (Đơn ≥ 300k)</span>
                                <% } else { %>
                                    <span class="font-bold text-gray-400">Tính khi thanh toán</span>
                                <% } %>
                            </div>
                            <div class="flex justify-between items-center text-sm">
                                <span class="text-gray-500 font-semibold">Khuyến mãi:</span>
                                <span class="font-bold text-winmart-red">- 0đ</span>
                            </div>
                        </div>

                        <div class="flex justify-between items-end mb-2">
                            <span class="text-sm text-gray-500 font-bold uppercase tracking-widest">Tổng cộng</span>
                            <span class="text-3xl font-black text-winmart-red"><%= (totalAmount + totalVat).toLocaleString('vi-VN') %>đ</span>
                        </div>
                        <div class="text-right text-[10px] text-gray-400 font-bold italic mb-6">(Đã bao gồm thuế VAT)</div>

                        <a href="/checkout" class="w-full bg-winmart-dark hover:bg-gray-800 text-white font-black px-6 py-4 rounded-xl transition-all shadow-lg shadow-gray-900/20 flex items-center justify-center gap-2 text-sm">
                            TIẾN HÀNH THANH TOÁN <i data-lucide="arrow-right" class="w-4 h-4"></i>
                        </a>
                        
                        <a href="/products" class="w-full block text-center text-sm font-bold text-gray-400 hover:text-winmart-dark transition-colors mt-4">
                            Tiếp tục mua sắm
                        </a>
                    </div>
                </div>

            </div>
        <% } else { %>
            <!-- Empty Cart -->
            <div class="bento-card p-12 text-center flex flex-col items-center">
                <div class="w-24 h-24 bg-gray-50 rounded-full flex items-center justify-center mb-6">
                    <i data-lucide="shopping-cart" class="w-12 h-12 text-gray-300"></i>
                </div>
                <h2 class="text-xl font-black text-winmart-dark mb-2">Giỏ hàng của bạn đang trống</h2>
                <p class="text-gray-500 font-semibold mb-8">Hãy khám phá thêm các sản phẩm tuyệt vời của chúng tôi</p>
                <a href="/products" class="bg-winmart-red hover:bg-red-700 text-white font-bold px-8 py-3 rounded-xl transition-colors shadow-lg shadow-winmart-red/20">
                    Mua sắm ngay
                </a>
            </div>
        <% } %>
        
    </div>
</div>

<script>
    async function handleQuantityInput(inputEl, productId, oldQuantity) {
        const newQuantity = parseInt(inputEl.value);
        if (isNaN(newQuantity) || newQuantity <= 0) {
            inputEl.value = oldQuantity;
            return;
        }
        const change = newQuantity - oldQuantity;
        if (change === 0) return;
        
        try {
            const res = await fetch('/cart/update', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ productId, change })
            });
            const data = await res.json();
            if (data.success) {
                window.location.reload();
            } else {
                showWmToast(data.message || 'Có lỗi xảy ra');
                inputEl.value = oldQuantity;
            }
        } catch (e) {
            showWmToast('Lỗi kết nối máy chủ');
            inputEl.value = oldQuantity;
        }
    }

    async function updateCartQuantity(productId, change) {
        try {
            const res = await fetch('/cart/update', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ productId, change })
            });
            const data = await res.json();
            if (data.success) {
                window.location.reload();
            } else {
                showWmToast(data.message || 'Có lỗi xảy ra');
            }
        } catch (e) {
            showWmToast('Lỗi kết nối máy chủ');
        }
    }

    async function removeFromCart(productId) {
        if (!confirm('Bạn có chắc muốn xóa sản phẩm này khỏi giỏ hàng?')) return;
        try {
            const res = await fetch('/cart/remove', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ productId })
            });
            const data = await res.json();
            if (data.success) {
                window.location.reload();
            } else {
                showWmToast(data.message || 'Có lỗi xảy ra');
            }
        } catch (e) {
            showWmToast('Lỗi kết nối máy chủ');
        }
    }
</script>