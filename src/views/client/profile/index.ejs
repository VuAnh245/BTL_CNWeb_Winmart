<div class="bg-gray-50 min-h-screen pt-12 pb-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
<%
    let currentTierLabel = 'Hạng Thường';
    let cardClass = 'from-gray-700 to-gray-900';
    let textClass = 'text-gray-200';
    let nextTierLabel = 'Hạng Bạc';
    let nextThresholdPts = appConfig.loyalty.thresholds.VIP1;
    let iconClass = 'text-gray-300';
    
    if (profileData.CapDoVIP === LOYALTY_TIER.VIP1) {
        currentTierLabel = 'Hạng Bạc';
        cardClass = 'from-gray-300 to-gray-500';
        textClass = 'text-white';
        nextTierLabel = 'Hạng Vàng';
        nextThresholdPts = appConfig.loyalty.thresholds.VIP2;
        iconClass = 'text-white';
    } else if (profileData.CapDoVIP === LOYALTY_TIER.VIP2) {
        currentTierLabel = 'Hạng Vàng';
        cardClass = 'from-yellow-400 to-yellow-600';
        textClass = 'text-white';
        nextTierLabel = 'Hạng Kim Cương';
        nextThresholdPts = appConfig.loyalty.thresholds.VIP3;
        iconClass = 'text-yellow-100';
    } else if (profileData.CapDoVIP === LOYALTY_TIER.VIP3) {
        currentTierLabel = 'Hạng Kim Cương';
        cardClass = 'from-purple-500 to-purple-800';
        textClass = 'text-white';
        nextTierLabel = 'Tối Đa';
        nextThresholdPts = appConfig.loyalty.thresholds.VIP3;
        iconClass = 'text-purple-200';
    } else if (profileData.CapDoVIP === 'Nhân viên') {
        currentTierLabel = 'Tài Khoản Nhân Viên';
        nextThresholdPts = 0;
    }

    const currentPts = profileData.TongDiemTichLuy || 0;
    
    let progressPercent = 100;
    let missingVnd = 0;
    if (profileData.CapDoVIP !== LOYALTY_TIER.VIP3 && profileData.CapDoVIP !== 'Nhân viên') {
        progressPercent = Math.min(100, Math.floor((currentPts / nextThresholdPts) * 100));
        const missingPts = nextThresholdPts - currentPts;
        missingVnd = missingPts * 100; 
    }
%>
        <!-- Breadcrumb -->
        <nav class="flex items-center gap-2 text-xs font-semibold text-gray-500 mb-8">
            <a href="/" class="hover:text-winmart-red transition-colors flex items-center gap-1.5"><i data-lucide="home" class="w-3.5 h-3.5"></i> Trang chủ</a>
            <i data-lucide="chevron-right" class="w-3.5 h-3.5"></i>
            <span class="text-winmart-dark font-bold">Hồ sơ cá nhân</span>
        </nav>

        <div class="flex flex-col lg:flex-row gap-8">
            
            <!-- Sidebar -->
            <aside class="w-full lg:w-72 shrink-0">
                <div class="bento-card p-6 mb-6 text-center relative overflow-hidden">
                    <div class="absolute top-0 inset-x-0 h-20 bg-gradient-to-r from-winmart-red to-red-800"></div>
                    <div class="relative z-10">
                        <div class="w-20 h-20 mx-auto rounded-[1.5rem] bg-white border-4 border-white shadow-xl flex items-center justify-center text-winmart-dark font-black text-2xl mb-4">
                            <%= profileData.HoTen ? profileData.HoTen.charAt(0).toUpperCase() : 'U' %>
                        </div>
                        <h2 class="text-lg font-black text-winmart-dark"><%= profileData.HoTen || 'Khách hàng' %></h2>
                        <p class="text-xs font-semibold text-gray-400 mt-1 mb-4"><%= profileData.SoDienThoai || 'Chưa cập nhật SĐT' %></p>
                        
                        <div class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-winmart-yellow/10 text-winmart-yellow rounded-xl text-xs font-black uppercase tracking-wider">
                            <i data-lucide="crown" class="w-3.5 h-3.5"></i> 
                            <%= currentTierLabel %>
                        </div>
                    </div>
                </div>

                <div class="bento-card p-3">
                    <nav class="flex flex-col gap-1.5">
                        <a href="/profile" class="flex items-center gap-3 px-4 py-3 rounded-xl bg-winmart-red/10 text-winmart-red font-bold text-sm transition-all">
                            <i data-lucide="user" class="w-4 h-4"></i> Thông tin tài khoản
                        </a>
                        <a href="/profile/orders" class="flex items-center gap-3 px-4 py-3 rounded-xl text-gray-500 hover:bg-gray-50 hover:text-winmart-dark font-bold text-sm transition-all">
                            <i data-lucide="package" class="w-4 h-4"></i> Đơn hàng của tôi
                        </a>
                        <a href="javascript:void(0)" onclick="goToWishlist()" class="flex items-center gap-3 px-4 py-3 rounded-xl text-gray-500 hover:bg-gray-50 hover:text-winmart-dark font-bold text-sm transition-all">
                            <i data-lucide="heart" class="w-4 h-4"></i> Sản phẩm yêu thích
                        </a>
                        <a href="/profile/address" class="flex items-center gap-3 px-4 py-3 rounded-xl text-gray-500 hover:bg-gray-50 hover:text-winmart-dark font-bold text-sm transition-all">
                            <i data-lucide="map-pin" class="w-4 h-4"></i> Sổ địa chỉ
                        </a>
                        <a href="/profile/change-password" class="flex items-center gap-3 px-4 py-3 rounded-xl text-gray-500 hover:bg-gray-50 hover:text-winmart-dark font-bold text-sm transition-all">
                            <i data-lucide="key" class="w-4 h-4"></i> Đổi mật khẩu
                        </a>
                        <div class="my-2 border-t border-gray-100"></div>
                        <a href="/auth/logout" class="flex items-center gap-3 px-4 py-3 rounded-xl text-red-500 hover:bg-red-50 font-bold text-sm transition-all">
                            <i data-lucide="log-out" class="w-4 h-4"></i> Đăng xuất
                        </a>
                    </nav>
                </div>
            </aside>

            <!-- Main Content -->
            <main class="flex-1">
                <div class="mb-6">
                    <h1 class="text-2xl font-black text-winmart-dark tracking-tight">Thông tin tài khoản</h1>
                    <p class="text-sm font-semibold text-gray-400 mt-1">Quản lý thông tin cá nhân và bảo mật</p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                    <!-- WinMart Plus Card -->
                    <div class="bento-card p-6 bg-gradient-to-br <%= cardClass %> text-white relative overflow-hidden group shadow-xl">
                        <div class="absolute -right-10 -bottom-10 w-40 h-40 bg-white/10 blur-3xl rounded-full group-hover:bg-white/20 transition-all"></div>
                        
                        <div class="flex items-start justify-between mb-8 relative z-10">
                            <div>
                                <p class="text-[10px] font-bold opacity-80 uppercase tracking-widest mb-1">Thẻ thành viên</p>
                                <h3 class="text-lg font-black <%= textClass %> flex items-center gap-2">WinMart Plus <i data-lucide="sparkles" class="w-4 h-4"></i></h3>
                            </div>
                            <div class="w-10 h-10 rounded-xl bg-white/20 backdrop-blur-md flex items-center justify-center">
                                <i data-lucide="award" class="w-5 h-5 <%= iconClass %>"></i>
                            </div>
                        </div>

                        <div class="relative z-10">
                            <p class="text-[10px] font-bold opacity-80 uppercase tracking-widest mb-1">Điểm tích lũy hiện tại</p>
                            <div class="text-3xl font-black mb-1"><%= currentPts.toLocaleString('vi-VN') %> <span class="text-lg font-bold opacity-80">điểm</span></div>
                            <p class="text-xs font-semibold opacity-90">Tương đương <span class="font-black"><%= currentPts.toLocaleString('vi-VN') %>đ</span></p>
                        </div>
                    </div>

                    <!-- Total Spent -->
                    <div class="bento-card p-6 flex flex-col justify-center">
                        <div class="flex items-center gap-4 mb-4">
                            <div class="w-12 h-12 rounded-2xl bg-emerald-50 text-emerald-500 flex items-center justify-center">
                                <i data-lucide="wallet" class="w-6 h-6"></i>
                            </div>
                            <div>
                                <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Tổng chi tiêu</p>
                                <div class="text-2xl font-black text-winmart-dark"><%= totalSpent ? totalSpent.toLocaleString('vi-VN') : 0 %>đ</div>
                            </div>
                        </div>
                        <% if (profileData.CapDoVIP !== LOYALTY_TIER.VIP3 && profileData.CapDoVIP !== 'Nhân viên') { %>
                        <div class="w-full bg-gray-100 rounded-full h-1.5 mb-2 overflow-hidden">
                            <div class="bg-emerald-500 h-1.5 rounded-full transition-all duration-1000" style="width: <%= progressPercent %>%"></div>
                        </div>
                        <p class="text-xs font-semibold text-gray-500">Mua thêm <span class="text-winmart-red font-bold"><%= missingVnd.toLocaleString('vi-VN') %>đ</span> để lên <span class="font-bold text-winmart-dark"><%= nextTierLabel %></span></p>
                        <% } else { %>
                        <div class="w-full bg-gray-100 rounded-full h-1.5 mb-2 overflow-hidden">
                            <div class="bg-gradient-to-r from-purple-500 to-fuchsia-500 h-1.5 rounded-full transition-all duration-1000" style="width: 100%"></div>
                        </div>
                        <p class="text-xs font-semibold text-purple-600 font-bold"><i data-lucide="star" class="w-3 h-3 inline mb-0.5"></i> Đã đạt hạng thẻ cao nhất</p>
                        <% } %>
                    </div>
                </div>

                <!-- Update Info Form -->
                <div class="bento-card p-6 lg:p-8">
                    <h3 class="text-sm font-black text-winmart-dark mb-6 flex items-center gap-2">
                        <div class="w-1.5 h-4 bg-winmart-red rounded-full"></div>
                        Cập nhật thông tin
                    </h3>

                    <form action="/profile/update" method="POST" class="space-y-5">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                            <div>
                                <label class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-1.5 ml-1">Họ và tên</label>
                                <div class="relative">
                                    <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                                        <i data-lucide="user" class="w-4 h-4 text-gray-400"></i>
                                    </div>
                                    <input type="text" name="fullName" value="<%= profileData.HoTen || '' %>"
                                           class="w-full pl-11 pr-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-sm font-bold text-winmart-dark focus:outline-none focus:border-winmart-red focus:bg-white transition-all">
                                </div>
                            </div>
                            <div>
                                <label class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-1.5 ml-1">Số điện thoại</label>
                                <div class="relative">
                                    <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                                        <i data-lucide="phone" class="w-4 h-4 text-gray-400"></i>
                                    </div>
                                    <input type="tel" name="phone" value="<%= profileData.SoDienThoai || '' %>"
                                           class="w-full pl-11 pr-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-sm font-bold text-winmart-dark focus:outline-none focus:border-winmart-red focus:bg-white transition-all">
                                </div>
                            </div>
                            <div class="md:col-span-2">
                                <label class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-1.5 ml-1">Email</label>
                                <div class="relative">
                                    <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                                        <i data-lucide="mail" class="w-4 h-4 text-gray-400"></i>
                                    </div>
                                    <input type="email" name="email" value="<%= profileData.Email || '' %>"
                                           class="w-full pl-11 pr-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-sm font-bold text-winmart-dark focus:outline-none focus:border-winmart-red focus:bg-white transition-all">
                                </div>
                            </div>
                        </div>

                        <% if (typeof success !== 'undefined' && success) { %>
                        <div class="p-4 mb-4 text-sm text-emerald-800 rounded-xl bg-emerald-50 font-semibold border border-emerald-200">
                            <%= success %>
                        </div>
                        <% } %>
                        <% if (typeof error !== 'undefined' && error) { %>
                        <div class="p-4 mb-4 text-sm text-red-800 rounded-xl bg-red-50 font-semibold border border-red-200">
                            <%= error %>
                        </div>
                        <% } %>

                        <div class="pt-4 border-t border-gray-100 flex justify-end gap-3">
                            <button type="button" class="px-6 py-2.5 rounded-xl text-sm font-bold text-gray-500 hover:bg-gray-100 transition-colors">
                                Hủy bỏ
                            </button>
                            <button type="submit" class="bg-winmart-dark hover:bg-gray-800 text-white px-6 py-2.5 rounded-xl text-sm font-bold shadow-lg shadow-gray-900/20 transition-all flex items-center gap-2">
                                <i data-lucide="save" class="w-4 h-4"></i> Lưu thay đổi
                            </button>
                        </div>
                    </form>
                </div>
            </main>
        </div>
    </div>
</div>
