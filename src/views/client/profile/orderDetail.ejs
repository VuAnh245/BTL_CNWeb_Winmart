<div class="container mx-auto px-4 py-8 mb-20 max-w-5xl">
    <!-- Breadcrumb -->
    <nav class="flex text-sm text-gray-500 mb-8" aria-label="Breadcrumb">
        <ol class="inline-flex items-center space-x-1 md:space-x-3">
            <li class="inline-flex items-center">
                <a href="/" class="hover:text-winmart-red transition-colors flex items-center gap-1.5">
                    <i data-lucide="home" class="w-4 h-4"></i> Trang chủ
                </a>
            </li>
            <li>
                <div class="flex items-center">
                    <i data-lucide="chevron-right" class="w-4 h-4 mx-1"></i>
                    <a href="/profile/orders" class="hover:text-winmart-red transition-colors">Đơn hàng của tôi</a>
                </div>
            </li>
            <li aria-current="page">
                <div class="flex items-center">
                    <i data-lucide="chevron-right" class="w-4 h-4 mx-1"></i>
                    <span class="font-bold text-winmart-dark">Chi tiết <%= order.MaHoaDon %></span>
                </div>
            </li>
        </ol>
    </nav>

    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
        <div>
            <h1 class="text-2xl font-black text-winmart-dark tracking-tight flex items-center gap-3">
                Chi tiết đơn hàng
                <%- getStatusBadge(order.TrangThai, order.PhuongThucTT) %>
            </h1>
            <p class="text-sm text-gray-500 font-medium mt-2">
                Đã đặt vào lúc <%= new Date(order.NgayLap).toLocaleString('vi-VN') %>
            </p>
        </div>
        <a href="/profile/orders" class="text-sm font-bold text-gray-500 hover:text-winmart-dark transition-colors flex items-center gap-1.5 bg-white border border-gray-200 px-4 py-2 rounded-xl hover:bg-gray-50">
            <i data-lucide="arrow-left" class="w-4 h-4"></i> Quay lại lịch sử
        </a>
    </div>

    <% 
        let tongVAT = 0;
        details.forEach(item => {
            const itemTotal = item.SoLuong * item.DonGiaGoc;
            const discount = item.PhanTramGiam ? itemTotal * (item.PhanTramGiam / 100) : 0;
            const vatRate = item.ThueVATApDung || 0;
            tongVAT += (itemTotal - discount) * (vatRate / 100);
        });
        
        const phiShip = Number(order.PhiShip) || 0;
        const isOnline = (order.MaLoaiHinh || '').toUpperCase() === 'ONLINE' || (order.MaLoaiHinh || '').toUpperCase() === 'WEB';
        let tienGiam = 0;
        if (isOnline) {
            tienGiam = Number(order.TongTienTruocKM) + phiShip - Number(order.TongTienSauKM);
        } else {
            tienGiam = Number(order.TongTienTruocKM) + tongVAT + phiShip - Number(order.TongTienSauKM); 
        }

        // Parse GhiChu to separate custom notes and timeline events
        const noteLines = (order.GhiChu || '').split('\n').map(l => l.trim()).filter(l => l);
        const timelineEvents = [];
        const customNotes = [];
        
        const translateAction = (actionText) => {
            return actionText
                .replace(/\bPending\b/g, order.PhuongThucTT === 'TienMat' ? 'Chờ xử lý' : 'Chờ thanh toán')
                .replace(/\bPaid\b/g, 'Đã thanh toán')
                .replace(/\bDelivering\b/g, 'Đang giao hàng')
                .replace(/\bCompleted\b/g, 'Hoàn thành')
                .replace(/\bCancelled_Return\b/g, 'Hủy & Hoàn hàng')
                .replace(/\bCancelled\b/g, 'Đã hủy')
                .replace(/\bRefunded\b/g, 'Đã hoàn tiền')
                .replace(/\bTest update status completed\b/g, 'Kiểm thử cập nhật trạng thái hoàn tất');
        };

        noteLines.forEach(line => {
            const trimmed = line.trim();
            // 1. Filter out weight and shipping fee log (handles standard and no-accent versions)
            if (trimmed.match(/^\[Trong\s+lượng|^\[Trọng\s+lượng/i)) {
                return;
            }
            
            // 2. Match standard timestamp prefixes (e.g. [2026-06-05 16:58] or [2026-06-05])
            const timestampMatch = trimmed.match(/^\[(\d{4}-\d{2}-\d{2}(?:\s+\d{2}:\d{2}(?::\d{2})?)?)\]\s*(.*)$/);
            if (timestampMatch) {
                timelineEvents.push({ 
                    time: timestampMatch[1], 
                    action: translateAction(timestampMatch[2]) 
                });
                return;
            }
            
            // 3. Fallback: check if the line starts with '[' and looks like a system log
            if (trimmed.startsWith('[') && trimmed.endsWith(']')) {
                timelineEvents.push({
                    time: '',
                    action: translateAction(trimmed.slice(1, -1))
                });
                return;
            }
            
            // 4. Otherwise it's a customer note
            customNotes.push(trimmed);
        });

        // Add order creation event at the beginning
        const createdDate = new Date(order.NgayLap);
        timelineEvents.unshift({
            time: createdDate.toLocaleString('vi-VN', { year: 'numeric', month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit' }),
            action: 'Đơn hàng được đặt thành công'
        });
    %>

    <!-- Order Progress Stepper -->
    <% if (['Cancelled', 'Cancelled_Return', 'Refunded'].includes(order.TrangThai)) { %>
        <!-- Cancelled State Banner -->
        <div class="bento-card bg-red-50 border border-red-100 p-6 md:p-8 rounded-3xl shadow-sm mb-8 flex items-center gap-4">
            <div class="w-12 h-12 bg-red-100 text-red-500 rounded-full flex items-center justify-center shrink-0">
                <i data-lucide="alert-triangle" class="w-6 h-6 animate-pulse"></i>
            </div>
            <div>
                <h3 class="text-base font-black text-red-800">Đơn hàng đã bị hủy / hoàn trả</h3>
                <p class="text-sm text-red-600/90 font-medium mt-1">
                    Đơn hàng này đã bị hủy hoặc hoàn trả. Nếu bạn đã thanh toán trực tuyến, số tiền sẽ được xử lý hoàn lại theo quy định của WinMart.
                </p>
            </div>
        </div>
    <% } else { %>
        <div class="bento-card bg-white p-6 md:p-8 rounded-3xl shadow-sm border border-gray-100 mb-8">
            <div class="max-w-3xl mx-auto relative px-4">
                <!-- Progress Line -->
                <% 
                    const getStepperProgressWidth = (status) => {
                        switch(status) {
                            case 'Pending': return 0;
                            case 'Paid': return 33;
                            case 'Delivering': return 66;
                            case 'Completed': return 100;
                            default: return 0;
                        }
                    };
                    const progressWidth = getStepperProgressWidth(order.TrangThai);
                %>
                <div class="absolute left-10 right-10 top-[22px] h-1 bg-gray-100 -z-0 rounded-full overflow-hidden">
                    <div class="h-full bg-gradient-to-r from-winmart-red to-purple-600 transition-all duration-500" style="width: <%= progressWidth %>%"></div>
                </div>
                
                <!-- Steps -->
                <% 
                    const steps = [
                        { key: 'placed', label: 'Đặt hàng', icon: 'shopping-bag', active: true },
                        { key: 'confirmed', label: 'Xác nhận', icon: 'check-square', active: ['Paid', 'Delivering', 'Completed'].includes(order.TrangThai) || (order.PhuongThucTT === 'TienMat' && ['Pending', 'Delivering', 'Completed'].includes(order.TrangThai)) },
                        { key: 'delivering', label: 'Đang giao', icon: 'truck', active: ['Delivering', 'Completed'].includes(order.TrangThai) },
                        { key: 'completed', label: 'Hoàn thành', icon: 'check-circle', active: order.TrangThai === 'Completed' }
                    ];
                %>
                <div class="relative flex items-center justify-between z-10">
                    <% steps.forEach((step, index) => { %>
                        <div class="flex flex-col items-center">
                            <div class="w-11 h-11 rounded-full flex items-center justify-center transition-all duration-300 bg-white border-2 <%= step.active ? 'border-winmart-red text-winmart-red font-bold shadow-md shadow-winmart-red/10 scale-105' : 'border-gray-200 text-gray-400' %>">
                                <i data-lucide="<%= step.icon %>" class="w-5 h-5"></i>
                            </div>
                            <span class="text-xs font-bold mt-2.5 tracking-tight <%= step.active ? 'text-winmart-dark font-black' : 'text-gray-400' %>"><%= step.label %></span>
                        </div>
                    <% }) %>
                </div>
            </div>
        </div>
    <% } %>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Cột trái: Sản phẩm & Giao hàng -->
        <div class="lg:col-span-2 space-y-8">
            <!-- Danh sách sản phẩm -->
            <div class="bento-card bg-white p-6 md:p-8 rounded-3xl shadow-sm border border-gray-100">
                <h3 class="text-sm font-black text-winmart-dark uppercase tracking-widest mb-6 flex items-center gap-2">
                    <i data-lucide="package" class="w-5 h-5 text-winmart-red"></i> Sản phẩm đã mua (<%= details.length %>)
                </h3>

                <div class="space-y-4">
                    <% details.forEach(item => { %>
                        <div class="flex gap-5 p-4 border border-gray-100 rounded-2xl bg-gray-50/50 hover:bg-gray-50 transition-colors">
                            <div class="w-24 h-24 rounded-xl bg-white shrink-0 overflow-hidden border border-gray-100 flex items-center justify-center p-2 relative">
                                <img src="<%= item.HinhAnh %>" alt="<%= item.TenSanPham %>" class="w-full h-full object-contain">
                                <span class="absolute top-2 right-2 bg-winmart-red text-white text-[10px] font-bold px-1.5 py-0.5 rounded-full"><%= item.SoLuong %></span>
                            </div>
                            <div class="flex-1 flex flex-col justify-center">
                                <h4 class="text-base font-bold text-winmart-dark line-clamp-2 mb-1"><%= item.TenSanPham %></h4>
                                
                                <% if (item.PhanTramGiam > 0) { %>
                                    <div class="mb-2">
                                        <span class="text-xs font-bold text-winmart-red bg-red-50 px-2 py-0.5 rounded border border-red-100">Giảm <%= item.PhanTramGiam %>%</span>
                                    </div>
                                <% } %>

                                <div class="flex justify-between items-end mt-auto">
                                    <div class="text-sm">
                                        <span class="font-semibold text-gray-500">Đơn giá: </span>
                                        <span class="font-bold text-winmart-dark"><%= Number(item.DonGiaGoc).toLocaleString('vi-VN') %>đ</span>
                                    </div>
                                    <span class="text-base font-black text-winmart-red"><%= Number(item.ThanhTienCuoi).toLocaleString('vi-VN') %>đ</span>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>

            <!-- Thông tin giao hàng & Thanh toán -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div class="bento-card bg-white p-6 rounded-3xl shadow-sm border border-gray-100 h-full">
                    <h3 class="text-xs font-black text-gray-400 uppercase tracking-widest mb-4 flex items-center gap-2">
                        <i data-lucide="map-pin" class="w-4 h-4"></i> Giao hàng đến
                    </h3>
                    <p class="text-sm font-bold text-winmart-dark leading-relaxed mb-3">
                        <%= order.DiaChiNhan || 'Không có địa chỉ (Mua tại cửa hàng)' %>
                    </p>
                    <% if (order.TenNguoiNhan || order.SdtNguoiNhan) { %>
                        <div class="text-xs text-gray-500 font-semibold space-y-1 mb-3">
                            <% if (order.TenNguoiNhan) { %>
                                <p>Người nhận: <span class="font-bold text-gray-700"><%= order.TenNguoiNhan %></span></p>
                            <% } %>
                            <% if (order.SdtNguoiNhan) { %>
                                <p>Số điện thoại: <span class="font-bold text-gray-700"><%= order.SdtNguoiNhan %></span></p>
                            <% } %>
                        </div>
                    <% } %>
                    <% if (customNotes.length > 0) { %>
                        <div class="mt-4 pt-4 border-t border-gray-100">
                            <p class="text-[10px] font-bold text-yellow-600 uppercase tracking-wider mb-1">Ghi chú của bạn</p>
                            <p class="text-xs text-gray-600 font-medium italic"><%= customNotes.join('\n') %></p>
                        </div>
                    <% } %>
                </div>

                <div class="bento-card bg-white p-6 rounded-3xl shadow-sm border border-gray-100 h-full">
                    <h3 class="text-xs font-black text-gray-400 uppercase tracking-widest mb-4 flex items-center gap-2">
                        <i data-lucide="credit-card" class="w-4 h-4"></i> Thanh toán
                    </h3>
                    <div class="flex items-center gap-4">
                        <% if (order.PhuongThucTT === 'TienMat') { %>
                            <div class="w-12 h-12 bg-emerald-50 border border-emerald-100 rounded-2xl flex items-center justify-center text-emerald-600">
                                <i data-lucide="banknote" class="w-6 h-6"></i>
                            </div>
                            <div>
                                <p class="text-sm font-bold text-winmart-dark">Tiền mặt (COD)</p>
                                <p class="text-xs text-gray-500 font-medium mt-1">Thanh toán khi nhận hàng</p>
                            </div>
                        <% } else { %>
                            <div class="w-12 h-12 bg-blue-50 border border-blue-100 rounded-2xl flex items-center justify-center text-blue-600">
                                <i data-lucide="qr-code" class="w-6 h-6"></i>
                            </div>
                            <div>
                                <p class="text-sm font-bold text-winmart-dark">Chuyển khoản</p>
                                <p class="text-xs text-gray-500 font-medium mt-1">Đã thanh toán online</p>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>

            <!-- Lịch sử giao hàng & Trạng thái đơn hàng -->
            <div class="bento-card bg-white p-6 md:p-8 rounded-3xl shadow-sm border border-gray-100 mt-8">
                <h3 class="text-sm font-black text-winmart-dark uppercase tracking-widest mb-6 flex items-center gap-2">
                    <i data-lucide="history" class="w-5 h-5 text-winmart-red"></i> Trạng thái & Lịch sử giao nhận
                </h3>

                <% if (order.GHNOrderCode) { %>
                    <div class="mb-6 p-4 bg-blue-50/50 border border-blue-100 rounded-2xl flex flex-col sm:flex-row justify-between items-start sm:items-center gap-3">
                        <div class="flex items-center gap-2.5">
                            <div class="w-10 h-10 rounded-xl bg-blue-100 text-blue-600 flex items-center justify-center shrink-0">
                                <i data-lucide="truck" class="w-5 h-5"></i>
                            </div>
                            <div>
                                <p class="text-[10px] text-gray-400 font-bold uppercase tracking-wider">Đơn vị vận chuyển: GHN</p>
                                <p class="text-sm font-black text-winmart-dark mt-0.5">Mã vận đơn: <span class="font-mono text-blue-600"><%= order.GHNOrderCode %></span></p>
                            </div>
                        </div>
                        <a href="https://donhang.ghn.vn/?order_code=<%= order.GHNOrderCode %>" target="_blank" class="text-xs font-bold text-blue-600 hover:text-blue-800 transition-colors flex items-center gap-1.5 bg-white border border-blue-200 px-4 py-2 rounded-xl shadow-sm">
                            <i data-lucide="external-link" class="w-4 h-4"></i> Theo dõi trên GHN
                        </a>
                    </div>
                <% } %>

                <div class="relative pl-2 mt-4 space-y-0">
                    <% timelineEvents.forEach((event, idx) => { %>
                        <div class="relative pl-8 pb-6 last:pb-0 group">
                            <!-- Line -->
                            <div class="absolute left-3.5 -translate-x-1/2 top-5 bottom-0 w-0.5 bg-gray-100 group-last:hidden"></div>
                            
                            <!-- Timeline Dot -->
                            <% 
                                let dotColor = 'bg-gray-50 text-gray-400 border-gray-200';
                                let dotIcon = 'circle';
                                
                                const actionText = event.action.toLowerCase();
                                if (actionText.includes('đặt thành công') || actionText.includes('đặt hàng')) {
                                    dotColor = 'bg-emerald-50 text-emerald-600 border-emerald-200';
                                    dotIcon = 'shopping-bag';
                                } else if (actionText.includes('thanh toán') || actionText.includes('paid')) {
                                    dotColor = 'bg-blue-50 text-blue-600 border-blue-200';
                                    dotIcon = 'credit-card';
                                } else if (actionText.includes('tạo đơn vận chuyển ghn') || actionText.includes('ghn')) {
                                    dotColor = 'bg-orange-50 text-orange-600 border-orange-200';
                                    dotIcon = 'truck';
                                } else if (actionText.includes('chuyển trạng thái') || actionText.includes('delivering')) {
                                    dotColor = 'bg-purple-50 text-purple-600 border-purple-200';
                                    dotIcon = 'package-check';
                                } else if (actionText.includes('lỗi')) {
                                    dotColor = 'bg-red-50 text-red-600 border-red-200 animate-pulse';
                                    dotIcon = 'alert-circle';
                                } else if (actionText.includes('hủy') || actionText.includes('cancelled')) {
                                    dotColor = 'bg-red-50 text-red-600 border-red-200';
                                    dotIcon = 'x-circle';
                                } else if (actionText.includes('hoàn thành') || actionText.includes('completed')) {
                                    dotColor = 'bg-emerald-50 text-emerald-600 border-emerald-200';
                                    dotIcon = 'check-circle';
                                }
                            %>
                            <div class="absolute left-3.5 -translate-x-1/2 top-1.5 w-7 h-7 rounded-full flex items-center justify-center border bg-white <%= dotColor %> shadow-sm z-10 transition-colors duration-300">
                                <i data-lucide="<%= dotIcon %>" class="w-3.5 h-3.5"></i>
                            </div>
                            
                            <!-- Content -->
                            <div class="pl-3">
                                <div class="text-[10px] font-bold text-gray-400 mb-0.5"><%= event.time %></div>
                                <div class="text-sm font-bold text-gray-700 leading-snug"><%= event.action %></div>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>
        </div>

        <!-- Cột phải: Tổng kết đơn hàng -->
        <div class="lg:col-span-1">
            <div class="bento-card bg-white p-6 md:p-8 rounded-3xl shadow-sm border border-gray-100 sticky top-24">
                <h3 class="text-sm font-black text-winmart-dark uppercase tracking-widest mb-6 flex items-center gap-2">
                    <i data-lucide="receipt" class="w-5 h-5 text-winmart-red"></i> Tổng kết đơn hàng
                </h3>
                
                <div class="space-y-4 text-sm mb-6">
                    <div class="flex justify-between items-center">
                        <span class="text-gray-500 font-medium">Mã đơn hàng:</span>
                        <span class="font-bold text-winmart-dark"><%= order.MaHoaDon %></span>
                    </div>
                    
                    <div class="h-px w-full bg-gray-100 my-2"></div>

                    <div class="flex justify-between items-center">
                        <span class="text-gray-500 font-medium">Tổng tiền hàng:</span>
                        <span class="font-bold text-winmart-dark"><%= Number(order.TongTienTruocKM).toLocaleString('vi-VN') %>đ</span>
                    </div>

                    <% if (tongVAT > 0) { %>
                        <div class="flex justify-between items-center">
                            <span class="text-gray-500 font-medium">Thuế GTGT (VAT<%= isOnline ? ' đã gồm' : '' %>):</span>
                            <span class="font-bold text-blue-600"><%= Number(Math.round(tongVAT)).toLocaleString('vi-VN') %>đ</span>
                        </div>
                    <% } %>

                    <% if (order.LoaiGiao === 'Ship') { %>
                        <% if (typeof order.baseFee !== 'undefined') { %>
                            <div class="flex justify-between items-center text-xs text-gray-500 ml-2">
                                <span>+ Phí nền giao hàng GHN (<%= order.totalWeight %>g):</span>
                                <span><%= order.baseFee.toLocaleString('vi-VN') %>đ</span>
                            </div>
                            <% if (order.freshFee > 0) { %>
                                <div class="flex justify-between items-center text-xs text-gray-500 ml-2">
                                    <span>+ Phụ phí hàng tươi sống:</span>
                                    <span><%= order.freshFee.toLocaleString('vi-VN') %>đ</span>
                                </div>
                            <% } %>
                            <% if (order.packagingFee > 0) { %>
                                <div class="flex justify-between items-center text-xs text-gray-500 ml-2">
                                    <span>+ Phụ phí đóng gói đặc biệt:</span>
                                    <span><%= order.packagingFee.toLocaleString('vi-VN') %>đ</span>
                                </div>
                            <% } %>
                            <% if (order.discount > 0) { %>
                                <div class="flex justify-between items-center text-xs text-emerald-600 ml-2">
                                    <span>- Miễn phí giao hàng:</span>
                                    <span>-<%= order.discount.toLocaleString('vi-VN') %>đ</span>
                                </div>
                            <% } %>
                        <% } %>
                        <div class="flex justify-between items-center mt-1">
                            <span class="text-gray-500 font-medium">Tổng phí vận chuyển:</span>
                            <span class="font-bold text-gray-700"><%= phiShip > 0 ? phiShip.toLocaleString('vi-VN') + 'đ' : 'Miễn phí' %></span>
                        </div>
                    <% } %>

                    <% if (tienGiam > 0) { %>
                        <div class="flex justify-between items-center">
                            <span class="text-gray-500 font-medium">Chiết khấu / Giảm giá:</span>
                            <span class="font-bold text-winmart-red">-<%= Math.round(Number(tienGiam)).toLocaleString('vi-VN') %>đ</span>
                        </div>
                    <% } %>

                    <% if (order.DiemSuDung > 0) { %>
                        <div class="flex justify-between items-center">
                            <span class="text-gray-500 font-medium">Dùng điểm thưởng:</span>
                            <span class="font-bold text-blue-600">-<%= order.DiemSuDung %> điểm</span>
                        </div>
                    <% } %>
                </div>

                <div class="pt-6 border-t border-dashed border-gray-200">
                    <div class="flex justify-between items-center mb-1">
                        <span class="text-xs font-black text-gray-400 uppercase tracking-widest">Tổng thanh toán</span>
                        <span class="text-2xl font-black text-winmart-red"><%= Number(order.TongTienSauKM).toLocaleString('vi-VN') %>đ</span>
                    </div>
                    <p class="text-[11px] text-gray-400 text-right mt-1">(Đã bao gồm VAT nếu có)</p>
                </div>

                <% if (order.TrangThai === 'Pending') { %>
                <div class="mt-6">
                    <button type="button" onclick="openCancelModal()" class="w-full bg-white text-red-600 border border-red-200 hover:bg-red-50 hover:border-red-300 font-bold py-3 rounded-xl transition-colors flex items-center justify-center gap-2">
                        <i data-lucide="x-circle" class="w-5 h-5"></i> Hủy Đơn Hàng
                    </button>
                </div>
                <% } %>
            </div>
        </div>
    </div>
</div>

<!-- ====================================================== -->
<!-- CANCEL CONFIRMATION MODAL -->
<!-- ====================================================== -->
<% if (order.TrangThai === 'Pending') { %>
<div id="cancel-modal" class="fixed inset-0 z-50 flex items-center justify-center pointer-events-none opacity-0 transition-opacity duration-300">
    <div class="absolute inset-0 bg-gray-900/60 backdrop-blur-sm" onclick="closeCancelModal()"></div>
    
    <div id="cancel-content" class="relative bg-white w-full max-w-md rounded-3xl shadow-2xl p-8 overflow-hidden transform scale-95 translate-y-4 transition-all duration-300 z-10">
        <!-- Icon -->
        <div class="w-16 h-16 bg-red-50 text-red-500 rounded-full flex items-center justify-center mx-auto mb-5">
            <i data-lucide="alert-triangle" class="w-8 h-8"></i>
        </div>
        
        <!-- Header -->
        <div class="text-center mb-8">
            <h2 class="text-xl font-black text-winmart-dark mb-2">Xác nhận hủy đơn hàng?</h2>
            <p class="text-sm text-gray-500 font-medium">Bạn có chắc chắn muốn hủy đơn hàng <strong><%= order.MaHoaDon %></strong> không? Số tiền đã thanh toán (nếu có) sẽ được xử lý hoàn lại theo quy định.</p>
        </div>

        <!-- Actions -->
        <form action="/profile/orders/<%= order.HoaDonId %>/cancel" method="POST">
            <!-- Lý do hủy -->
            <div class="mb-6 text-left">
                <label for="cancelReason" class="block text-xs font-bold text-gray-700 mb-2">Lý do hủy đơn hàng (tùy chọn)</label>
                <textarea id="cancelReason" name="cancelReason" rows="2" class="w-full bg-gray-50 border border-gray-200 rounded-xl p-3 text-sm focus:outline-none focus:border-winmart-red focus:bg-white transition-colors" placeholder="Ví dụ: Đổi ý không muốn mua nữa..."></textarea>
            </div>
            
            <div class="flex gap-3">
                <button type="button" onclick="closeCancelModal()" class="flex-1 bg-gray-100 hover:bg-gray-200 text-gray-600 font-bold py-3 rounded-xl transition-colors">
                    Trở lại
                </button>
                <button type="submit" class="flex-1 bg-winmart-red hover:bg-red-700 text-white font-bold py-3 rounded-xl transition-colors shadow-lg shadow-winmart-red/30">
                    Đồng ý Hủy
                </button>
            </div>
        </form>
    </div>
</div>

<script>
    function openCancelModal() {
        const modal = document.getElementById('cancel-modal');
        const content = document.getElementById('cancel-content');
        modal.classList.remove('pointer-events-none', 'opacity-0');
        content.classList.remove('scale-95', 'translate-y-4');
    }
    
    function closeCancelModal() {
        const modal = document.getElementById('cancel-modal');
        const content = document.getElementById('cancel-content');
        content.classList.add('scale-95', 'translate-y-4');
        setTimeout(() => {
            modal.classList.add('pointer-events-none', 'opacity-0');
        }, 200);
    }
</script>
<% } %>
