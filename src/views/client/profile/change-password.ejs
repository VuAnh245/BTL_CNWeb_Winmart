<div class="bg-gray-50 min-h-screen pt-12 pb-24">
    <div class="container mx-auto px-4 max-w-5xl">
        <!-- Breadcrumb -->
        <nav class="flex text-sm text-gray-500 mb-8" aria-label="Breadcrumb">
            <ol class="inline-flex items-center space-x-1 md:space-x-3">
                <li class="inline-flex items-center">
                    <a href="/" class="hover:text-winmart-red transition-colors flex items-center gap-1.5">
                        <i data-lucide="home" class="w-4 h-4"></i> Trang chủ
                    </a>
                </li>
                <li aria-current="page">
                    <div class="flex items-center">
                        <i data-lucide="chevron-right" class="w-4 h-4 mx-1"></i>
                        <span class="font-bold text-winmart-dark">Đổi mật khẩu</span>
                    </div>
                </li>
            </ol>
        </nav>

        <div class="flex flex-col md:flex-row gap-8">
            
            <!-- Sidebar Menu -->
            <div class="w-full md:w-64 shrink-0">
                <div class="bento-card p-4 sticky top-24">
                    <nav class="space-y-1 flex flex-col gap-1.5">
                        <a href="/profile" class="flex items-center gap-3 px-4 py-3 rounded-xl text-gray-500 hover:bg-gray-50 hover:text-winmart-dark font-bold text-sm transition-all">
                            <i data-lucide="user" class="w-4 h-4"></i> Thông tin tài khoản
                        </a>
                        <a href="/profile/orders" class="flex items-center gap-3 px-4 py-3 rounded-xl text-gray-500 hover:bg-gray-50 hover:text-winmart-dark font-bold text-sm transition-all">
                            <i data-lucide="package" class="w-4 h-4"></i> Đơn hàng của tôi
                        </a>
                        <a href="javascript:void(0)" onclick="goToWishlist()" class="flex items-center gap-3 px-4 py-3 rounded-xl text-gray-500 hover:bg-gray-50 hover:text-winmart-dark font-bold text-sm transition-all">
                            <i data-lucide="heart" class="w-4 h-4"></i> Sản phẩm yêu thích
                        </a>
                        <a href="/profile/address" class="flex items-center gap-3 px-4 py-3 rounded-xl text-gray-500 hover:bg-gray-50 hover:text-winmart-dark font-bold text-sm transition-all">
                            <i data-lucide="map-pin" class="w-4 h-4"></i> Sổ địa chỉ
                        </a>
                        <a href="/profile/change-password" class="flex items-center gap-3 px-4 py-3 bg-winmart-red/10 text-winmart-red rounded-xl font-bold text-sm transition-all">
                            <i data-lucide="key" class="w-4 h-4"></i> Đổi mật khẩu
                        </a>
                        <div class="my-2 border-t border-gray-100"></div>
                        <a href="/auth/logout" class="flex items-center gap-3 px-4 py-3 rounded-xl text-red-500 hover:bg-red-50 font-bold text-sm transition-all">
                            <i data-lucide="log-out" class="w-4 h-4"></i> Đăng xuất
                        </a>
                    </nav>
                </div>
            </div>

            <!-- Main Content -->
            <div class="flex-1">
                <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-8">
                    <div class="mb-8">
                        <h2 class="text-2xl font-black text-winmart-dark tracking-tight">Đổi mật khẩu</h2>
                        <p class="text-gray-500 font-medium text-sm mt-1">Để bảo mật tài khoản, vui lòng không chia sẻ mật khẩu cho người khác</p>
                    </div>

                    <form id="change-password-form" class="max-w-md space-y-6">
                        <div>
                            <label class="block text-xs font-bold text-gray-700 uppercase tracking-wide mb-2">Mật khẩu hiện tại</label>
                            <input type="password" id="currentPassword" required class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-sm font-bold text-winmart-dark focus:outline-none focus:border-winmart-red focus:bg-white transition-all">
                        </div>

                        <div>
                            <label class="block text-xs font-bold text-gray-700 uppercase tracking-wide mb-2">Mật khẩu mới</label>
                            <input type="password" id="newPassword" required minlength="6" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-sm font-bold text-winmart-dark focus:outline-none focus:border-winmart-red focus:bg-white transition-all">
                        </div>

                        <div>
                            <label class="block text-xs font-bold text-gray-700 uppercase tracking-wide mb-2">Xác nhận mật khẩu mới</label>
                            <input type="password" id="confirmPassword" required minlength="6" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-sm font-bold text-winmart-dark focus:outline-none focus:border-winmart-red focus:bg-white transition-all">
                        </div>

                        <div class="pt-4">
                            <button type="submit" id="btn-change-password" class="px-8 py-3 bg-winmart-red hover:bg-red-700 text-white font-bold rounded-xl text-sm transition-all shadow-md hover:shadow-lg flex items-center justify-center min-w-[160px]">
                                Xác nhận
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const form = document.getElementById('change-password-form');
        if (form) {
            form.addEventListener('submit', async (e) => {
                e.preventDefault();
                const btn = document.getElementById('btn-change-password');
                const originalText = btn.innerHTML;
                
                const currentPassword = document.getElementById('currentPassword').value;
                const newPassword = document.getElementById('newPassword').value;
                const confirmPassword = document.getElementById('confirmPassword').value;
                
                if (newPassword !== confirmPassword) {
                    showWmToast('Mật khẩu xác nhận không khớp', 'error');
                    return;
                }
                
                btn.innerHTML = '<i data-lucide="loader-2" class="w-4 h-4 animate-spin mr-2 inline"></i> Đang xử lý...';
                btn.disabled = true;
                if(typeof lucide !== 'undefined') lucide.createIcons();
                
                try {
                    const res = await fetch('/profile/change-password', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ currentPassword, newPassword, confirmPassword })
                    });
                    
                    const data = await res.json();
                    if (data.success) {
                        showWmToast(data.message);
                        form.reset();
                        // Optional: Logout and redirect to login
                        setTimeout(() => {
                            window.location.href = '/auth/login?modal=login';
                        }, 2000);
                    } else {
                        showWmToast(data.message, 'error');
                    }
                } catch (err) {
                    showWmToast('Lỗi kết nối máy chủ', 'error');
                } finally {
                    btn.innerHTML = originalText;
                    btn.disabled = false;
                }
            });
        }
    });
</script>
