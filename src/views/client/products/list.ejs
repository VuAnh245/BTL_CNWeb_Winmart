<div class="bg-gray-50 min-h-screen pt-8 pb-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <!-- Breadcrumb -->
        <nav class="flex items-center gap-2 text-xs font-semibold text-gray-500 mb-6">
            <a href="/" class="hover:text-winmart-red transition-colors flex items-center gap-1.5"><i data-lucide="home" class="w-3.5 h-3.5"></i> Trang chủ</a>
            <i data-lucide="chevron-right" class="w-3.5 h-3.5"></i>
            <span class="text-winmart-dark font-bold">Sản phẩm</span>
        </nav>

        <div class="flex flex-col lg:flex-row gap-8">
            
            <!-- Sidebar Lọc -->
            <aside class="w-full lg:w-64 shrink-0">
                <div class="bento-card p-5 mb-6 sticky top-24">
                    <h3 class="text-sm font-black text-winmart-dark mb-4 flex items-center gap-2">
                        <div class="w-1.5 h-4 bg-winmart-red rounded-full"></div>
                        Danh mục sản phẩm
                    </h3>
                    
                    <ul class="space-y-1.5">
                        <li>
                            <a href="/products" class="flex items-center justify-between px-3 py-2.5 rounded-xl text-sm transition-all <%= !filters.category ? 'bg-winmart-dark text-white font-bold shadow-md' : 'text-gray-500 hover:bg-gray-100 hover:text-winmart-dark font-semibold' %>">
                                <span>Tất cả</span>
                            </a>
                        </li>
                        <% if (categories && categories.length > 0) { %>
                            <% categories.forEach(cat => { %>
                                <li>
                                    <a href="/products?category=<%= cat.DanhMucId %>" class="flex items-center justify-between px-3 py-2.5 rounded-xl text-sm transition-all <%= (filters.category == cat.DanhMucId) ? 'bg-winmart-red text-white font-bold shadow-md shadow-winmart-red/20' : 'text-gray-500 hover:bg-gray-100 hover:text-winmart-dark font-semibold' %>">
                                        <span class="flex items-center gap-2">
                                            <i data-lucide="<%= (filters.category == cat.DanhMucId) ? 'check-circle-2' : 'chevron-right' %>" class="w-4 h-4 <%= (filters.category == cat.DanhMucId) ? 'text-white' : 'text-gray-400' %>"></i>
                                            <%= cat.TenDanhMuc %>
                                        </span>
                                    </a>
                                </li>
                            <% }) %>
                        <% } else { %>
                            <li class="px-3 py-2 text-sm text-gray-400 italic">Chưa có danh mục</li>
                        <% } %>
                    </ul>
                </div>
            </aside>

            <!-- Khung danh sách -->
            <main class="flex-1">
                
                <!-- Toolbar -->
                <div class="bento-card p-4 mb-6 flex flex-col sm:flex-row items-center justify-between gap-4">
                    <h1 class="text-xl font-black text-winmart-dark tracking-tight">
                        <%= filters.search ? `Tìm kiếm: "${filters.search}"` : 'Tất cả sản phẩm' %>
                    </h1>
                    
                    <div class="flex items-center gap-3 w-full sm:w-auto">
                        <span class="text-xs font-bold text-gray-400 uppercase tracking-widest hidden sm:block">Sắp xếp</span>
                        <div class="relative w-full sm:w-48 group">
                            <select onchange="window.location.href=this.value" class="w-full appearance-none bg-gray-50 border border-gray-200 text-winmart-dark text-sm font-bold rounded-xl px-4 py-2.5 pr-10 focus:outline-none focus:border-winmart-red cursor-pointer transition-all hover:bg-gray-100">
                                <option value="?sort=newest" <%= (!filters.sort || filters.sort === 'newest') ? 'selected' : '' %>>Mới nhất</option>
                                <option value="?sort=price_asc" <%= filters.sort === 'price_asc' ? 'selected' : '' %>>Giá: Thấp đến Cao</option>
                                <option value="?sort=price_desc" <%= filters.sort === 'price_desc' ? 'selected' : '' %>>Giá: Cao đến Thấp</option>
                            </select>
                            <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none text-gray-500 group-hover:text-winmart-dark">
                                <i data-lucide="chevron-down" class="w-4 h-4"></i>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Product Grid -->
                <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 lg:gap-6">
                    <% if (products && products.length > 0) { %>
                        <% products.forEach(p => { %>
                            <%- include('../../partials/product-card', { product: p }) %>
                        <% }) %>
                    <% } else { %>
                        <div class="col-span-full py-16 text-center bento-card">
                            <div class="w-20 h-20 bg-gray-50 rounded-full flex items-center justify-center mx-auto mb-4">
                                <i data-lucide="package-search" class="w-10 h-10 text-gray-300"></i>
                            </div>
                            <h2 class="text-lg font-black text-winmart-dark mb-2">Không tìm thấy sản phẩm</h2>
                            <p class="text-sm text-gray-500 mb-6">Thử thay đổi bộ lọc hoặc từ khóa tìm kiếm</p>
                            <a href="/products" class="inline-block bg-winmart-dark hover:bg-gray-800 text-white font-bold text-sm px-6 py-3 rounded-xl transition-colors shadow-lg">
                                Bỏ lọc
                            </a>
                        </div>
                    <% } %>
                </div>

                <!-- Phân trang -->
                <% if (meta && meta.totalPages > 1) { %>
                    <div class="mt-10 flex justify-center">
                        <nav class="inline-flex items-center gap-2 bg-white p-2 rounded-2xl shadow-sm border border-gray-100">
                            
                            <!-- Prev -->
                            <% if (meta.page > 1) { %>
                                <a href="?page=<%= meta.page - 1 %><%= filters.category ? '&category='+filters.category : '' %><%= filters.search ? '&search='+filters.search : '' %>" 
                                   class="w-10 h-10 flex items-center justify-center rounded-xl text-gray-500 hover:bg-gray-100 hover:text-winmart-dark transition-colors">
                                    <i data-lucide="chevron-left" class="w-5 h-5"></i>
                                </a>
                            <% } %>

                            <!-- Pages -->
                            <% for(let i=1; i<=meta.totalPages; i++) { %>
                                <% if (i === meta.page) { %>
                                    <span class="w-10 h-10 flex items-center justify-center rounded-xl bg-winmart-dark text-white font-black shadow-md">
                                        <%= i %>
                                    </span>
                                <% } else { %>
                                    <a href="?page=<%= i %><%= filters.category ? '&category='+filters.category : '' %><%= filters.search ? '&search='+filters.search : '' %>" 
                                       class="w-10 h-10 flex items-center justify-center rounded-xl text-gray-500 hover:bg-gray-100 hover:text-winmart-dark font-bold transition-colors">
                                        <%= i %>
                                    </a>
                                <% } %>
                            <% } %>

                            <!-- Next -->
                            <% if (meta.page < meta.totalPages) { %>
                                <a href="?page=<%= meta.page + 1 %><%= filters.category ? '&category='+filters.category : '' %><%= filters.search ? '&search='+filters.search : '' %>" 
                                   class="w-10 h-10 flex items-center justify-center rounded-xl text-gray-500 hover:bg-gray-100 hover:text-winmart-dark transition-colors">
                                    <i data-lucide="chevron-right" class="w-5 h-5"></i>
                                </a>
                            <% } %>

                        </nav>
                    </div>
                <% } %>

            </main>
        </div>
    </div>
</div>