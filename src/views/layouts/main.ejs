<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="WinMart - Hệ sinh thái bán lẻ hiện đại. Thực phẩm sạch, giao hàng siêu tốc, tích điểm thưởng hội viên.">
    <title><%= typeof title !== 'undefined' ? `${title} | WinMart` : 'WinMart - Hệ Sinh Thái Bán Lẻ' %></title>

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/images/icons/favicon.png">

    <!-- Google Fonts: Plus Jakarta Sans -->
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">

    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>

    <!-- Leaflet Map -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        winmart: {
                            red: '#E21E26',
                            redHover: '#BE1117',
                            yellow: '#FFC522',
                            dark: '#111827',
                            slate: '#6B7280'
                        }
                    },
                    fontFamily: {
                        sans: ['"Plus Jakarta Sans"', 'sans-serif']
                    }
                }
            }
        }
    </script>

    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #F8F9FA;
            scroll-behavior: smooth;
        }

        /* Glassmorphism Header */
        .glass-nav {
            background: rgba(255, 255, 255, 0.88);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border-bottom: 1px solid rgba(230, 230, 230, 0.5);
        }

        /* Hero Banner */
        .hero-bg {
            background: linear-gradient(135deg, #111827 0%, #1e293b 100%);
            position: relative;
            overflow: hidden;
        }
        .hero-bg::before {
            content: '';
            position: absolute;
            top: -50%; left: -50%;
            width: 100%; height: 100%;
            background: radial-gradient(circle, rgba(226,30,38,0.15) 0%, transparent 70%);
            border-radius: 50%;
        }

        /* Nút chính */
        .btn-primary-wm {
            background: linear-gradient(135deg, #E21E26 0%, #B91319 100%);
            box-shadow: 0 10px 25px -5px rgba(226, 30, 38, 0.3);
            transition: all 0.3s ease;
        }
        .btn-primary-wm:hover {
            transform: translateY(-2px);
            box-shadow: 0 15px 35px -5px rgba(226, 30, 38, 0.4);
        }

        /* Modal Transitions */
        #auth-modal, #location-modal { transition: opacity 0.3s ease, visibility 0.3s ease; }
        #auth-modal.modal-hidden, #location-modal.modal-hidden { opacity: 0; visibility: hidden; pointer-events: none !important; }
        #auth-modal.modal-active, #location-modal.modal-active { opacity: 1; visibility: visible; pointer-events: auto !important; }
        #auth-content, #location-content { transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1); }
        #auth-modal.modal-hidden #auth-content, #location-modal.modal-hidden #location-content { transform: scale(0.95) translateY(20px); }
        #auth-modal.modal-active #auth-content, #location-modal.modal-active #location-content { transform: scale(1) translateY(0); }

        /* Form Switching */
        .form-panel { transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1); }
        .hidden-form { opacity: 0; transform: translateX(20px); pointer-events: none; position: absolute; visibility: hidden; }
        .active-form { opacity: 1; transform: translateX(0); position: relative; visibility: visible; }

        /* Input Glow */
        .input-group-wm:focus-within i { color: #E21E26; }
    </style>
</head>
<body class="text-gray-800 antialiased relative">

    <!-- ====================================================== -->
    <!-- LOCATION MODAL -->
    <!-- ====================================================== -->
    <div id="location-modal" class="fixed inset-0 z-50 flex items-center justify-center modal-hidden pointer-events-none">
        <div class="absolute inset-0 bg-gray-900/40 backdrop-blur-sm" onclick="closeLocationModal()"></div>
        
        <div id="location-content" class="relative bg-white w-full max-w-md rounded-3xl shadow-2xl p-6 overflow-hidden transform transition-all">
            <!-- Close btn -->
            <button onclick="closeLocationModal()" class="absolute top-4 right-4 text-gray-400 hover:text-winmart-dark transition-colors bg-gray-50 hover:bg-gray-100 p-2 rounded-full z-10">
                <i data-lucide="x" class="w-5 h-5"></i>
            </button>
            
            <!-- Header -->
            <div class="text-center mb-6 mt-2">
                <h2 class="text-xl font-black text-winmart-dark">Chọn địa chỉ giao hàng</h2>
                <p class="text-gray-500 mt-1 text-[11px] font-semibold">Cắm ghim chính xác để được giao hàng nhanh nhất</p>
            </div>

            <!-- Form -->
            <div class="space-y-4">
                <!-- Khu vực chung -->
                <div class="relative">
                    <label class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-1.5 ml-1">Khu vực / Tỉnh thành</label>
                    <i data-lucide="search" class="absolute left-4 top-[30px] w-4 h-4 text-gray-400"></i>
                    <input type="text" id="global-address-input" placeholder="Ví dụ: Mỹ Hào, Hưng Yên..." class="w-full bg-gray-50 border border-gray-200 text-winmart-dark text-sm rounded-xl focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 block p-3 pl-10 font-bold" autocomplete="off">
                    
                    <!-- Dropdown gợi ý -->
                    <ul id="address-suggestions" class="absolute z-50 w-full bg-white border border-gray-100 rounded-xl shadow-2xl mt-1 hidden max-h-60 overflow-y-auto custom-scrollbar text-left">
                    </ul>
                </div>
                
                <!-- Bản đồ -->
                <div>
                    <label class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-1.5 ml-1">Chỉnh sửa vị trí chính xác trên bản đồ (*)</label>
                    <div id="header-map" class="h-40 w-full bg-gray-100 rounded-xl border border-gray-200 z-10 relative"></div>
                </div>

                <!-- Chi tiết số nhà -->
                <div>
                    <label class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-1.5 ml-1">Số nhà, ngõ/hẻm, tên toà nhà (Không bắt buộc)</label>
                    <input type="text" id="global-address-detail" placeholder="Ví dụ: Nhà trọ ABC, ngõ 123..." class="w-full bg-white border border-gray-200 text-winmart-dark text-sm rounded-xl focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 block p-3 font-bold" autocomplete="off">
                </div>
                
                <!-- Lưu địa chỉ khi gõ tự do (phòng hờ không chọn từ list) -->
                <button onclick="saveManualLocation()" class="w-full bg-emerald-500 hover:bg-emerald-600 text-white font-black rounded-xl text-sm px-5 py-3.5 mt-2 transition-all shadow-lg shadow-emerald-500/30 flex justify-center items-center gap-2">
                    XÁC NHẬN ĐỊA CHỈ
                </button>
            </div>
        </div>
    </div>

    <!-- ====================================================== -->
    <!-- NAVIGATION BAR -->
    <!-- ====================================================== -->
    <nav class="glass-nav fixed top-0 w-full z-40 transition-all duration-300">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center h-20">

                <!-- Left (Logo & Location) -->
                <div class="flex items-center gap-6 flex-1">
                    <!-- Logo -->
                    <a href="/" class="flex items-center gap-3 cursor-pointer text-decoration-none">
                        <div class="w-11 h-11 rounded-[14px] bg-winmart-red flex items-center justify-center text-white font-black text-lg shadow-lg shadow-winmart-red/30">
                            WM
                        </div>
                        <div>
                            <h1 class="text-xl font-black text-winmart-dark tracking-tight leading-none">WinMart</h1>
                            <span class="text-[10px] text-winmart-red font-bold uppercase tracking-widest">Premium Store</span>
                        </div>
                    </a>

                    <!-- Location Selector -->
                    <div onclick="openLocationModal()" class="hidden lg:flex items-center gap-2 cursor-pointer bg-gray-50 hover:bg-gray-100 rounded-xl px-3 py-2 transition-colors border border-gray-100">
                        <div class="w-8 h-8 rounded-full bg-emerald-50 text-emerald-500 flex items-center justify-center">
                            <i data-lucide="map-pin" class="w-4 h-4"></i>
                        </div>
                        <div class="flex flex-col">
                            <span class="text-[10px] text-gray-400 font-bold uppercase tracking-widest leading-none mb-1">Giao đến</span>
                            <span id="header-location-text" class="text-xs font-black text-winmart-dark leading-none">Chọn địa chỉ...</span>
                        </div>
                        <i data-lucide="chevron-down" class="w-3.5 h-3.5 text-gray-400 ml-1"></i>
                    </div>
                </div>

                <!-- Center (Main Menu) -->
                <div class="hidden md:flex items-center justify-center gap-8 text-sm font-bold text-gray-500 flex-none">
                    <%
                        const isActive = (p) => {
                            if (p === '/' && currentPath === '/') return true;
                            if (p !== '/' && currentPath.startsWith(p)) return true;
                            return false;
                        };
                        const activeClass = "text-winmart-red border-b-2 border-winmart-red pb-1";
                        const inactiveClass = "hover:text-winmart-dark transition-colors border-b-2 border-transparent pb-1";
                    %>
                    <a href="/" class="<%= isActive('/') ? activeClass : inactiveClass %>">Trang Chủ</a>
                    <% if (!isMaintenance) { %>
                    <a href="/products" class="<%= isActive('/products') ? activeClass : inactiveClass %>">Sản Phẩm</a>
                    <% } %>
                    <a href="/promotions" class="<%= isActive('/promotions') ? activeClass : inactiveClass %>">Khuyến Mãi</a>
                    <a href="/contact" class="<%= isActive('/contact') ? activeClass : inactiveClass %>">Liên Hệ</a>
                </div>

                <!-- Right (Actions) -->
                <div class="flex items-center justify-end gap-3 flex-1">
                    <!-- Yêu thích -->
                    <% if (!isMaintenance) { %>
                        <a href="javascript:void(0)" onclick="goToWishlist()" class="relative p-2 text-gray-500 hover:text-winmart-dark transition-colors mr-1">
                            <i data-lucide="heart" class="w-5 h-5"></i>
                            <span id="header-wishlist-count" class="absolute -top-0.5 -right-0.5 w-4 h-4 bg-winmart-red text-white text-[9px] font-black rounded-full flex items-center justify-center hidden">
                                0
                            </span>
                        </a>
                        
                        <% if (typeof user !== 'undefined' && user) { %>
                            <a href="/cart" class="relative p-2 text-gray-500 hover:text-winmart-dark transition-colors">
                                <i data-lucide="shopping-cart" class="w-5 h-5"></i>
                                <span id="header-cart-count" class="absolute -top-0.5 -right-0.5 w-4 h-4 bg-winmart-red text-white text-[9px] font-black rounded-full flex items-center justify-center <%= (typeof cartCount !== 'undefined' && cartCount > 0) ? '' : 'hidden' %>">
                                    <%= typeof cartCount !== 'undefined' ? cartCount : 0 %>
                                </span>
                            </a>
                        <% } else { %>
                            <button onclick="openAuthModal('login')" class="relative p-2 text-gray-500 hover:text-winmart-dark transition-colors">
                                <i data-lucide="shopping-cart" class="w-5 h-5"></i>
                                <span id="header-cart-count" class="absolute -top-0.5 -right-0.5 w-4 h-4 bg-winmart-red text-white text-[9px] font-black rounded-full flex items-center justify-center <%= (typeof cartCount !== 'undefined' && cartCount > 0) ? '' : 'hidden' %>">
                                    <%= typeof cartCount !== 'undefined' ? cartCount : 0 %>
                                </span>
                            </button>
                        <% } %>
                    <% } %>

                    <% if (typeof user !== 'undefined' && user) { %>
                        <!-- Đã đăng nhập -->
                        <div class="relative group">
                            <button class="flex items-center gap-2 bg-gray-50 hover:bg-gray-100 border border-gray-200 rounded-xl px-3 py-2 transition-all">
                                <div class="w-7 h-7 rounded-full bg-winmart-red flex items-center justify-center text-white font-black text-xs">
                                    <%= (user.HoTen || user.fullName || 'U').charAt(0).toUpperCase() %>
                                </div>
                                <span class="text-sm font-bold text-winmart-dark hidden md:block"><%= user.HoTen || user.fullName || 'Người dùng' %></span>
                                <i data-lucide="chevron-down" class="w-4 h-4 text-gray-400"></i>
                            </button>
                            <div class="absolute right-0 top-full mt-2 w-48 bg-white rounded-2xl shadow-xl border border-gray-100 p-2 invisible group-hover:visible opacity-0 group-hover:opacity-100 transition-all">
                                <a href="/profile" class="flex items-center gap-2 px-3 py-2 text-xs font-bold text-gray-600 hover:text-winmart-dark hover:bg-gray-50 rounded-xl transition-all">
                                    <i data-lucide="user" class="w-4 h-4"></i> Hồ sơ cá nhân
                                </a>
                                <a href="/profile/orders" class="flex items-center gap-2 px-3 py-2 text-xs font-bold text-gray-600 hover:text-winmart-dark hover:bg-gray-50 rounded-xl transition-all">
                                    <i data-lucide="receipt" class="w-4 h-4"></i> Đơn hàng của tôi
                                </a>
                                <hr class="border-gray-100 my-1">
                                <a href="/auth/logout" class="flex items-center gap-2 px-3 py-2 text-xs font-bold text-red-500 hover:bg-red-50 rounded-xl transition-all">
                                    <i data-lucide="log-out" class="w-4 h-4"></i> Đăng xuất
                                </a>
                            </div>
                        </div>
                    <% } else { %>
                        <!-- Chưa đăng nhập -->
                        <button onclick="openAuthModal('register')" class="hidden sm:block text-sm font-bold text-gray-500 hover:text-winmart-dark transition-colors px-3">
                            Đăng ký
                        </button>
                        <button onclick="openAuthModal('login')" class="btn-primary-wm text-white px-6 py-2.5 rounded-xl text-sm font-bold flex items-center gap-2">
                            <i data-lucide="user" class="w-4 h-4"></i> Đăng Nhập
                        </button>
                    <% } %>
                </div>
            </div>
        </div>
    </nav>

    <!-- ====================================================== -->
    <!-- MAIN CONTENT (được inject bởi EJS layout) -->
    <!-- ====================================================== -->
    <main class="pt-20">
        <% if (isMaintenance) { %>
        <div class="bg-amber-50 border-b border-amber-200">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3 flex items-center justify-center gap-3">
                <i data-lucide="alert-triangle" class="w-5 h-5 text-amber-500"></i>
                <p class="text-sm font-bold text-amber-800">
                    Tính năng mua sắm đang được bảo trì định kỳ. Bạn vẫn có thể xem các chương trình khuyến mãi và tin tức.
                </p>
            </div>
        </div>
        <% } %>
        <%- include('../partials/flash-message') %>
        <%- body %>
    </main>

    <!-- ====================================================== -->
    <!-- FOOTER -->
    <!-- ====================================================== -->
    <footer class="bg-winmart-dark text-gray-400 mt-16">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
                <!-- Brand -->
                <div class="lg:col-span-1">
                    <div class="flex items-center gap-3 mb-5">
                        <div class="w-11 h-11 rounded-[14px] bg-winmart-red flex items-center justify-center text-white font-black text-lg shadow-lg shadow-winmart-red/30">WM</div>
                        <div>
                            <div class="text-white font-black text-xl leading-none">WinMart</div>
                            <div class="text-winmart-yellow text-[10px] font-bold uppercase tracking-widest">Premium Store</div>
                        </div>
                    </div>
                    <p class="text-sm leading-relaxed mb-5">Hệ sinh thái bán lẻ WinMart cung cấp thực phẩm sạch, an toàn với quy trình kiểm định nghiêm ngặt từ nông trại đến tay người dùng.</p>
                    <div class="flex gap-2 flex-wrap">
                        <span class="bg-white/5 border border-white/10 text-xs font-semibold px-3 py-1.5 rounded-lg flex items-center gap-1.5">
                            <i data-lucide="shield-check" class="w-3.5 h-3.5 text-emerald-400"></i> ISO 22000
                        </span>
                        <span class="bg-white/5 border border-white/10 text-xs font-semibold px-3 py-1.5 rounded-lg flex items-center gap-1.5">
                            <i data-lucide="leaf" class="w-3.5 h-3.5 text-emerald-400"></i> WinEco Sạch
                        </span>
                    </div>
                </div>

                <!-- Khám Phá -->
                <div>
                    <h4 class="text-white font-black text-sm mb-5 uppercase tracking-wider flex items-center gap-2">
                        <span class="w-1 h-4 bg-winmart-red rounded-full"></span> Khám Phá
                    </h4>
                    <ul class="space-y-3 text-sm">
                        <li><a href="/" class="hover:text-white transition-all inline-flex items-center gap-1.5"><i data-lucide="home" class="w-3 h-3 opacity-50"></i> Trang chủ</a></li>
                        <li><a href="/products" class="hover:text-white transition-all inline-flex items-center gap-1.5"><i data-lucide="package" class="w-3 h-3 opacity-50"></i> Tất cả sản phẩm</a></li>
                        <li><a href="/promotions" class="hover:text-white transition-all inline-flex items-center gap-1.5"><i data-lucide="tag" class="w-3 h-3 opacity-50"></i> Khuyến mãi & Ưu đãi</a></li>
                        <li><a href="/products?sort=newest" class="hover:text-white transition-all inline-flex items-center gap-1.5"><i data-lucide="sparkles" class="w-3 h-3 opacity-50"></i> Sản phẩm mới nhất</a></li>
                        <li><a href="/contact" class="hover:text-white transition-all inline-flex items-center gap-1.5"><i data-lucide="headset" class="w-3 h-3 opacity-50"></i> Liên hệ & CSKH</a></li>
                    </ul>
                </div>

                <!-- Hỗ Trợ -->
                <div>
                    <h4 class="text-white font-black text-sm mb-5 uppercase tracking-wider flex items-center gap-2">
                        <span class="w-1 h-4 bg-winmart-yellow rounded-full"></span> Hỗ Trợ
                    </h4>
                    <ul class="space-y-3 text-sm">
                        <li><a href="/about" class="hover:text-white transition-all inline-flex items-center gap-1.5"><i data-lucide="info" class="w-3 h-3 opacity-50"></i> Về WinMart</a></li>
                        <li><a href="/cart" class="hover:text-white transition-all inline-flex items-center gap-1.5"><i data-lucide="shopping-cart" class="w-3 h-3 opacity-50"></i> Giỏ hàng</a></li>
                        <li><a href="/profile/orders" class="hover:text-white transition-all inline-flex items-center gap-1.5"><i data-lucide="receipt" class="w-3 h-3 opacity-50"></i> Tra cứu đơn hàng</a></li>
                        <li><a href="#" class="hover:text-white transition-all inline-flex items-center gap-1.5"><i data-lucide="shield" class="w-3 h-3 opacity-50"></i> Chính sách đổi trả</a></li>
                        <li><a href="#" class="hover:text-white transition-all inline-flex items-center gap-1.5"><i data-lucide="lock" class="w-3 h-3 opacity-50"></i> Bảo mật & Quyền riêng tư</a></li>
                    </ul>
                </div>

                <!-- Tài Khoản + Hotline -->
                <div>
                    <h4 class="text-white font-black text-sm mb-5 uppercase tracking-wider flex items-center gap-2">
                        <span class="w-1 h-4 bg-blue-400 rounded-full"></span> Tài Khoản
                    </h4>
                    <ul class="space-y-3 text-sm mb-6">
                        <li>
                            <button onclick="openAuthModal('login')" class="hover:text-white transition-all inline-flex items-center gap-1.5 w-full text-left">
                                <i data-lucide="log-in" class="w-3 h-3 opacity-50"></i> Đăng nhập
                            </button>
                        </li>
                        <li>
                            <button onclick="openAuthModal('register')" class="hover:text-white transition-all inline-flex items-center gap-1.5 w-full text-left">
                                <i data-lucide="user-plus" class="w-3 h-3 opacity-50"></i> Đăng ký Hội viên
                            </button>
                        </li>
                        <li><a href="/profile" class="hover:text-white transition-all inline-flex items-center gap-1.5"><i data-lucide="user" class="w-3 h-3 opacity-50"></i> Hồ sơ cá nhân</a></li>
                        <li><a href="/profile/orders" class="hover:text-white transition-all inline-flex items-center gap-1.5"><i data-lucide="package-check" class="w-3 h-3 opacity-50"></i> Đơn hàng của tôi</a></li>
                    </ul>
                    <!-- Hotline -->
                    <div class="bg-white/5 border border-white/10 rounded-2xl p-4">
                        <p class="text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-2">Hotline hỗ trợ</p>
                        <a href="tel:19006677" class="text-white font-black text-xl hover:text-winmart-yellow transition-colors">1900 6677</a>
                        <p class="text-[10px] text-gray-500 mt-1">Thứ 2 – CN, 7:00 – 22:00</p>
                    </div>
                </div>
            </div>

            <!-- Bottom Bar -->
            <div class="border-t border-gray-800 mt-12 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs">
                <span>© 2025 WinMart Corporation. Bảo lưu mọi quyền.</span>
                <div class="flex items-center gap-4 text-gray-500">
                    <span class="flex items-center gap-1.5"><i data-lucide="map-pin" class="w-3 h-3"></i> TP. Hồ Chí Minh, Việt Nam</span>
                    <span class="flex items-center gap-1.5"><i data-lucide="mail" class="w-3 h-3"></i> lienhe@winmart.vn</span>
                </div>
            </div>
        </div>
    </footer>

    <!-- ====================================================== -->
    <!-- AUTHENTICATION MODAL -->
    <!-- ====================================================== -->
    <div id="auth-modal" class="fixed inset-0 z-50 flex items-center justify-center modal-hidden pointer-events-none">
        <div class="absolute inset-0 bg-winmart-dark/60 backdrop-blur-sm" onclick="closeAuthModal()"></div>

        <div id="auth-content" class="relative w-full max-w-[960px] max-h-[90vh] bg-white rounded-[2rem] shadow-2xl flex overflow-hidden mx-4 z-10">

            <!-- Nút đóng -->
            <button onclick="closeAuthModal()" class="absolute top-4 right-4 z-20 w-10 h-10 bg-gray-100 hover:bg-gray-200 rounded-full flex items-center justify-center text-gray-500 hover:text-winmart-dark transition-colors">
                <i data-lucide="x" class="w-5 h-5"></i>
            </button>

            <!-- Bên trái: Brand Banner -->
            <section class="hidden lg:flex w-5/12 relative bg-winmart-dark overflow-hidden flex-col justify-between p-10">
                <img src="https://images.unsplash.com/photo-1604719312566-8912e9227c6a?auto=format&fit=crop&q=80&w=800" alt="Supermarket" class="absolute inset-0 w-full h-full object-cover opacity-40 mix-blend-overlay">
                <div class="absolute inset-0 bg-gradient-to-t from-winmart-dark via-winmart-dark/50 to-transparent"></div>

                <div class="relative z-10 flex items-center gap-2">
                    <div class="w-10 h-10 rounded-xl bg-winmart-red flex items-center justify-center text-white font-black text-lg">WM</div>
