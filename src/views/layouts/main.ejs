    <!-- TOAST (MODERN STYLE) -->
    <div class="fixed top-20 right-5 z-[1060] space-y-3 max-w-sm w-full pointer-events-none" style="top: 85px;">
        <div id="wm-toast" class="flex items-center gap-3 bg-white border border-emerald-200 text-emerald-700 px-4 py-3.5 rounded-2xl shadow-xl pointer-events-auto transition-all duration-300 transform translate-x-full opacity-0" style="transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);">
            <div id="wm-toast-icon-bg" class="w-9 h-9 bg-emerald-50 rounded-xl flex items-center justify-center shrink-0">
                <i id="wm-toast-icon" data-lucide="check-circle" class="w-5 h-5"></i>
            </div>
            <div class="flex-1">
                <strong id="wm-toast-title" class="text-xs font-black block leading-tight">Thành công!</strong>
                <span id="wm-toast-text" class="text-xs font-medium"></span>
            </div>
            <button onclick="hideWmToast()" class="text-gray-300 hover:text-gray-500 transition">
                <i data-lucide="x" class="w-4 h-4"></i>
            </button>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            try {
                lucide.createIcons();
            } catch (err) {
                console.error("Lucide Error:", err);
            }

            // Mở modal từ flash message redirect (nếu có param ?modal=login)
            const urlParams = new URLSearchParams(window.location.search);
            if (urlParams.get('modal') === 'login') openAuthModal('login');
            if (urlParams.get('modal') === 'register') openAuthModal('register');

            // Khôi phục hiển thị địa chỉ trên thanh công cụ sau khi tải trang
            const savedLocStr = localStorage.getItem('winmart_location_json');
            const oldSavedLoc = localStorage.getItem('winmart_location');
            const headerText = document.getElementById('header-location-text');
            
            if (headerText) {
                if (savedLocStr) {
                    try {
                        const locData = JSON.parse(savedLocStr);
                        let shortName = locData.detail || locData.address;
                        const parts = locData.address.split(',');
                        if (!locData.detail) {
                            if (parts.length >= 3) {
                                shortName = parts[parts.length - 3].trim() || parts[0];
                            } else if (parts.length > 0) {
                                shortName = parts[0];
                            }
                        }
                        headerText.innerText = shortName.substring(0, 15) + (shortName.length > 15 ? '...' : '');
                    } catch(e) {}
                } else if (oldSavedLoc) {
                    const parts = oldSavedLoc.split(',');
                    let shortName = oldSavedLoc;
                    if (parts.length >= 3) {
                        shortName = parts[parts.length - 3].trim() || parts[0];
                    } else if (parts.length > 0) {
                        shortName = parts[0];
                    }
                    headerText.innerText = shortName.substring(0, 15) + (shortName.length > 15 ? '...' : '');
                }
            }

            // Update wishlist count on load
            const updateWishlistCount = () => {
                const badge = document.getElementById('header-wishlist-count');
                if (badge) {
                    const list = JSON.parse(localStorage.getItem('wm_wishlist') || '[]');
                    if (list.length > 0) {
                        badge.innerText = list.length;
                        badge.classList.remove('hidden');
                    } else {
                        badge.classList.add('hidden');
                    }
                }
            };
            updateWishlistCount();
            window.updateWishlistCount = updateWishlistCount;
        });

        // OpenStreetMap Nominatim Logic for Header
        const globalInput = document.getElementById('global-address-input');
        const globalDetailInput = document.getElementById('global-address-detail');
        const headerSuggestions = document.getElementById('address-suggestions');
        let headerSearchTimeout;
        let headerMap = null;
        let headerMarker = null;

        function initHeaderMap() {
            if (!headerMap && document.getElementById('header-map')) {
                // Default center (Hanoi)
                headerMap = L.map('header-map').setView([21.0285, 105.8542], 10);
                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                    attribution: '© OSM'
                }).addTo(headerMap);

                // Allow clicking to drop pin
                headerMap.on('click', async function(e) {
                    const lat = e.latlng.lat;
                    const lng = e.latlng.lng;
                    if (!headerMarker) {
                        headerMarker = L.marker([lat, lng], {
                            icon: L.divIcon({className: 'bg-winmart-red w-4 h-4 rounded-full border-2 border-white shadow-xl'})
                        }).addTo(headerMap);
                    } else {
                        headerMarker.setLatLng([lat, lng]);
                    }
                    headerMap.setView([lat, lng], 16);

                    // Reverse geocode to get area name
                    try {
                        const res = await fetch(`https://nominatim.openstreetmap.org/reverse?lat=${lat}&lon=${lng}&format=json&addressdetails=1`);
                        const data = await res.json();
                        if (data && data.display_name) {
                            if (globalInput) globalInput.value = data.display_name;
                        }
                    } catch(err) {}
                });
            }
        }

        if (globalInput && headerSuggestions) {
            globalInput.addEventListener('input', (e) => {
                clearTimeout(headerSearchTimeout);
                const query = e.target.value.trim();
                if (query.length < 2) {
                    headerSuggestions.classList.add('hidden');
                    return;
                }

                headerSuggestions.innerHTML = '<li class="px-4 py-3 text-sm text-gray-500 text-center"><i data-lucide="loader-2" class="w-4 h-4 animate-spin inline mr-2"></i>Đang tìm...</li>';
                headerSuggestions.classList.remove('hidden');
                lucide.createIcons();

                headerSearchTimeout = setTimeout(async () => {
                    try {
                        const res = await fetch(`https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(query)}&format=json&addressdetails=1&countrycodes=vn&limit=5`);
                        const data = await res.json();
                        
                        headerSuggestions.innerHTML = '';
                        if (data.length > 0) {
                            data.forEach(place => {
                                const li = document.createElement('li');
                                li.className = 'px-4 py-3 hover:bg-gray-50 cursor-pointer border-b border-gray-50 text-sm font-bold text-winmart-dark';
                                li.innerText = place.display_name;
                                
                                li.onclick = () => {
                                    globalInput.value = place.display_name;
                                    headerSuggestions.classList.add('hidden');
                                    
                                    const lat = parseFloat(place.lat);
                                    const lng = parseFloat(place.lon);
                                    
                                    if (headerMap) {
                                        headerMap.setView([lat, lng], 16);
                                        if (!headerMarker) {
                                            headerMarker = L.marker([lat, lng], {
                                                icon: L.divIcon({className: 'bg-winmart-red w-4 h-4 rounded-full border-2 border-white shadow-xl'})
                                            }).addTo(headerMap);
                                        } else {
                                            headerMarker.setLatLng([lat, lng]);
                                        }
                                    }
                                };
                                headerSuggestions.appendChild(li);
                            });
                        } else {
                            headerSuggestions.innerHTML = '<li class="px-4 py-3 text-sm text-gray-500 text-center">Không tìm thấy địa chỉ</li>';
                        }
                    } catch (err) {}
                }, 600);
            });

            // Hide when clicking outside
            document.addEventListener('click', (e) => {
                if (!globalInput.contains(e.target) && !headerSuggestions.contains(e.target)) {
                    headerSuggestions.classList.add('hidden');
                }
            });
        }


        function saveManualLocation() {
            const input = globalInput ? globalInput.value : '';
            const detailInput = globalDetailInput ? globalDetailInput.value : '';
            
            if (!input) {
                showWmToast('Vui lòng chọn khu vực / tỉnh thành!');
                return;
            }
            if (!headerMarker) {
                showWmToast('Vui lòng cắm ghim trên bản đồ để xác định vị trí chính xác!');
                return;
            }
            
            const pos = headerMarker.getLatLng();
            
            const locationData = {
                address: input,
                detail: detailInput,
                lat: pos.lat,
                lng: pos.lng
            };
            
            localStorage.setItem('winmart_location_json', JSON.stringify(locationData));
            
            // Extract short name for header
            let shortName = detailInput || input;
            const parts = input.split(',');
            if (!detailInput) {
                if (parts.length >= 3) {
                    shortName = parts[parts.length - 3].trim() || parts[0];
                } else if (parts.length > 0) {
                    shortName = parts[0];
                }
            }
            
            const headerText = document.getElementById('header-location-text');
            if (headerText) headerText.innerText = shortName.substring(0, 15) + (shortName.length > 15 ? '...' : '');
            
            closeLocationModal();
            showWmToast('Đã cập nhật địa chỉ giao hàng');
            
            // Reload logic for checkout page to apply new location
            if (window.location.pathname.includes('/checkout')) {
                window.location.reload();
            }
        }

        function openLocationModal() {
            const modal = document.getElementById('location-modal');
            if (modal) {
                // Reset input to blank when opening modal as requested
                if (globalInput) globalInput.value = '';
                if (globalDetailInput) globalDetailInput.value = '';
                
                if (headerSuggestions) {
                    headerSuggestions.innerHTML = '';
                    headerSuggestions.classList.add('hidden');
                }
                
                if (headerMarker && headerMap) {
                    headerMap.removeLayer(headerMarker);
                    headerMarker = null;
                }
                
                modal.classList.remove('modal-hidden');
                modal.classList.add('modal-active');
                document.body.style.overflow = 'hidden';
                
                setTimeout(() => {
                    initHeaderMap();
                    if (headerMap) {
                        headerMap.invalidateSize();
                    }
                }, 300);
            }
        }

        function closeLocationModal() {
            const modal = document.getElementById('location-modal');
            if (modal) {
                modal.classList.remove('modal-active');
                modal.classList.add('modal-hidden');
                document.body.style.overflow = 'auto';
            }
        }

        function openAuthModal(tabName) {
            const modal = document.getElementById('auth-modal');
            modal.classList.remove('modal-hidden');
            modal.classList.add('modal-active');
            document.body.style.overflow = 'hidden';
            // Tự động xóa sạch form mỗi khi mở pop-up để tránh trình duyệt điền mặc định
            // Dùng setTimeout để đè lên tính năng tự động điền (autofill) của Chrome
            setTimeout(() => {
                const identifierInput = document.getElementById('modal-identifier');
                const passwordInput = document.getElementById('modal-login-password');
                if (identifierInput) identifierInput.value = '';
                if (passwordInput) passwordInput.value = '';
            }, 50);
            
            switchTab(tabName || 'login');
        }

        function closeAuthModal() {
            const modal = document.getElementById('auth-modal');
            modal.classList.remove('modal-active');
            modal.classList.add('modal-hidden');
            document.body.style.overflow = 'auto';
        }

        // Auto-open modal on error redirect and handle datalist
        document.addEventListener('DOMContentLoaded', () => {
            const urlParams = new URLSearchParams(window.location.search);
            if (urlParams.get('openModal') === 'login') {
                openAuthModal('login');
                // Remove the parameter from URL to avoid re-opening on reload
                const newUrl = window.location.protocol + "//" + window.location.host + window.location.pathname;
                window.history.replaceState({path: newUrl}, '', newUrl);
            }
            
            // Handle Modal Login via AJAX
            const modalLoginForm = document.getElementById('modal-login-form');
            if (modalLoginForm) {
                modalLoginForm.addEventListener('submit', async (e) => {
                    e.preventDefault();
                    
                    const btn = modalLoginForm.querySelector('button[type="submit"]');
                    const originalText = btn.innerHTML;
                    btn.innerHTML = '<i data-lucide="loader-2" class="w-4 h-4 animate-spin"></i> Đang xử lý...';
                    btn.disabled = true;
                    lucide.createIcons();

                    try {
                        const formData = new URLSearchParams(new FormData(modalLoginForm));
                        // Flag to tell server we want JSON response
                        formData.append('isAjax', 'true');

                        const res = await fetch('/auth/login', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/x-www-form-urlencoded',
                                'Accept': 'application/json'
                            },
                            body: formData.toString()
                        });
                        
                        const data = await res.json();
                        
                        if (data.success) {
                            showWmToast('Đăng nhập thành công! Đang chuyển hướng...');
                            
                            // Lưu tài khoản vào danh sách gợi ý
                            const enteredId = document.getElementById('modal-identifier').value.trim();
                            if (enteredId) {
                                let accounts = JSON.parse(localStorage.getItem('wm_saved_accounts') || '[]');
                                if (!accounts.includes(enteredId)) {
                                    accounts.push(enteredId);
                                    localStorage.setItem('wm_saved_accounts', JSON.stringify(accounts));
                                }
                            }
                            
                            setTimeout(() => {
                                window.location.href = data.redirectUrl || '/';
                            }, 500);
                        } else {
                            showWmToast(data.message || 'Đăng nhập thất bại');
                            btn.innerHTML = originalText;
                            btn.disabled = false;
                            lucide.createIcons();
                        }
                    } catch (err) {
                        showWmToast('Có lỗi xảy ra, vui lòng thử lại sau.');
                        btn.innerHTML = originalText;
                        btn.disabled = false;
                        lucide.createIcons();
                    }
                });
            }
            
            // Populate datalist
            const dataList = document.getElementById('savedAccountsList');
            if (dataList) {
                let accounts = JSON.parse(localStorage.getItem('wm_saved_accounts') || '[]');
                accounts.forEach(acc => {
                    const option = document.createElement('option');
                    option.value = acc;
                    dataList.appendChild(option);
                });
            }

            // Handle Modal Register via AJAX
            const modalRegisterForm = document.getElementById('modal-register-form');
            if (modalRegisterForm) {
                modalRegisterForm.addEventListener('submit', async (e) => {
                    e.preventDefault();
                    
                    const btn = modalRegisterForm.querySelector('button[type="submit"]');
                    const originalText = btn.innerHTML;
                    btn.innerHTML = '<i data-lucide="loader-2" class="w-4 h-4 animate-spin"></i> Đang xử lý...';
                    btn.disabled = true;
                    lucide.createIcons();

                    try {
                        const formData = new URLSearchParams(new FormData(modalRegisterForm));

                        const res = await fetch('/auth/register', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/x-www-form-urlencoded',
                                'Accept': 'application/json'
                            },
                            body: formData.toString()
                        });
                        
                        const data = await res.json();
                        
                        if (data.success) {
                            showWmToast('Đăng ký thành công! Vui lòng đăng nhập.');
                            modalRegisterForm.reset();
                            switchTab('login');
                        } else {
                            showWmToast(data.message || 'Đăng ký thất bại', 'error');
                        }
                    } catch (err) {
                        showWmToast('Có lỗi xảy ra, vui lòng thử lại sau.', 'error');
                    } finally {
                        btn.innerHTML = originalText;
                        btn.disabled = false;
                        lucide.createIcons();
                    }
                });
            }

            const forgotForm = document.getElementById('modal-forgot-form');
            if (forgotForm) {
                forgotForm.addEventListener('submit', async (e) => {
                    e.preventDefault();
                    const btn = document.getElementById('btn-forgot-submit');
                    const originalText = btn.innerHTML;
                    btn.innerHTML = '<i data-lucide="loader-2" class="w-4 h-4 animate-spin mr-2 inline"></i> Đang xử lý...';
                    btn.disabled = true;
                    lucide.createIcons();

                    try {
                        const identifier = document.getElementById('modal-forgot-identifier').value;
                        const res = await fetch('/auth/forgot-password', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ identifier })
                        });
                        const data = await res.json();
                        
                        if (data.success) {
                            showWmToast(data.message || 'Mật khẩu mới đã được gửi vào email của bạn');
                            switchTab('login');
                        } else {
                            showWmToast(data.message || 'Có lỗi xảy ra', 'error');
                        }
                    } catch (err) {
                        showWmToast('Lỗi kết nối máy chủ', 'error');
                    } finally {
                        btn.innerHTML = originalText;
                        btn.disabled = false;
                        lucide.createIcons();
                    }
                });
            }
        });

        // Escape key closes modal
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') {
                closeAuthModal();
                if (typeof closeLocationModal === 'function') closeLocationModal();
            }
        });

        function switchTab(tab) {
            const loginForm = document.getElementById('form-login');
            const registerForm = document.getElementById('form-register');
            const forgotForm = document.getElementById('form-forgot');
            const tabLogin = document.getElementById('tab-login');
            const tabRegister = document.getElementById('tab-register');

            if (tab === 'login') {
                loginForm.classList.remove('hidden-form'); loginForm.classList.add('active-form');
                registerForm.classList.remove('active-form'); registerForm.classList.add('hidden-form');
                if (forgotForm) { forgotForm.classList.remove('active-form'); forgotForm.classList.add('hidden-form'); }
                tabLogin.className = "flex-1 py-2.5 text-sm font-extrabold rounded-xl transition-all duration-300 bg-white text-winmart-dark shadow-sm";
                tabRegister.className = "flex-1 py-2.5 text-sm font-extrabold rounded-xl transition-all duration-300 text-gray-400 hover:text-winmart-dark";
            } else if (tab === 'register') {
                registerForm.classList.remove('hidden-form'); registerForm.classList.add('active-form');
                loginForm.classList.remove('active-form'); loginForm.classList.add('hidden-form');
                if (forgotForm) { forgotForm.classList.remove('active-form'); forgotForm.classList.add('hidden-form'); }
                tabRegister.className = "flex-1 py-2.5 text-sm font-extrabold rounded-xl transition-all duration-300 bg-white text-winmart-dark shadow-sm";
                tabLogin.className = "flex-1 py-2.5 text-sm font-extrabold rounded-xl transition-all duration-300 text-gray-400 hover:text-winmart-dark";
            } else if (tab === 'forgot') {
                if (forgotForm) { forgotForm.classList.remove('hidden-form'); forgotForm.classList.add('active-form'); }
                loginForm.classList.remove('active-form'); loginForm.classList.add('hidden-form');
                registerForm.classList.remove('active-form'); registerForm.classList.add('hidden-form');
                tabLogin.className = "flex-1 py-2.5 text-sm font-extrabold rounded-xl transition-all duration-300 text-gray-400 hover:text-winmart-dark";
                tabRegister.className = "flex-1 py-2.5 text-sm font-extrabold rounded-xl transition-all duration-300 text-gray-400 hover:text-winmart-dark";
            }
        }

        function togglePassword(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon = document.getElementById(iconId);
            if (input.type === 'password') {
                input.type = 'text';
                icon.setAttribute('data-lucide', 'eye-off');
            } else {
                input.type = 'password';
                icon.setAttribute('data-lucide', 'eye');
            }
            lucide.createIcons();
        }

        document.addEventListener('DOMContentLoaded', () => {
            const pwd = document.getElementById('modal-register-password');
            const confirmPwd = document.getElementById('modal-confirm-password');
            const shield = document.getElementById('modal-confirm-shield-wrapper');

            const validatePasswords = () => {
                if (!pwd.value && !confirmPwd.value) {
                    shield.classList.remove('text-emerald-500', 'text-red-500');
                    shield.classList.add('text-gray-400');
                    return;
                }

                if (pwd.value.length >= 6 && pwd.value === confirmPwd.value) {
                    shield.classList.remove('text-gray-400', 'text-red-500');
                    shield.classList.add('text-emerald-500');
                } else if (confirmPwd.value.length > 0) {
                    shield.classList.remove('text-gray-400', 'text-emerald-500');
                    shield.classList.add('text-red-500');
                } else {
                    shield.classList.remove('text-emerald-500', 'text-red-500');
                    shield.classList.add('text-gray-400');
                }
            };

            if (pwd && confirmPwd) {
                pwd.addEventListener('input', validatePasswords);
                confirmPwd.addEventListener('input', validatePasswords);
            }
        });

        let toastTimeout;
        function showWmToast(text, type = 'success') {
            const toast = document.getElementById('wm-toast');
            const toastIcon = document.getElementById('wm-toast-icon');
            const toastIconBg = document.getElementById('wm-toast-icon-bg');
            const toastTitle = document.getElementById('wm-toast-title');
            const toastText = document.getElementById('wm-toast-text');
            
            clearTimeout(toastTimeout);
            
            toastText.innerHTML = text;
            
            if (type === 'error') {
                toast.className = 'flex items-center gap-3 bg-white border border-red-200 text-red-600 px-4 py-3.5 rounded-2xl shadow-xl pointer-events-auto transition-all duration-300 transform';
                toastIconBg.className = 'w-9 h-9 bg-red-50 rounded-xl flex items-center justify-center shrink-0 text-red-500';
                toastIcon.setAttribute('data-lucide', 'alert-circle');
                toastTitle.innerText = 'Có lỗi xảy ra!';
            } else {
                toast.className = 'flex items-center gap-3 bg-white border border-emerald-200 text-emerald-700 px-4 py-3.5 rounded-2xl shadow-xl pointer-events-auto transition-all duration-300 transform';
                toastIconBg.className = 'w-9 h-9 bg-emerald-50 rounded-xl flex items-center justify-center shrink-0 text-emerald-500';
                toastIcon.setAttribute('data-lucide', 'check-circle');
                toastTitle.innerText = 'Thành công!';
            }
            
            lucide.createIcons();
            
            // Show
            toast.style.opacity = '1';
            toast.style.transform = 'translateX(0)';
            
            toastTimeout = setTimeout(() => {
                hideWmToast();
            }, 3000);
        }
        
        function hideWmToast() {
            const toast = document.getElementById('wm-toast');
            toast.style.opacity = '0';
            toast.style.transform = 'translateX(100%)';
        }

        async function addToCart(productId, quantity = 1) {
            try {
                const res = await fetch('/cart/add', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ productId, quantity })
                });
                const data = await res.json();
                if (data.success) {
                    showWmToast(data.message || 'Đã thêm vào giỏ hàng');
                    const badge = document.getElementById('header-cart-count');
                    if (badge && data.cartCount !== undefined) {
                        badge.innerText = data.cartCount;
                        badge.classList.remove('hidden');
                    }
                } else {
                    showWmToast(data.message || 'Có lỗi xảy ra', 'error');
                }
            } catch (err) {
                showWmToast('Lỗi kết nối máy chủ', 'error');
            }
        }

        function goToWishlist() {
            const list = JSON.parse(localStorage.getItem('wm_wishlist') || '[]');
            if (list.length === 0) {
                showWmToast('Bạn chưa có sản phẩm yêu thích nào!', 'error');
                return;
            }
            window.location.href = '/profile/wishlist?ids=' + encodeURIComponent(JSON.stringify(list));
        }

        function toggleWishlist(productId) {
            let list = JSON.parse(localStorage.getItem('wm_wishlist') || '[]');
            const index = list.indexOf(productId);
            if (index > -1) {
                list.splice(index, 1);
                showWmToast('Đã bỏ sản phẩm khỏi danh sách yêu thích');
            } else {
                list.push(productId);
                showWmToast('Đã thêm sản phẩm vào danh sách yêu thích');
            }
            localStorage.setItem('wm_wishlist', JSON.stringify(list));
            if (window.updateWishlistCount) window.updateWishlistCount();
            
            // If on wishlist page, optionally remove the element or reload
            if (window.location.pathname === '/profile/wishlist') {
                const card = document.getElementById('wishlist-item-' + productId);
                if (card) {
                    card.style.opacity = '0';
                    setTimeout(() => card.remove(), 300);
                } else {
                    setTimeout(() => window.location.reload(), 500);
                }
            }
            
            // Update heart icon states if on product list
            const btn = document.getElementById('wishlist-btn-' + productId);
            if (btn) {
                if (index > -1) {
                    btn.classList.remove('text-winmart-red', 'fill-winmart-red');
                    btn.classList.add('text-gray-400');
                } else {
                    btn.classList.remove('text-gray-400');
                    btn.classList.add('text-winmart-red', 'fill-winmart-red');
                }
            }
        }
    </script>


</body>
