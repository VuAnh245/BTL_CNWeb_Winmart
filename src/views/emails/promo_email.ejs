<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>Khuyến mãi WinMart</title>
    <style>
        body { font-family: Arial, sans-serif; background-color: #f3f4f6; padding: 20px; }
        .container { margin: 0 auto; background-color: white; border-radius: 12px; overflow: hidden; max-width: 600px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
        .header { background-color: #e11d48; padding: 30px; text-align: center; color: white; }
        .header h1 { margin: 0; font-size: 24px; font-weight: 900; }
        .content { padding: 30px; }
        
        /* Membership Card */
        .membership-card {
            border-radius: 12px;
            padding: 25px;
            color: white;
            position: relative;
            overflow: hidden;
            margin-bottom: 20px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        }
        .membership-card.thuong { background: linear-gradient(135deg, #64748b, #475569); }
        .membership-card.đồng { background: linear-gradient(135deg, #d97706, #b45309); }
        .membership-card.bạc { background: linear-gradient(135deg, #94a3b8, #64748b); }
        .membership-card.vàng { background: linear-gradient(135deg, #eab308, #ca8a04); }
        .membership-card.kim { background: linear-gradient(135deg, #0ea5e9, #0284c7); }
        
        .card-header { font-size: 10px; letter-spacing: 2px; opacity: 0.8; margin-bottom: 15px; font-weight: bold; }
        .card-name { font-size: 20px; font-weight: 900; margin-bottom: 20px; text-transform: uppercase; letter-spacing: 1px; }
        .card-points { margin-bottom: 5px; }
        .points-label { display: block; font-size: 10px; opacity: 0.8; margin-bottom: 2px; text-transform: uppercase; font-weight: bold; }
        .points-value { font-size: 28px; font-weight: 900; }
        .card-tier { position: absolute; top: 20px; right: 20px; font-size: 12px; font-weight: 900; background: rgba(255,255,255,0.2); padding: 4px 10px; border-radius: 20px; text-transform: uppercase; }
        
        /* Gamification */
        .gamification {
            background-color: #f8fafc;
            border-left: 4px solid #3b82f6;
            padding: 15px;
            font-size: 14px;
            color: #334155;
            margin-bottom: 25px;
            border-radius: 0 8px 8px 0;
            line-height: 1.5;
        }
        .gamification strong { color: #2563eb; }
        
        /* Promo Box */
        .promo-box { background-color: #fef2f2; border: 2px dashed #f43f5e; border-radius: 12px; padding: 20px; text-align: center; margin: 20px 0; }
        .code { font-size: 32px; font-weight: 900; color: #e11d48; letter-spacing: 2px; margin: 10px 0; font-family: monospace; }
        .details { font-size: 14px; color: #4b5563; line-height: 1.6; }
        .btn-wrapper { text-align: center; margin-top: 30px; }
        .btn { display: inline-block; background-color: #e11d48; color: white; text-decoration: none; padding: 15px 30px; border-radius: 50px; font-weight: bold; font-size: 16px; }
        .footer { background-color: #f9fafb; padding: 20px; text-align: center; font-size: 12px; color: #9ca3af; border-top: 1px solid #f3f4f6; }
        
        .tip { font-size: 13px; color: #64748b; text-align: center; margin-top: 20px; padding-top: 20px; border-top: 1px dashed #cbd5e1; }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>🎁 QUÀ TẶNG TỪ WINMART</h1>
        </div>
        
        <div class="content">
            <% 
                let pts = customer.TongDiemTichLuy || 0;
                let rawTier = customer.CapDoVIP || 'Thuong';
                let tierDisplay = 'Thường';
                let tierClass = 'thuong';
                
                if (rawTier === 'VIP1') { tierDisplay = 'VIP Đồng'; tierClass = 'đồng'; }
                if (rawTier === 'VIP2') { tierDisplay = 'VIP Bạc'; tierClass = 'bạc'; }
                if (rawTier === 'VIP3') { tierDisplay = 'VIP Vàng'; tierClass = 'vàng'; }
            %>
            
            <!-- Virtual Membership Card -->
            <div class="membership-card <%= tierClass %>">
                <div class="card-header">WINMART MEMBERSHIP</div>
                <div class="card-name"><%= customer.HoTen || 'Quý khách' %></div>
                <div class="card-points">
                    <span class="points-label">ĐIỂM TÍCH LŨY</span>
                    <span class="points-value"><%= Number(pts).toLocaleString('vi-VN') %></span>
                </div>
                <div class="card-tier"><%= tierDisplay %></div>
            </div>

            <% 
                let nextTier = '';
                let pointsNeeded = 0;
                if (rawTier === 'Thuong') { nextTier = 'VIP Đồng'; pointsNeeded = 1000 - pts; }
                else if (rawTier === 'VIP1') { nextTier = 'VIP Bạc'; pointsNeeded = 5000 - pts; }
                else if (rawTier === 'VIP2') { nextTier = 'VIP Vàng'; pointsNeeded = 10000 - pts; }
            %>
            
            <% if (nextTier && pointsNeeded > 0) { %>
            <div class="gamification">
                💡 Cố lên! Bạn chỉ cần tích thêm <strong><%= pointsNeeded.toLocaleString('vi-VN') %> điểm</strong> nữa để thăng hạng <strong><%= nextTier %></strong> và nhận thêm vô vàn đặc quyền!
            </div>
            <% } %>

            <p style="color: #4b5563; line-height: 1.6;">Để tri ân sự gắn bó của bạn, WinMart dành tặng riêng cho bạn mã ưu đãi dưới đây. Hãy sử dụng ngay để mua sắm và tích điểm thăng hạng nhé!</p>
            
            <div class="promo-box">
                <div style="font-size: 14px; font-weight: bold; color: #f43f5e; text-transform: uppercase;"><%= promo.TenMaGiamGia %></div>
                <div class="code"><%= promo.MaCode %></div>
                <div style="font-size: 14px; color: #ef4444; font-weight: bold;">
                    <% if (promo.LoaiGiamGia === 'Percent') { %>
                        Giảm <%= promo.GiaTri %>% 
                        <% if (promo.PhanTramToiDa > 0) { %> (Tối đa <%= Number(promo.PhanTramToiDa).toLocaleString('vi-VN') %>đ) <% } %>
                    <% } else { %>
                        Giảm ngay <%= Number(promo.GiaTri).toLocaleString('vi-VN') %>đ
                    <% } %>
                </div>
            </div>
            
            <div class="details">
                <strong>Điều kiện áp dụng:</strong><br>
                - Đơn hàng tối thiểu: <%= promo.GiaTriDonHangToiThieu > 0 ? Number(promo.GiaTriDonHangToiThieu).toLocaleString('vi-VN') + 'đ' : 'Không yêu cầu' %><br>
                - Hạn sử dụng: Từ <%= new Date(promo.NgayBatDau).toLocaleString('vi-VN') %> đến <%= new Date(promo.NgayKetThuc).toLocaleString('vi-VN') %>
            </div>
            
            <div class="btn-wrapper">
                <a href="http://localhost:3000/promotions" class="btn">Dùng Mã & Tích Điểm Ngay</a>
            </div>

            <% if(pts > 0) { %>
            <div class="tip">
                💡 <strong>Gợi ý:</strong> Với <%= pts.toLocaleString('vi-VN') %> điểm hiện tại, bạn có thể quy đổi thành <strong><%= (pts * 10).toLocaleString('vi-VN') %>đ</strong> giảm trực tiếp vào hóa đơn thanh toán!
            </div>
            <% } %>
        </div>
        
        <div class="footer">
            <p>Email này được gửi tự động từ hệ thống WinMart Online.</p>
            <p>© 2026 WinMart. All rights reserved.</p>
        </div>
    </div>
</body>
</html>
