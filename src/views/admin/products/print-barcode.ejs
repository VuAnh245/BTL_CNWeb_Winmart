<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>In Mã Vạch - <%= product.TenSanPham %></title>
    <!-- JsBarcode CDN -->
    <script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.5/dist/JsBarcode.all.min.js"></script>
    <style>
        /* CSS reset & base settings for thermal printing */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Arial', sans-serif;
        }

        body {
            background: #f3f4f6;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 20px;
        }

        /* The label design - Target Size: 50mm x 30mm */
        .label-container {
            background: white;
            width: 50mm;
            height: 30mm;
            padding: 2mm;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            border: 1px dashed #ccc; /* Just for screen viewing */
            margin-bottom: 20px;
        }

        .store-name {
            font-size: 8pt;
            font-weight: bold;
            text-transform: uppercase;
            margin-bottom: 1mm;
        }

        .product-name {
            font-size: 7pt;
            line-height: 1.2;
            margin-bottom: 1mm;
            overflow: hidden;
            text-overflow: ellipsis;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            max-width: 100%;
        }

        .price {
            font-size: 9pt;
            font-weight: bold;
            margin-bottom: 1mm;
        }

        .barcode-svg {
            max-width: 100%;
            height: 12mm; /* Constrain height */
        }

        /* Screen controls */
        .controls {
            background: white;
            padding: 15px 25px;
            border-radius: 8px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
            margin-bottom: 20px;
            display: flex;
            gap: 15px;
            align-items: center;
        }

        button {
            background: #0f172a;
            color: white;
            border: none;
            padding: 8px 16px;
            border-radius: 6px;
            cursor: pointer;
            font-weight: bold;
        }

        button:hover {
            background: #000;
        }

        input[type="number"] {
            padding: 8px;
            width: 60px;
            border: 1px solid #ccc;
            border-radius: 6px;
            text-align: center;
        }

        /* Print Specific Styles */
        @media print {
            body {
                background: white;
                padding: 0;
            }
            .controls {
                display: none; /* Hide controls when printing */
            }
            .label-container {
                border: none;
                margin: 0;
                page-break-after: always; /* Force page break for multiple labels */
            }
            @page {
                size: 50mm 30mm;
                margin: 0;
            }
        }
    </style>
</head>
<body>

    <!-- Controls for user (hidden during print) -->
    <div class="controls">
        <label>
            <strong>Số lượng tem:</strong>
            <input type="number" id="print-count" value="1" min="1" max="100">
        </label>
        <button onclick="window.print()">🖨️ In Ngay</button>
        <button onclick="window.close()" style="background: #e5e7eb; color: #374151;">Đóng</button>
    </div>

    <!-- Container for dynamic generation of labels -->
    <div id="labels-wrapper">
        <!-- Default 1 label for preview -->
        <div class="label-container">
            <div class="store-name">WinMart Store</div>
            <div class="product-name"><%= product.TenSanPham %></div>
            <div class="price"><%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(product.GiaBan) %></div>
            <svg class="barcode-svg" data-barcode="<%= product.Barcode %>"></svg>
        </div>
    </div>

    <script>
        // Init JsBarcode for the existing SVG element
        function renderBarcodes() {
            JsBarcode(".barcode-svg", "<%= product.Barcode %>", {
                format: "<%= product.Barcode.length === 13 ? 'EAN13' : 'CODE128' %>",
                lineColor: "#000",
                width: 1.5,
                height: 40,
                displayValue: true,
                fontSize: 12,
                margin: 0
            });
        }
        
        // Initial render
        renderBarcodes();

        // Handle quantity change
        document.getElementById('print-count').addEventListener('input', function(e) {
            const count = parseInt(e.target.value) || 1;
            const wrapper = document.getElementById('labels-wrapper');
            
            // Generate HTML for N labels
            let html = '';
            for(let i=0; i<count; i++) {
                html += `
                <div class="label-container">
                    <div class="store-name">WinMart Store</div>
                    <div class="product-name"><%= product.TenSanPham.replace(/"/g, '&quot;') %></div>
                    <div class="price"><%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(product.GiaBan) %></div>
                    <svg class="barcode-svg"></svg>
                </div>`;
            }
            wrapper.innerHTML = html;
            
            // Re-render barcodes on all new SVGs
            renderBarcodes();
        });
    </script>
</body>
</html>
