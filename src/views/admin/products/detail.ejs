<!-- Page Header -->
<div class="flex justify-between items-center mb-6">
    <div class="flex items-center gap-4">
        <a href="/admin/products" class="text-winmart-slate hover:bg-gray-100 p-2 rounded-xl transition">
            <i data-lucide="arrow-left" class="w-5 h-5"></i>
        </a>
        <div>
            <p class="text-[11px] text-winmart-slate font-semibold tracking-wider uppercase mb-1">Hồ Sơ Sản Phẩm</p>
            <h1 class="text-2xl font-black tracking-tight text-winmart-dark"><%= product.TenSanPham %></h1>
        </div>
    </div>
    
    <div class="flex items-center gap-3">
        <a href="/admin/products/<%= product.SanPhamId %>/edit" class="bg-blue-50 text-blue-600 hover:bg-blue-100 px-4 py-2.5 rounded-xl text-xs font-bold transition-all shadow-sm flex items-center gap-2 border border-blue-100">
            <i data-lucide="edit" class="w-4 h-4"></i> Chỉnh Sửa
        </a>
        <% if (product.Barcode) { %>
            <a href="/admin/products/<%= product.SanPhamId %>/print-barcode" target="_blank" class="bg-winmart-dark hover:bg-black text-white px-5 py-2.5 rounded-xl text-xs font-bold transition-all shadow-sm shadow-gray-900/20 flex items-center gap-2">
                <i data-lucide="printer" class="w-4 h-4 text-winmart-yellow"></i> In Mã Vạch
            </a>
        <% } %>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Info Card -->
    <div class="lg:col-span-1 space-y-6">
        <div class="bento-card overflow-hidden">
            <div class="aspect-square bg-gray-50 flex items-center justify-center p-4">
                <% if (product.HinhAnh) { %>
                    <% const imgSrc = product.HinhAnh.startsWith('/') || product.HinhAnh.startsWith('http') ? product.HinhAnh : '/uploads/' + product.HinhAnh; %>
                    <img src="<%= imgSrc %>" alt="<%= product.TenSanPham %>" class="w-full h-full object-contain drop-shadow-md">
                <% } else { %>
                    <i data-lucide="image" class="w-16 h-16 text-gray-300"></i>
                <% } %>
            </div>
            
            <div class="p-6 space-y-4">
                <div>
                    <span class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Mã Sản Phẩm</span>
                    <span class="text-sm font-black text-gray-800"><%= product.MaSanPham %></span>
                </div>
                <div>
                    <span class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Danh Mục</span>
                    <span class="inline-block bg-gray-100 text-gray-700 px-2.5 py-1 rounded-md text-xs font-bold"><%= product.TenDanhMuc || 'Không rõ' %></span>
                </div>
                <div>
                    <span class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Đơn Vị Tính</span>
                    <span class="text-sm font-semibold text-gray-800"><%= product.DonViTinh %></span>
                </div>
                <div>
                    <span class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Mức Cảnh Báo (Tồn Nhỏ Nhất)</span>
                    <span class="text-sm font-semibold text-amber-600"><%= product.MucCanDat || 0 %> <%= product.DonViTinh %></span>
                </div>
                <div>
                    <span class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Thuế VAT (Mặc định)</span>
                    <span class="inline-flex items-center gap-1 bg-red-50 text-winmart-red px-2.5 py-1 rounded-md text-xs font-black border border-red-100">
                        <%= product.ThueVAT || 0 %>%
                    </span>
                </div>
            </div>
            
            <div class="p-6 border-t border-gray-100 bg-gray-50/50 space-y-3">
                <div class="flex justify-between items-end">
                    <span class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest">Giá Nhập Gốc</span>
                    <span class="text-lg font-black text-gray-500"><%= Number(product.GiaNhapGoc || 0).toLocaleString('vi-VN') %>đ</span>
                </div>
                <div class="flex justify-between items-end pt-3 border-t border-gray-100">
                    <span class="block text-[10px] font-bold text-winmart-red uppercase tracking-widest">Giá Bán Lẻ</span>
                    <span class="text-2xl font-black text-winmart-red"><%= Number(product.GiaBan || 0).toLocaleString('vi-VN') %>đ</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Batches Table -->
    <div class="lg:col-span-2 space-y-6">
        <div class="bento-card overflow-hidden h-full flex flex-col">
            <div class="p-6 border-b border-gray-100 flex justify-between items-center bg-gray-50/50">
                <div>
                    <h3 class="text-sm font-black text-winmart-dark uppercase tracking-wide">Lịch Sử Lô Hàng Tồn Kho</h3>
                    <p class="text-[10px] text-gray-400 font-semibold mt-0.5">Danh sách các lô hàng đang lưu trữ hoặc đã hết</p>
                </div>
                <span class="bg-blue-50 text-blue-600 text-[10px] font-black uppercase px-2 py-1 rounded-md"><%= batches.length %> Lô hàng</span>
            </div>
            
            <div class="overflow-x-auto flex-1">
                <table class="w-full text-left">
                    <thead>
                        <tr class="bg-white border-b border-gray-100">
                            <th class="py-4 px-5 text-[10px] font-black text-gray-400 uppercase tracking-wider">Mã Lô</th>
                            <th class="py-4 px-4 text-[10px] font-black text-gray-400 uppercase tracking-wider">Ngày Nhập</th>
                            <th class="py-4 px-4 text-[10px] font-black text-gray-400 uppercase tracking-wider text-right">Nhập Ban Đầu</th>
                            <th class="py-4 px-4 text-[10px] font-black text-gray-400 uppercase tracking-wider text-right">Tồn Hiện Tại</th>
                            <th class="py-4 px-4 text-[10px] font-black text-gray-400 uppercase tracking-wider text-center">Hạn Sử Dụng</th>
                            <th class="py-4 px-5 text-[10px] font-black text-gray-400 uppercase tracking-wider text-center">Trạng Thái</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-50">
                        <% if (batches && batches.length > 0) { %>
                            <% batches.forEach(b => { %>
                            <tr class="hover:bg-gray-50/50 transition bg-white <%= b.SoLuongHienTai <= 0 ? 'opacity-50' : '' %>">
                                <td class="py-4 px-5">
                                    <h4 class="font-extrabold text-winmart-dark text-xs"><%= b.MaLo %></h4>
                                </td>
                                <td class="py-4 px-4">
                                    <span class="text-xs font-semibold text-gray-600"><%= new Date(b.NgayNhap).toLocaleDateString('vi-VN') %></span>
                                </td>
                                <td class="py-4 px-4 text-right">
                                    <span class="text-xs font-bold text-gray-500"><%= b.SoLuongNhap %></span>
                                </td>
                                <td class="py-4 px-4 text-right">
                                    <span class="text-sm font-black <%= b.SoLuongHienTai > 0 ? 'text-winmart-dark' : 'text-gray-400' %>"><%= b.SoLuongHienTai %></span>
                                </td>
                                <td class="py-4 px-4 text-center">
                                    <% if (b.NgayHetHan) { %>
                                        <span class="inline-flex items-center gap-1 bg-gray-50 text-gray-600 px-2 py-1 rounded-md text-[9px] font-bold border border-gray-100">
                                            <i data-lucide="clock" class="w-3 h-3"></i> <%= new Date(b.NgayHetHan).toLocaleDateString('vi-VN') %>
                                        </span>
                                    <% } else { %>
                                        <span class="text-[10px] text-gray-400">Không có</span>
                                    <% } %>
                                </td>
                                <td class="py-4 px-5 text-center">
                                    <% if (b.SoLuongHienTai <= 0) { %>
                                        <span class="bg-gray-100 text-gray-500 px-2 py-1 rounded text-[9px] font-black whitespace-nowrap">HẾT HÀNG</span>
                                    <% } else { %>
                                        <span class="bg-emerald-50 text-emerald-600 px-2 py-1 rounded text-[9px] font-black border border-emerald-100 whitespace-nowrap">CÒN HÀNG</span>
                                    <% } %>
                                </td>
                            </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="6" class="py-12 text-center text-gray-400">
                                    <i data-lucide="box" class="w-12 h-12 mx-auto mb-3 opacity-20"></i>
                                    <p class="text-sm font-semibold">Chưa có lô hàng nào</p>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
