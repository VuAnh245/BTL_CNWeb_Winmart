<!-- Page Header -->
<div class="flex items-center gap-4 mb-6">
    <a href="/admin/customers" class="w-10 h-10 bg-white border border-gray-200 rounded-xl flex items-center justify-center text-gray-400 hover:text-winmart-dark hover:border-gray-300 transition shadow-sm">
        <i data-lucide="arrow-left" class="w-5 h-5"></i>
    </a>
    <div>
        <p class="text-[11px] text-winmart-slate font-semibold tracking-wider uppercase mb-1">Hồ Sơ Khách Hàng</p>
        <h1 class="text-2xl font-black tracking-tight text-winmart-dark"><%= customer.HoTen %></h1>
    </div>
</div>

<div class="grid grid-cols-1 xl:grid-cols-3 gap-6">
    <!-- Left Column: Personal Info & Settings -->
    <div class="space-y-6">
        <div class="bento-card p-8 rounded-3xl shadow-sm border border-gray-100 bg-white text-center relative">
            <button onclick="toggleEditSlideOver()" class="absolute top-4 right-4 p-2 bg-gray-50 text-gray-400 hover:text-winmart-dark hover:bg-gray-100 rounded-xl transition" title="Chỉnh sửa hồ sơ">
                <i data-lucide="edit-2" class="w-4 h-4"></i>
            </button>
            <div class="w-24 h-24 rounded-full bg-blue-50 border-[4px] border-white shadow-xl shadow-blue-500/10 flex items-center justify-center text-blue-600 font-black text-3xl mx-auto mb-4">
                <%= customer.HoTen.charAt(0).toUpperCase() %>
            </div>
            <h4 class="font-extrabold text-winmart-dark text-lg mb-1"><%= customer.HoTen %></h4>
            <span class="text-xs text-gray-400 font-bold uppercase tracking-wider block mb-4">Mã KH: <%= customer.MaKhachHang %></span>

            <div class="flex justify-center mb-6">
                <% if (customer.CapDoVIP === LOYALTY_TIER.THUONG) { %>
                    <span class="inline-flex items-center bg-gray-50 text-gray-600 px-3 py-1.5 rounded-xl text-xs font-bold border border-gray-200 shadow-sm">Hạng Thường</span>
                <% } else if (customer.CapDoVIP === LOYALTY_TIER.VIP1) { %>
                    <span class="inline-flex items-center bg-blue-50 text-blue-600 px-3 py-1.5 rounded-xl text-xs font-bold border border-blue-100 shadow-sm">VIP 1</span>
                <% } else if (customer.CapDoVIP === LOYALTY_TIER.VIP2) { %>
                    <span class="inline-flex items-center bg-purple-50 text-purple-600 px-3 py-1.5 rounded-xl text-xs font-bold border border-purple-100 shadow-sm">VIP 2</span>
                <% } else if (customer.CapDoVIP === LOYALTY_TIER.VIP3) { %>
                    <span class="inline-flex items-center gap-1.5 bg-amber-50 text-amber-600 px-3 py-1.5 rounded-xl text-xs font-bold border border-amber-100 shadow-sm">
                        <i data-lucide="crown" class="w-3.5 h-3.5"></i> VIP 3
                    </span>
                <% } %>
            </div>

            <div class="grid grid-cols-2 gap-4 border-t border-b border-gray-50 py-5 mb-5">
                <div class="relative group">
                    <div class="flex justify-between items-center mb-1">
                        <p class="text-[10px] text-gray-400 font-bold uppercase">Điểm Tích Lũy</p>
                        <button onclick="adjustPoints('<%= customer.KhachHangId %>')" class="opacity-0 group-hover:opacity-100 transition-opacity bg-amber-50 text-amber-600 hover:bg-amber-100 px-2 py-0.5 rounded text-[10px] font-bold border border-amber-100 cursor-pointer">+/- Điều chỉnh</button>
                    </div>
                    <p class="text-lg font-black text-amber-500"><%= customer.TongDiemTichLuy || 0 %></p>
                </div>
                <div>
                    <p class="text-[10px] text-gray-400 font-bold uppercase mb-1">Tổng Chi Tiêu</p>
                    <p class="text-lg font-black text-emerald-500"><%= Number(customer.TongChiTieu || 0).toLocaleString('vi-VN') %><span class="text-xs">đ</span></p>
                </div>
            </div>

            <div class="space-y-3 text-left">
                <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-full bg-gray-50 flex items-center justify-center shrink-0">
                        <i data-lucide="phone" class="w-4 h-4 text-gray-400"></i>
                    </div>
                    <div>
                        <p class="text-[10px] text-gray-400 font-semibold uppercase">Điện thoại</p>
                        <p class="text-sm font-bold text-winmart-dark"><%= customer.SoDienThoai || 'Chưa cập nhật' %></p>
                    </div>
                </div>
                <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-full bg-gray-50 flex items-center justify-center shrink-0">
                        <i data-lucide="mail" class="w-4 h-4 text-gray-400"></i>
                    </div>
                    <div>
                        <p class="text-[10px] text-gray-400 font-semibold uppercase">Email</p>
                        <p class="text-sm font-bold text-winmart-dark break-all"><%= customer.Email || 'Chưa cập nhật' %></p>
                    </div>
                </div>
                <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-full bg-gray-50 flex items-center justify-center shrink-0">
                        <i data-lucide="calendar-days" class="w-4 h-4 text-gray-400"></i>
                    </div>
                    <div>
                        <p class="text-[10px] text-gray-400 font-semibold uppercase">Ngày tham gia</p>
                        <p class="text-sm font-bold text-winmart-dark"><%= new Date(customer.NgayTao).toLocaleDateString('vi-VN') %></p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tier Settings Card -->
        <div class="bento-card p-7 rounded-3xl shadow-sm border border-gray-100 bg-white">
            <h3 class="text-sm font-black text-winmart-dark mb-4 flex items-center gap-2">
                <span class="w-1.5 h-4 bg-winmart-red rounded-full"></span> Thiết lập Hạng thành viên
            </h3>
            <form action="/admin/customers/<%= customer.KhachHangId %>/update-tier" method="POST" id="tier-form">
                <div class="space-y-4">
                    <select name="CapDoVIP" class="w-full bg-gray-50 border border-gray-200 rounded-xl px-4 py-3 text-sm font-bold text-winmart-dark focus:bg-white focus:outline-none focus:border-winmart-red focus:ring-4 focus:ring-winmart-red/10 transition-all appearance-none cursor-pointer">
                        <% Object.keys(LOYALTY_TIER).forEach(key => { %>
                            <option value="<%= LOYALTY_TIER[key] %>" <%= customer.CapDoVIP === LOYALTY_TIER[key] ? 'selected' : '' %>>
                                Hạng <%= LOYALTY_TIER[key] %>
                            </option>
                        <% }) %>
                    </select>
                    <button type="submit" id="submitBtn" class="w-full bg-winmart-dark hover:bg-black text-white px-5 py-3 rounded-xl text-sm font-bold transition flex items-center justify-center gap-2 shadow-sm">
                        <i data-lucide="refresh-cw" class="w-4 h-4 text-winmart-yellow"></i> Cập nhật Hạng
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Right Column: Order History -->
    <div class="xl:col-span-2">
        <div class="bento-card rounded-3xl shadow-sm border border-gray-100 bg-white h-full flex flex-col overflow-hidden">
            <div class="px-6 py-5 border-b border-gray-50 flex items-center gap-2 bg-gray-50/50">
                <div class="w-8 h-8 rounded-full bg-indigo-50 flex items-center justify-center">
                    <i data-lucide="history" class="w-4 h-4 text-indigo-500"></i>
                </div>
                <h3 class="text-sm font-black text-winmart-dark">10 Đơn Hàng Gần Nhất</h3>
            </div>
            
            <div class="flex-1 p-0 overflow-x-auto">
                <table class="w-full text-left min-w-[500px]">
                    <thead>
                        <tr class="bg-white border-b border-gray-50">
                            <th class="py-4 px-6 text-[10px] font-black text-gray-400 uppercase tracking-wider">Mã Đơn</th>
                            <th class="py-4 px-4 text-[10px] font-black text-gray-400 uppercase tracking-wider">Ngày Mua</th>
                            <th class="py-4 px-4 text-[10px] font-black text-gray-400 uppercase tracking-wider text-right">Tổng Tiền</th>
                            <th class="py-4 px-6 text-[10px] font-black text-gray-400 uppercase tracking-wider text-right">Trạng Thái</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-50">
                        <% if (customer.recentOrders && customer.recentOrders.length > 0) { %>
                            <% customer.recentOrders.forEach(order => { %>
                                <tr class="hover:bg-gray-50/50 transition">
                                    <td class="py-4 px-6">
                                        <span class="text-xs font-black text-indigo-500 hover:text-indigo-600 transition cursor-pointer"><%= order.maHD %></span>
                                    </td>
                                    <td class="py-4 px-4 text-xs font-semibold text-gray-500">
                                        <%= new Date(order.ngay).toLocaleString('vi-VN') %>
                                    </td>
                                    <td class="py-4 px-4 text-right text-sm font-black text-emerald-500">
                                        <%= Number(order.tong).toLocaleString('vi-VN') %>đ
                                    </td>
                                    <td class="py-4 px-6 text-right">
                                        <% if (order.status === 'Completed') { %>
                                            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md text-[10px] font-bold uppercase tracking-wider bg-emerald-50 text-emerald-600 border border-emerald-100">
                                                <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span> Hoàn thành
                                            </span>
                                        <% } else if (order.status === 'Cancelled') { %>
                                            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md text-[10px] font-bold uppercase tracking-wider bg-red-50 text-winmart-red border border-red-100">
                                                Đã hủy
                                            </span>
                                        <% } else { %>
                                            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md text-[10px] font-bold uppercase tracking-wider bg-amber-50 text-amber-600 border border-amber-100">
                                                <i data-lucide="clock" class="w-3 h-3"></i> <%= order.status %>
                                            </span>
                                        <% } %>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="4" class="py-16 text-center">
                                    <div class="w-14 h-14 bg-gray-50 rounded-full flex items-center justify-center mx-auto mb-3">
                                        <i data-lucide="shopping-bag" class="w-7 h-7 text-gray-300"></i>
                                    </div>
                                    <p class="text-sm font-bold text-gray-500 mb-1">Chưa có đơn hàng nào</p>
                                    <p class="text-xs text-gray-400">Khách hàng này chưa thực hiện giao dịch mua sắm.</p>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Slide-over Cập nhật Khách Hàng -->
<div id="editSlideOverBg" class="fixed inset-0 bg-gray-900/40 backdrop-blur-sm z-[99] hidden opacity-0 transition-opacity duration-300" onclick="closeEditSlideOver()"></div>
<div id="editSlideOver" class="fixed inset-y-0 right-0 w-full md:w-[450px] bg-white z-[100] transform translate-x-full transition-transform duration-300 ease-out shadow-2xl flex flex-col">
    <div class="px-6 py-5 border-b border-gray-100 flex justify-between items-center bg-gray-50/50">
        <div class="flex items-center gap-3">
            <div class="w-1.5 h-6 bg-winmart-red rounded-full"></div>
            <h2 class="text-lg font-black text-winmart-dark">Chỉnh Sửa Hồ Sơ</h2>
        </div>
        <button onclick="closeEditSlideOver()" class="p-2 hover:bg-gray-100 rounded-xl text-gray-400 hover:text-gray-600 transition">
            <i data-lucide="x" class="w-5 h-5"></i>
        </button>
    </div>

    <form id="editForm" action="/admin/customers/<%= customer.KhachHangId %>/update" method="POST" class="flex-1 flex flex-col overflow-y-auto">
        <div class="p-6 space-y-5">
            <div>
                <label class="block text-xs font-bold text-gray-700 mb-1.5">Tên khách hàng <span class="text-winmart-red">*</span></label>
                <input type="text" name="HoTen" value="<%= customer.HoTen %>" required 
                       class="w-full bg-white border border-gray-200 rounded-xl px-4 py-2.5 text-sm font-semibold focus:outline-none focus:border-winmart-red focus:ring-4 focus:ring-winmart-red/10 transition">
            </div>

            <div>
                <label class="block text-xs font-bold text-gray-700 mb-1.5">Số điện thoại <span class="text-winmart-red">*</span></label>
                <input type="text" name="SoDienThoai" value="<%= customer.SoDienThoai || '' %>" required 
                       class="w-full bg-white border border-gray-200 rounded-xl px-4 py-2.5 text-sm font-semibold focus:outline-none focus:border-winmart-red focus:ring-4 focus:ring-winmart-red/10 transition">
            </div>

            <div>
                <label class="block text-xs font-bold text-gray-700 mb-1.5">Email (không bắt buộc)</label>
                <input type="email" name="Email" value="<%= customer.Email || '' %>" 
                       class="w-full bg-white border border-gray-200 rounded-xl px-4 py-2.5 text-sm font-semibold focus:outline-none focus:border-winmart-red focus:ring-4 focus:ring-winmart-red/10 transition">
            </div>
        </div>

        <div class="p-6 border-t border-gray-100 bg-gray-50/50 mt-auto flex gap-3">
            <button type="button" onclick="closeEditSlideOver()" class="flex-1 bg-white border border-gray-200 text-gray-600 px-5 py-3 rounded-xl text-sm font-bold hover:bg-gray-50 transition shadow-sm">
                Thoát
            </button>
            <button type="submit" id="editSubmitBtn" class="flex-1 bg-winmart-dark text-white px-5 py-3 rounded-xl text-sm font-bold hover:bg-black transition shadow-sm flex items-center justify-center gap-2">
                <i data-lucide="save" class="w-4 h-4 text-winmart-yellow"></i> Lưu Thay Đổi
            </button>
        </div>
    </form>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    document.addEventListener('DOMContentLoaded', () => {
        const form = document.getElementById('tier-form');
        
        if (form) {
            form.addEventListener('submit', async (e) => {
                e.preventDefault();
                
                const btn = document.getElementById('submitBtn');
                const btnOriginalText = btn.innerHTML;
                btn.disabled = true;
                btn.innerHTML = '<i data-lucide="loader-2" class="w-4 h-4 text-winmart-yellow animate-spin"></i> Đang xử lý...';
                lucide.createIcons();

                try {
                    const formData = new URLSearchParams(new FormData(form));

                    const res = await fetch(form.action, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                        },
                        body: formData
                    });
                    
                    const data = await res.json();
                    
                    if (data.success) {
                        await Swal.fire({
                            title: 'Thành công',
                            text: data.message,
                            icon: 'success',
                            timer: 1500,
                            showConfirmButton: false
                        });
                        window.location.reload();
                    } else {
                        Swal.fire('Lỗi', data.message, 'error');
                        btn.disabled = false;
                        btn.innerHTML = btnOriginalText;
                        lucide.createIcons();
                    }
                } catch (err) {
                    Swal.fire('Lỗi', 'Có lỗi kết nối máy chủ', 'error');
                    btn.disabled = false;
                    btn.innerHTML = btnOriginalText;
                    lucide.createIcons();
                }
            });
        }

        const editForm = document.getElementById('editForm');
        if (editForm) {
            editForm.addEventListener('submit', async (e) => {
                e.preventDefault();
                
                const btn = document.getElementById('editSubmitBtn');
                const btnOriginalText = btn.innerHTML;
                btn.disabled = true;
                btn.innerHTML = '<i data-lucide="loader-2" class="w-4 h-4 text-winmart-yellow animate-spin"></i> Đang xử lý...';
                lucide.createIcons();

                try {
                    const formData = new URLSearchParams(new FormData(editForm));

                    const res = await fetch(editForm.action, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                        },
                        body: formData
                    });
                    
                    const data = await res.json();
                    
                    if (data.success) {
                        closeEditSlideOver();
                        await Swal.fire({
                            title: 'Thành công',
                            text: data.message,
                            icon: 'success',
                            timer: 1500,
                            showConfirmButton: false
                        });
                        window.location.reload();
                    } else {
                        Swal.fire('Lỗi', data.message, 'error');
                        btn.disabled = false;
                        btn.innerHTML = btnOriginalText;
                        lucide.createIcons();
                    }
                } catch (err) {
                    Swal.fire('Lỗi', 'Có lỗi kết nối máy chủ', 'error');
                    btn.disabled = false;
                    btn.innerHTML = btnOriginalText;
                    lucide.createIcons();
                }
            });
        }
    });

    function toggleEditSlideOver() {
        const bg = document.getElementById('editSlideOverBg');
        const slide = document.getElementById('editSlideOver');
        
        if (bg.classList.contains('hidden')) {
            bg.classList.remove('hidden');
            setTimeout(() => {
                bg.classList.remove('opacity-0');
                slide.classList.remove('translate-x-full');
            }, 10);
            document.body.style.overflow = 'hidden';
        }
    }

    function closeEditSlideOver() {
        const bg = document.getElementById('editSlideOverBg');
        const slide = document.getElementById('editSlideOver');
        
        bg.classList.add('opacity-0');
        slide.classList.add('translate-x-full');
        
        setTimeout(() => {
            bg.classList.add('hidden');
        }, 300);
        document.body.style.overflow = '';
    }

    async function adjustPoints(id) {
        const { value: formValues } = await Swal.fire({
            title: 'Điều chỉnh điểm',
            html: `
                <input id="swal-input-diem" type="number" class="w-full bg-gray-50 border border-gray-200 rounded-xl px-4 py-3 mb-3 text-sm focus:border-winmart-red focus:outline-none" placeholder="Số điểm (+ để cộng, - để trừ)">
                <input id="swal-input-ghichu" type="text" class="w-full bg-gray-50 border border-gray-200 rounded-xl px-4 py-3 text-sm focus:border-winmart-red focus:outline-none" placeholder="Lý do điều chỉnh (bắt buộc)">
            `,
            focusConfirm: false,
            showCancelButton: true,
            confirmButtonText: 'Thực hiện',
            cancelButtonText: 'Hủy',
            confirmButtonColor: '#1e293b',
            preConfirm: () => {
                const diem = document.getElementById('swal-input-diem').value;
                const ghichu = document.getElementById('swal-input-ghichu').value;
                if (!diem || isNaN(diem)) {
                    Swal.showValidationMessage('Vui lòng nhập số điểm hợp lệ');
                } else if (!ghichu.trim()) {
                    Swal.showValidationMessage('Vui lòng nhập lý do điều chỉnh');
                }
                return { SoDiemThayDoi: diem, GhiChu: ghichu };
            }
        });

        if (formValues) {
            try {
                const formData = new URLSearchParams();
                formData.append('SoDiemThayDoi', formValues.SoDiemThayDoi);
                formData.append('GhiChu', formValues.GhiChu);

                const res = await fetch('/admin/customers/' + id + '/adjust-points', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: formData
                });
                const data = await res.json();
                
                if (data.success) {
                    await Swal.fire({
                        title: 'Thành công',
                        text: data.message,
                        icon: 'success',
                        timer: 1500,
                        showConfirmButton: false
                    });
                    window.location.reload();
                } else {
                    Swal.fire('Lỗi', data.message, 'error');
                }
            } catch (err) {
                Swal.fire('Lỗi', 'Có lỗi kết nối máy chủ', 'error');
            }
        }
    }
</script>
