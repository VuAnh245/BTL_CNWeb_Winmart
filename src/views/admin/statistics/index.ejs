    <div class="flex items-center justify-between mb-5">
        <h3 class="text-sm font-black text-winmart-dark dark:text-white flex items-center gap-2">
            <div class="w-1.5 h-4 bg-blue-500 rounded-full"></div>
            Hiệu Suất Nhân Viên
        </h3>
    </div>
    <div class="overflow-x-auto">
        <table class="w-full text-left">
            <thead>
                <tr class="bg-gray-50 dark:bg-gray-800">
                    <th class="py-3 px-4 text-[10px] font-black text-gray-400 uppercase tracking-wider rounded-tl-lg">#</th>
                    <th class="py-3 px-4 text-[10px] font-black text-gray-400 uppercase tracking-wider">Nhân Viên</th>
                    <th class="py-3 px-4 text-[10px] font-black text-gray-400 uppercase tracking-wider text-right">Số Đơn Xử Lý</th>
                    <th class="py-3 px-4 text-[10px] font-black text-gray-400 uppercase tracking-wider text-right rounded-tr-lg">Doanh Thu Mang Lại</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-50 dark:divide-gray-700">
                <% if (employeePerformance && employeePerformance.length > 0) { %>
                    <% employeePerformance.forEach((e, index) => { %>
                    <tr class="hover:bg-gray-50/50 transition bg-white dark:bg-transparent dark:hover:bg-gray-800/50">
                        <td class="py-3 px-4">
                            <span class="w-6 h-6 rounded bg-gray-100 dark:bg-gray-700 flex items-center justify-center text-xs font-black text-gray-400"><%= index + 1 %></span>
