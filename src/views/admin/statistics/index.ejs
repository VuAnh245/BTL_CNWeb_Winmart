    <div class="flex items-center justify-between mb-5">
        <h3 class="text-sm font-black text-winmart-dark dark:text-white flex items-center gap-2">
            <div class="w-1.5 h-4 bg-purple-500 rounded-full"></div>
            Thống Kê Khuyến Mãi
        </h3>
    </div>
    <div class="overflow-x-auto">
        <table class="w-full text-left">
            <thead>
                <tr class="bg-gray-50 dark:bg-gray-800">
                    <th class="py-3 px-4 text-[10px] font-black text-gray-400 uppercase tracking-wider rounded-tl-lg">Mã Giảm Giá</th>
                    <th class="py-3 px-4 text-[10px] font-black text-gray-400 uppercase tracking-wider">Tên Chương Trình</th>
                    <th class="py-3 px-4 text-[10px] font-black text-gray-400 uppercase tracking-wider text-right">Số Lần Sử Dụng</th>
                    <th class="py-3 px-4 text-[10px] font-black text-gray-400 uppercase tracking-wider text-right rounded-tr-lg">Tổng Giá Trị Giảm</th>
