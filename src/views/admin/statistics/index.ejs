                        <td class="py-3 px-4">
                            <span class="w-6 h-6 rounded bg-gray-100 dark:bg-gray-700 flex items-center justify-center text-xs font-black text-gray-400"><%= index + 1 %></span>
                        </td>
                        <td class="py-3 px-4">
                            <span class="text-sm font-bold text-gray-700 dark:text-gray-200"><%= p.TenSanPham %></span>
                        </td>
                        <td class="py-3 px-4 text-right">
                            <span class="text-xs font-black text-winmart-dark dark:text-white"><%= p.TotalSold %></span>
                        </td>
                        <td class="py-3 px-4 text-right">
                            <span class="text-sm font-black text-emerald-600"><%= Number(p.TotalMoney).toLocaleString('vi-VN') %>đ</span>
                        </td>
                    </tr>
                    <% }) %>
                <% } else { %>
