                    <td class="py-3 px-4">
                        <span class="text-sm font-bold text-gray-700 dark:text-gray-200"><%= promo.TenMaGiamGia %></span>
                    </td>
                    <td class="py-3 px-4 text-right">
                        <span class="text-xs font-black text-winmart-dark dark:text-white"><%= promo.UsageCount %></span>
