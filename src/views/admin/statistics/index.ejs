                        <span class="inline-flex items-center gap-1.5 text-xs font-black text-purple-600 bg-purple-50 px-2.5 py-1 rounded-lg dark:bg-purple-900/30">
                            <i data-lucide="tag" class="w-3 h-3"></i>
                            <%= promo.MaCode %>
