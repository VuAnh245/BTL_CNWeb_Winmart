                    <tr>
                        <td colspan="4" class="py-8 text-center">
                            <i data-lucide="users" class="w-10 h-10 text-gray-300 mx-auto mb-2"></i>
                            <p class="text-sm font-semibold text-gray-400">Chưa có dữ liệu nhân viên trong tháng này.</p>
                        </td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

        </div>
    </div>
</div>

<!-- Row 7: Promotion Stats Table (only if data exists) -->
<% if (promotionStats && promotionStats.length > 0) { %>
