                            <i data-lucide="package" class="w-10 h-10 text-gray-300 mx-auto mb-2"></i>
                            <p class="text-sm font-semibold text-gray-400">Chưa có dữ liệu bán hàng trong tháng này.</p>
                        </td>
                    </tr>
                <% } %>
