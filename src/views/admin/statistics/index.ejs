                    <th class="py-3 px-4 text-[10px] font-black text-gray-400 uppercase tracking-wider">Sản Phẩm</th>
                    <th class="py-3 px-4 text-[10px] font-black text-gray-400 uppercase tracking-wider text-right">Số Lượng Bán</th>
                    <th class="py-3 px-4 text-[10px] font-black text-gray-400 uppercase tracking-wider text-right rounded-tr-lg">Doanh Thu Mang Lại</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-50 dark:divide-gray-700">
