<!-- Row 0: Page Header with Date Filter & Export -->
<div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-6">
    <div>
        <p class="text-[11px] text-winmart-slate font-semibold tracking-wider uppercase mb-1">Thống Kê</p>
        <h1 class="text-2xl font-black tracking-tight text-winmart-dark dark:text-white">Báo Cáo Doanh Thu</h1>
    </div>
    <div class="flex flex-wrap items-center gap-3">
        <!-- Date Filter -->
        <form method="GET" action="/admin/statistics" class="flex items-center gap-2">
            <div class="flex items-center gap-2 bg-white border border-gray-100 rounded-2xl px-4 py-2 shadow-sm dark:bg-gray-800 dark:border-gray-700">
                <i data-lucide="calendar" class="w-4 h-4 text-winmart-red"></i>
                <select name="month" class="text-xs font-bold text-gray-700 bg-transparent border-none outline-none cursor-pointer pr-1 dark:text-gray-200">
                    <% for (let m = 1; m <= 12; m++) { %>
                    <option value="<%= m %>" <%= m === selectedMonth ? 'selected' : '' %>>Tháng <%= m %></option>
                    <% } %>
                </select>
                <select name="year" class="text-xs font-bold text-gray-700 bg-transparent border-none outline-none cursor-pointer pr-1 dark:text-gray-200">
                    <% for (let y = 2024; y <= 2030; y++) { %>
                    <option value="<%= y %>" <%= y === selectedYear ? 'selected' : '' %>><%= y %></option>
                    <% } %>
                </select>
            </div>
            <button type="submit" class="px-4 py-2 bg-winmart-dark text-white text-xs font-black rounded-xl hover:bg-gray-800 transition-colors shadow-sm dark:bg-gray-700 dark:hover:bg-gray-600">
                <i data-lucide="search" class="w-3.5 h-3.5 inline-block mr-1 -mt-0.5"></i> Xem
            </button>
        </form>

        <!-- Export Buttons -->
        <div class="flex items-center gap-2">
            <a href="/admin/statistics/export/excel?month=<%= selectedMonth %>&year=<%= selectedYear %>"
               class="flex items-center gap-1.5 px-4 py-2 bg-emerald-500 text-white text-xs font-black rounded-xl hover:bg-emerald-600 transition-colors shadow-sm">
                <i data-lucide="file-spreadsheet" class="w-3.5 h-3.5"></i> Xuất Excel
            </a>
            <a href="/admin/statistics/export/pdf?month=<%= selectedMonth %>&year=<%= selectedYear %>"
               class="flex items-center gap-1.5 px-4 py-2 bg-winmart-red text-white text-xs font-black rounded-xl hover:bg-winmart-redHover transition-colors shadow-sm">
                <i data-lucide="file-text" class="w-3.5 h-3.5"></i> Xuất PDF
            </a>
        </div>
    </div>
</div>

<!-- Row 1: 4 KPI Cards -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5 mb-6">
    <!-- Tổng Doanh Thu -->
    <div class="bento-card p-5 group hover:-translate-y-1 transition-transform">
        <div class="flex items-center justify-between mb-4">
            <div class="w-10 h-10 rounded-2xl bg-emerald-50 text-emerald-500 flex items-center justify-center group-hover:bg-emerald-500 group-hover:text-white transition-colors">
                <i data-lucide="dollar-sign" class="w-5 h-5"></i>
            </div>
            <span class="text-[10px] font-black text-emerald-500 bg-emerald-50 px-2 py-1 rounded-lg">Tháng <%= selectedMonth %></span>
        </div>
        <div class="text-2xl font-black text-winmart-dark dark:text-white mb-1">
            <%= Number(stats.totalRevenue).toLocaleString('vi-VN') %>đ
        </div>
        <p class="text-[10px] font-black text-gray-400 uppercase tracking-widest">Tổng Doanh Thu</p>
    </div>

    <!-- Đơn Hàng Hoàn Thành -->
    <div class="bento-card p-5 group hover:-translate-y-1 transition-transform">
        <div class="flex items-center justify-between mb-4">
            <div class="w-10 h-10 rounded-2xl bg-blue-50 text-blue-500 flex items-center justify-center group-hover:bg-blue-500 group-hover:text-white transition-colors">
                <i data-lucide="shopping-bag" class="w-5 h-5"></i>
            </div>
            <span class="text-[10px] font-black text-blue-500 bg-blue-50 px-2 py-1 rounded-lg">Hoàn thành</span>
        </div>
        <div class="text-2xl font-black text-winmart-dark dark:text-white mb-1">
            <%= Number(stats.totalOrders).toLocaleString('vi-VN') %>
        </div>
        <p class="text-[10px] font-black text-gray-400 uppercase tracking-widest">Đơn Hàng Hoàn Thành</p>
    </div>

    <!-- Khách Hàng Mua Hàng -->
    <div class="bento-card p-5 group hover:-translate-y-1 transition-transform">
        <div class="flex items-center justify-between mb-4">
            <div class="w-10 h-10 rounded-2xl bg-purple-50 text-purple-500 flex items-center justify-center group-hover:bg-purple-500 group-hover:text-white transition-colors">
                <i data-lucide="users" class="w-5 h-5"></i>
            </div>
            <span class="text-[10px] font-black text-purple-500 bg-purple-50 px-2 py-1 rounded-lg">Unique</span>
        </div>
        <div class="text-2xl font-black text-winmart-dark dark:text-white mb-1">
            <%= Number(stats.totalCustomers).toLocaleString('vi-VN') %>
        </div>
        <p class="text-[10px] font-black text-gray-400 uppercase tracking-widest">Khách Hàng Mua Hàng</p>
    </div>

    <!-- Lợi Nhuận Gộp -->
    <div class="bento-card p-5 group hover:-translate-y-1 transition-transform">
        <div class="flex items-center justify-between mb-4">
            <div class="w-10 h-10 rounded-2xl bg-winmart-red/10 text-winmart-red flex items-center justify-center group-hover:bg-winmart-red group-hover:text-white transition-colors">
                <i data-lucide="trending-up" class="w-5 h-5"></i>
            </div>
            <span class="text-[10px] font-black text-winmart-red bg-red-50 px-2 py-1 rounded-lg">
                Margin: <%= Number(stats.totalRevenue) > 0 ? (Number(stats.grossProfit) / Number(stats.totalRevenue) * 100).toFixed(1) : '0.0' %>%
            </span>
        </div>
        <div class="text-2xl font-black text-winmart-dark dark:text-white mb-1">
            <%= Number(stats.grossProfit).toLocaleString('vi-VN') %>đ
        </div>
        <p class="text-[10px] font-black text-gray-400 uppercase tracking-widest">Lợi Nhuận Gộp</p>
    </div>
</div>

<!-- Row 2: Charts (2/3 + 1/3) -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6">
    <!-- Line Chart: Daily Revenue -->
    <div class="bento-card p-6 lg:col-span-2 flex flex-col">
        <div class="flex items-center justify-between mb-5">
            <h3 class="text-sm font-black text-winmart-dark dark:text-white flex items-center gap-2">
                <div class="w-1.5 h-4 bg-emerald-500 rounded-full"></div>
                Biểu Đồ Doanh Thu Theo Ngày
            </h3>
            <span class="text-[10px] font-black text-gray-400 uppercase">Tháng <%= selectedMonth %>/<%= selectedYear %></span>
        </div>
        <div class="flex-1 w-full bg-white dark:bg-gray-800 rounded-xl relative min-h-[280px]">
            <canvas id="revenueChart"></canvas>
        </div>
    </div>

    <!-- Doughnut Chart: Online vs POS -->
    <div class="bento-card p-6 lg:col-span-1 flex flex-col">
        <div class="flex items-center justify-between mb-5">
            <h3 class="text-sm font-black text-winmart-dark dark:text-white flex items-center gap-2">
                <div class="w-1.5 h-4 bg-blue-500 rounded-full"></div>
                Tỉ Lệ Đơn Hàng
            </h3>
        </div>
        <div class="relative flex-1 flex items-center justify-center min-h-[200px]">
            <canvas id="typeChart"></canvas>
        </div>
        <div class="mt-4 grid grid-cols-2 gap-4">
            <div class="text-center bg-gray-50 rounded-xl p-3 dark:bg-gray-800">
                <span class="block text-[10px] font-bold text-gray-400 uppercase mb-1">Web Online</span>
                <span class="text-lg font-black text-winmart-red"><%= chart.onlineCount %></span>
            </div>
            <div class="text-center bg-gray-50 rounded-xl p-3 dark:bg-gray-800">
                <span class="block text-[10px] font-bold text-gray-400 uppercase mb-1">Tại Quầy (POS)</span>
                <span class="text-lg font-black text-gray-700 dark:text-gray-200"><%= chart.posCount %></span>
            </div>
        </div>
    </div>
</div>

<!-- Row 3: Two more charts (1/2 + 1/2) -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
    <!-- Doughnut Chart: Payment Methods -->
    <div class="bento-card p-6 flex flex-col">
        <div class="flex items-center justify-between mb-5">
            <h3 class="text-sm font-black text-winmart-dark dark:text-white flex items-center gap-2">
                <div class="w-1.5 h-4 bg-purple-500 rounded-full"></div>
                Phương Thức Thanh Toán
            </h3>
        </div>
        <% if (paymentMethods && paymentMethods.length > 0) { %>
        <div class="flex-1 flex items-center justify-center min-h-[250px]">
            <canvas id="paymentChart"></canvas>
        </div>
        <div class="mt-4 flex flex-wrap justify-center gap-4">
            <% paymentMethods.forEach(pm => {
                let label = pm.PhuongThucTT;
                if (label === 'TienMat') label = 'Tiền mặt';
                else if (label === 'ChuyenKhoan') label = 'Chuyển khoản';
                else if (label === 'QR') label = 'QR Code';
            %>
            <div class="flex items-center gap-2">
                <span class="w-2.5 h-2.5 rounded-full <%= pm.PhuongThucTT === 'TienMat' ? 'bg-emerald-500' : pm.PhuongThucTT === 'ChuyenKhoan' ? 'bg-blue-500' : 'bg-purple-500' %>"></span>
                <span class="text-xs font-bold text-gray-600 dark:text-gray-300"><%= label %>: <span class="text-winmart-dark dark:text-white"><%= pm.Count %></span></span>
            </div>
            <% }) %>
        </div>
        <% } else { %>
        <div class="flex-1 flex flex-col items-center justify-center py-8">
            <i data-lucide="credit-card" class="w-10 h-10 text-gray-300 mb-2"></i>
            <p class="text-sm font-semibold text-gray-400">Chưa có dữ liệu thanh toán</p>
        </div>
        <% } %>
    </div>

    <!-- Bar Chart: Revenue by Category (Horizontal) -->
    <div class="bento-card p-6 flex flex-col">
        <div class="flex items-center justify-between mb-5">
            <h3 class="text-sm font-black text-winmart-dark dark:text-white flex items-center gap-2">
                <div class="w-1.5 h-4 bg-winmart-red rounded-full"></div>
                Doanh Thu Theo Danh Mục
            </h3>
        </div>
        <% if (categoryRevenue && categoryRevenue.length > 0) { %>
        <div class="flex-1 flex items-center justify-center min-h-[250px]">
            <canvas id="categoryChart"></canvas>
        </div>
        <% } else { %>
        <div class="flex-1 flex flex-col items-center justify-center py-8">
            <i data-lucide="bar-chart-3" class="w-10 h-10 text-gray-300 mb-2"></i>
            <p class="text-sm font-semibold text-gray-400">Chưa có dữ liệu danh mục</p>
        </div>
        <% } %>
    </div>
</div>

<!-- Row 4: Top 5 Products Table -->
<div class="bento-card p-6 mb-6">
    <div class="flex items-center justify-between mb-5">
        <h3 class="text-sm font-black text-winmart-dark dark:text-white flex items-center gap-2">
            <div class="w-1.5 h-4 bg-emerald-500 rounded-full"></div>
            Top 5 Sản Phẩm Bán Chạy Nhất
