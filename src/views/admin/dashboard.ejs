<!-- Dashboard Overview -->
<div class="mb-8">
    <p class="text-[11px] text-winmart-slate font-semibold tracking-widest uppercase mb-1">Tổng quan hệ thống</p>
    <h1 class="text-2xl font-black text-winmart-dark dark:text-white tracking-tight">Dashboard</h1>
</div>

<!-- Hàng 1: 4 Thẻ Chỉ Số Trọng Yếu (KPIs) -->
<div class="grid grid-cols-2 lg:grid-cols-4 gap-5 mb-6">
    <!-- Doanh thu -->
    <div class="bento-card p-5 group hover:-translate-y-1 transition-transform">
        <div class="flex items-center justify-between mb-4">
            <div class="w-10 h-10 rounded-2xl bg-emerald-50 text-emerald-500 flex items-center justify-center group-hover:bg-emerald-500 group-hover:text-white transition-colors">
                <i data-lucide="dollar-sign" class="w-5 h-5"></i>
            </div>
            <span class="text-[10px] font-black text-emerald-500 bg-emerald-50 px-2 py-1 rounded-lg">Tháng này</span>
        </div>
        <div class="text-2xl font-black text-winmart-dark dark:text-white mb-1">
            <%= Number(stats.doanhThu).toLocaleString('vi-VN') %>đ
        </div>
        <p class="text-[10px] font-bold text-gray-400 uppercase tracking-wider">Doanh thu thuần</p>
    </div>

    <!-- Lợi nhuận gộp -->
    <div class="bento-card p-5 group hover:-translate-y-1 transition-transform">
        <div class="flex items-center justify-between mb-4">
            <div class="w-10 h-10 rounded-2xl bg-winmart-red/10 text-winmart-red flex items-center justify-center group-hover:bg-winmart-red group-hover:text-white transition-colors">
                <i data-lucide="trending-up" class="w-5 h-5"></i>
            </div>
            <span class="text-[10px] font-black text-winmart-red bg-red-50 px-2 py-1 rounded-lg">Real-time</span>
        </div>
        <div class="text-2xl font-black text-winmart-dark dark:text-white mb-1">
            <%= Number(stats.loiNhuanGop).toLocaleString('vi-VN') %>đ
        </div>
        <p class="text-[10px] font-bold text-gray-400 uppercase tracking-wider">Lợi nhuận gộp</p>
    </div>

    <!-- Giá trị trung bình đơn (AOV) -->
    <div class="bento-card p-5 group hover:-translate-y-1 transition-transform">
        <div class="flex items-center justify-between mb-4">
            <div class="w-10 h-10 rounded-2xl bg-blue-50 text-blue-500 flex items-center justify-center group-hover:bg-blue-500 group-hover:text-white transition-colors">
                <i data-lucide="shopping-cart" class="w-5 h-5"></i>
            </div>
            <span class="text-[10px] font-black text-blue-500 bg-blue-50 px-2 py-1 rounded-lg">AOV</span>
        </div>
        <div class="text-2xl font-black text-winmart-dark dark:text-white mb-1">
            <%= Math.round(Number(stats.aov)).toLocaleString('vi-VN') %>đ
        </div>
        <p class="text-[10px] font-bold text-gray-400 uppercase tracking-wider">Trung bình / Đơn</p>
    </div>

    <!-- Sản phẩm kho -->
    <div class="bento-card p-5 group hover:-translate-y-1 transition-transform">
        <div class="flex items-center justify-between mb-4">
            <div class="w-10 h-10 rounded-2xl bg-purple-50 text-purple-500 flex items-center justify-center group-hover:bg-purple-500 group-hover:text-white transition-colors">
                <i data-lucide="package" class="w-5 h-5"></i>
            </div>
            <span class="text-[10px] font-black text-purple-500 bg-purple-50 px-2 py-1 rounded-lg">Đang bán</span>
        </div>
        <div class="text-2xl font-black text-winmart-dark dark:text-white mb-1">
            <%= Number(stats.sanPham).toLocaleString('vi-VN') %>
        </div>
        <p class="text-[10px] font-bold text-gray-400 uppercase tracking-wider">Sản phẩm đầu mã</p>
    </div>
</div>

<!-- Hàng 2: Biểu đồ thông tin chiến lược -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6">
    <!-- Biểu đồ doanh thu (Line Chart) -->
    <div class="bento-card p-6 lg:col-span-2 flex flex-col">
        <div class="flex items-center justify-between mb-5">
            <h3 class="text-sm font-black text-winmart-dark dark:text-white flex items-center gap-2">
                <div class="w-1.5 h-4 bg-emerald-500 rounded-full"></div>
                Biểu đồ Doanh thu <%= typeof period !== 'undefined' && period === 'month' ? '(30 ngày qua)' : '(7 ngày qua)' %>
            </h3>
            <div class="flex bg-gray-100 dark:bg-gray-700 rounded-lg p-0.5">
                <a href="/admin?period=week" class="px-3 py-1 text-[10px] font-bold rounded-md transition-colors <%= (!locals.period || locals.period === 'week') ? 'bg-white text-winmart-dark shadow-sm dark:bg-gray-600 dark:text-white' : 'text-gray-500 hover:text-winmart-dark dark:text-gray-400 dark:hover:text-white' %>">Tuần</a>
                <a href="/admin?period=month" class="px-3 py-1 text-[10px] font-bold rounded-md transition-colors <%= (locals.period === 'month') ? 'bg-white text-winmart-dark shadow-sm dark:bg-gray-600 dark:text-white' : 'text-gray-500 hover:text-winmart-dark dark:text-gray-400 dark:hover:text-white' %>">Tháng</a>
            </div>
        </div>
        <div class="flex-1 w-full bg-white dark:bg-gray-800 rounded-xl relative min-h-[250px]">
            <canvas id="revenueChart"></canvas>
        </div>
    </div>

    <!-- Tỉ lệ Kênh bán hàng (Doughnut Chart) -->
    <div class="bento-card p-6 lg:col-span-1 flex flex-col">
        <div class="flex items-center justify-between mb-5">
            <h3 class="text-sm font-black text-winmart-dark dark:text-white flex items-center gap-2">
                <div class="w-1.5 h-4 bg-blue-500 rounded-full"></div>
                Cơ cấu Kênh bán hàng
            </h3>
        </div>
        <div class="relative flex-1 flex items-center justify-center min-h-[200px]">
            <canvas id="channelChart"></canvas>
        </div>
        <div class="mt-4 grid grid-cols-2 gap-4">
            <div class="text-center bg-gray-50 rounded-xl p-3">
                <span class="block text-[10px] font-bold text-gray-400 uppercase mb-1">Web Online</span>
                <span class="text-lg font-black text-winmart-red"><%= chartData.onlineCount %></span>
            </div>
            <div class="text-center bg-gray-50 rounded-xl p-3">
                <span class="block text-[10px] font-bold text-gray-400 uppercase mb-1">Tại quầy POS</span>
                <span class="text-lg font-black text-gray-700"><%= chartData.posCount %></span>
            </div>
        </div>
    </div>
</div>

<!-- Hàng 3: Đơn hàng & Top Sản phẩm -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6">
    <!-- Đơn hàng gần đây -->
    <div class="bento-card p-6 lg:col-span-2">
        <div class="flex items-center justify-between mb-5">
            <h3 class="text-sm font-black text-winmart-dark dark:text-white flex items-center gap-2">
                <div class="w-1.5 h-4 bg-winmart-red rounded-full"></div>
                Đơn hàng gần đây
            </h3>
            <a href="/admin/orders" class="text-xs font-bold text-winmart-red hover:text-winmart-dark dark:text-white transition-colors flex items-center gap-1">
                Xem tất cả <i data-lucide="arrow-right" class="w-3 h-3"></i>
            </a>
        </div>
        <div class="space-y-3">
            <% if (typeof recentOrders !== 'undefined' && recentOrders && recentOrders.length > 0) { %>
                <% recentOrders.forEach(order => { %>
                <div class="flex items-center justify-between p-3 bg-gray-50 rounded-xl hover:bg-gray-100 transition-colors">
                    <div class="flex items-center gap-3">
                        <div class="w-9 h-9 rounded-xl bg-white border border-gray-100 flex items-center justify-center shadow-sm">
                            <i data-lucide="receipt" class="w-4 h-4 text-gray-500"></i>
                        </div>
                        <div>
                            <div class="text-xs font-extrabold text-winmart-dark dark:text-white"><%= order.MaHoaDon %></div>
                            <div class="text-[10px] text-gray-400 font-semibold"><%= new Date(order.NgayLap).toLocaleDateString('vi-VN') %></div>
                        </div>
                    </div>
                    <div class="text-right">
                        <div class="text-sm font-black text-winmart-dark dark:text-white"><%= Number(order.TongTienSauKM).toLocaleString('vi-VN') %>đ</div>
                        <% 
                            let statusColor = 'text-gray-500 bg-gray-100';
                            if (order.TrangThai === 'Pending') { statusColor = 'text-amber-500 bg-amber-50'; }
                            else if (order.TrangThai === 'Processing') { statusColor = 'text-blue-500 bg-blue-50'; }
                            else if (order.TrangThai === 'Shipping') { statusColor = 'text-indigo-500 bg-indigo-50'; }
                            else if (order.TrangThai === 'Completed') { statusColor = 'text-emerald-500 bg-emerald-50'; }
                            else if (order.TrangThai === 'Canceled') { statusColor = 'text-red-500 bg-red-50'; }
                        %>
                        <span class="inline-flex mt-1 text-[9px] font-black uppercase px-2 py-0.5 rounded-md <%= statusColor %>"><%= order.TrangThai %></span>
                    </div>
                </div>
                <% }) %>
            <% } else { %>
            <div class="text-center py-8">
                <i data-lucide="inbox" class="w-10 h-10 text-gray-300 mx-auto mb-2"></i>
                <p class="text-sm font-semibold text-gray-400">Chưa có đơn hàng nào</p>
            </div>
            <% } %>
        </div>
    </div>

    <!-- Top 5 Sản phẩm bán chạy -->
    <div class="bento-card p-6 lg:col-span-1">
        <h3 class="text-sm font-black text-winmart-dark dark:text-white mb-5 flex items-center gap-2">
            <div class="w-1.5 h-4 bg-purple-500 rounded-full"></div>
            Top 5 Bán chạy
        </h3>
        <div class="space-y-4">
            <% if (typeof topProducts !== 'undefined' && topProducts && topProducts.length > 0) { %>
                <% topProducts.forEach((p, index) => { %>
                <div class="flex items-center gap-3">
                    <span class="text-sm font-black text-gray-300 w-4"><%= index + 1 %></span>
                    <img src="<%= p.HinhAnh ? (p.HinhAnh.startsWith('http') || p.HinhAnh.startsWith('/') ? p.HinhAnh : '/uploads/' + p.HinhAnh) : '/images/products/placeholder.png' %>" class="w-10 h-10 rounded-lg object-cover border border-gray-100" onerror="this.onerror=null; this.src='https://ui-avatars.com/api/?name=<%= encodeURIComponent(p.TenSanPham.charAt(0)) %>&background=f1f5f9&color=94a3b8&size=100';">
                    <div class="flex-1 min-w-0">
                        <div class="text-xs font-bold text-winmart-dark truncate"><%= p.TenSanPham %></div>
                        <div class="text-[10px] text-gray-400 font-medium">Đã bán: <span class="text-emerald-500 font-bold"><%= p.TotalSold %></span></div>
                    </div>
                </div>
                <% }) %>
            <% } else { %>
                <div class="text-center py-6 text-gray-400 text-xs font-semibold">Chưa có dữ liệu</div>
            <% } %>
        </div>
    </div>
</div>

<!-- Hàng 3.5: Kho hàng -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
    <!-- Phiếu nhập đang chờ duyệt -->
    <div class="bento-card p-6">
        <div class="flex items-center justify-between mb-5">
            <h3 class="text-sm font-black text-winmart-dark dark:text-white flex items-center gap-2">
                <div class="w-1.5 h-4 bg-orange-500 rounded-full"></div>
                Phiếu nhập chờ duyệt
            </h3>
            <a href="/admin/inventory" class="text-xs font-bold text-orange-500 hover:text-winmart-dark dark:text-white transition-colors flex items-center gap-1">
                Xem tất cả <i data-lucide="arrow-right" class="w-3 h-3"></i>
            </a>
        </div>
        <div class="space-y-3">
            <% if (typeof pendingReceipts !== 'undefined' && pendingReceipts && pendingReceipts.length > 0) { %>
                <% pendingReceipts.forEach(receipt => { %>
                <div class="flex items-center justify-between p-3 bg-gray-50 rounded-xl hover:bg-gray-100 transition-colors">
                    <div class="flex items-center gap-3">
                        <div class="w-9 h-9 rounded-xl bg-white border border-gray-100 flex items-center justify-center shadow-sm">
                            <i data-lucide="package-plus" class="w-4 h-4 text-gray-500"></i>
                        </div>
                        <div>
                            <div class="text-xs font-extrabold text-winmart-dark dark:text-white"><%= receipt.MaPhieuNhap %></div>
                            <div class="text-[10px] text-gray-400 font-semibold"><%= new Date(receipt.NgayLap).toLocaleDateString('vi-VN') %> • <%= receipt.TenNhaCungCap || 'Không có NCC' %></div>
                        </div>
                    </div>
                    <div class="text-right">
                        <div class="text-sm font-black text-winmart-dark dark:text-white"><%= (Number(receipt.TongTienNhap) + Number(receipt.TongVATDauVao || 0)).toLocaleString('vi-VN') %>đ</div>
                        <a href="/admin/inventory/<%= receipt.PhieuNhapId %>" class="inline-flex mt-1 text-[9px] font-black uppercase px-2 py-0.5 rounded-md text-orange-600 bg-orange-100 hover:bg-orange-200 transition">Duyệt ngay</a>
                    </div>
                </div>
                <% }) %>
            <% } else { %>
            <div class="text-center py-8">
                <i data-lucide="check-circle" class="w-10 h-10 text-emerald-300 mx-auto mb-2"></i>
                <p class="text-sm font-semibold text-gray-400">Không có phiếu nhập nào cần duyệt</p>
            </div>
            <% } %>
        </div>
    </div>

    <!-- Cảnh báo Hạn Sử Dụng -->
    <div class="bento-card p-6">
        <div class="flex items-center justify-between mb-5">
            <h3 class="text-sm font-black text-winmart-dark dark:text-white flex items-center gap-2">
                <div class="w-1.5 h-4 bg-red-500 rounded-full"></div>
                Sắp hết hạn (Date)
            </h3>
            <a href="/admin/inventory" class="text-xs font-bold text-red-500 hover:text-winmart-dark dark:text-white transition-colors flex items-center gap-1">
                Xem kho <i data-lucide="arrow-right" class="w-3 h-3"></i>
            </a>
        </div>
        <div class="space-y-3">
            <% if (typeof expiringProducts !== 'undefined' && expiringProducts && expiringProducts.length > 0) { %>
                <% expiringProducts.forEach(product => { 
                    const today = new Date();
                    const expDate = new Date(product.NgayHetHan);
                    const diffTime = expDate - today;
                    const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
                    
                    let statusColor = 'text-amber-600 bg-amber-50 border-amber-100';
                    let statusIcon = 'alert-triangle';
                    if (diffDays <= 7) {
                        statusColor = 'text-red-600 bg-red-50 border-red-100';
                        statusIcon = 'alert-octagon';
                    } else if (diffDays <= 0) {
                        statusColor = 'text-red-700 bg-red-100 border-red-200';
                        statusIcon = 'x-circle';
                    }
                %>
                <div class="flex items-center justify-between p-3 bg-gray-50 rounded-xl hover:bg-gray-100 transition-colors">
                    <div class="flex items-center gap-3">
                        <img src="<%= product.HinhAnh ? (product.HinhAnh.startsWith('http') || product.HinhAnh.startsWith('/') ? product.HinhAnh : '/uploads/' + product.HinhAnh) : '/images/products/placeholder.png' %>" class="w-9 h-9 rounded-xl object-cover border border-gray-100 shadow-sm" onerror="this.onerror=null; this.src='https://ui-avatars.com/api/?name=<%= encodeURIComponent(product.TenSanPham.charAt(0)) %>&background=f1f5f9&color=94a3b8&size=100';">
                        <div>
                            <div class="text-xs font-extrabold text-winmart-dark dark:text-white truncate max-w-[150px]" title="<%= product.TenSanPham %>"><%= product.TenSanPham %></div>
                            <div class="text-[10px] text-gray-400 font-semibold">Lô: <%= product.MaLo %> • Tồn: <span class="text-winmart-dark font-bold"><%= product.SoLuongHienTai %></span></div>
                        </div>
                    </div>
                    <div class="text-right">
                        <div class="text-sm font-black text-winmart-dark dark:text-white"><%= expDate.toLocaleDateString('vi-VN') %></div>
                        <span class="inline-flex mt-1 items-center gap-1 text-[9px] font-black uppercase px-2 py-0.5 rounded-md border <%= statusColor %>">
                            <i data-lucide="<%= statusIcon %>" class="w-3 h-3"></i> <%= diffDays > 0 ? `Còn ${diffDays} ngày` : 'Đã hết hạn' %>
                        </span>
                    </div>
                </div>
                <% }) %>
            <% } else { %>
            <div class="text-center py-8">
                <i data-lucide="shield-check" class="w-10 h-10 text-emerald-300 mx-auto mb-2"></i>
                <p class="text-sm font-semibold text-gray-400">Date hàng hóa đang rất an toàn</p>
            </div>
            <% } %>
        </div>
    </div>
</div>

<!-- Hàng 4: Cảnh báo -->
<div class="bento-card p-6">
    <div class="flex items-center justify-between mb-5">
        <h3 class="text-sm font-black text-winmart-dark dark:text-white flex items-center gap-2">
            <div class="w-1.5 h-4 bg-amber-500 rounded-full"></div>
            Sản phẩm sắp hết hàng
        </h3>
        <a href="/admin/inventory" class="text-xs font-bold text-amber-500 hover:text-winmart-dark dark:text-white transition-colors flex items-center gap-1">
            Xem kho <i data-lucide="arrow-right" class="w-3 h-3"></i>
        </a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4">
        <% if (typeof lowStockProducts !== 'undefined' && lowStockProducts && lowStockProducts.length > 0) { %>
            <% lowStockProducts.forEach(product => { %>
            <div class="p-3 bg-red-50/50 border border-red-100 rounded-xl flex items-center gap-3">
                <img src="<%= product.HinhAnh ? (product.HinhAnh.startsWith('http') || product.HinhAnh.startsWith('/') ? product.HinhAnh : '/uploads/' + product.HinhAnh) : '/images/products/placeholder.png' %>" class="w-8 h-8 rounded-lg object-cover" onerror="this.onerror=null; this.src='https://ui-avatars.com/api/?name=<%= encodeURIComponent(product.TenSanPham.charAt(0)) %>&background=f1f5f9&color=94a3b8&size=100';">
                <div class="flex-1 min-w-0">
                    <div class="text-[11px] font-bold text-winmart-dark truncate"><%= product.TenSanPham %></div>
                    <div class="text-[10px] font-black text-winmart-red mt-0.5">Còn <%= product.SoLuongTon || 0 %></div>
                </div>
            </div>
            <% }) %>
        <% } else { %>
            <div class="col-span-full text-center py-4">
                <i data-lucide="check-circle" class="w-8 h-8 text-emerald-400 mx-auto mb-2"></i>
                <p class="text-xs font-semibold text-gray-400">Tồn kho ổn định, chưa có mặt hàng nào báo động.</p>
            </div>
        <% } %>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    document.addEventListener("DOMContentLoaded", function() {
        // Line Chart (Revenue)
        const ctxRev = document.getElementById('revenueChart');
        if (ctxRev) {
            const rawLabels = <%- typeof chartData !== 'undefined' ? JSON.stringify(chartData.labels) : '[]' %>;
            const rawData = <%- typeof chartData !== 'undefined' ? JSON.stringify(chartData.values) : '[]' %>;
            
            let gradient = ctxRev.getContext('2d').createLinearGradient(0, 0, 0, 400);
            gradient.addColorStop(0, 'rgba(16, 185, 129, 0.2)'); // Emerald
            gradient.addColorStop(1, 'rgba(16, 185, 129, 0)');

            new Chart(ctxRev, {
                type: 'line',
                data: {
                    labels: rawLabels,
                    datasets: [{
                        label: 'Doanh thu (VNĐ)',
                        data: rawData,
                        borderColor: '#10b981', // emerald-500
                        backgroundColor: gradient,
                        borderWidth: 3,
                        pointBackgroundColor: '#ffffff',
                        pointBorderColor: '#10b981',
                        pointBorderWidth: 2,
                        pointRadius: 4,
                        pointHoverRadius: 6,
                        fill: true,
                        tension: 0.4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: 'rgba(31, 41, 55, 0.95)',
                            titleColor: '#9ca3af',
                            bodyColor: '#ffffff',
                            borderColor: '#374151',
                            borderWidth: 1,
                            padding: 12,
                            displayColors: true,
                            boxPadding: 6,
                            usePointStyle: true,
                            titleFont: { size: 12, family: 'Inter', weight: 'normal' },
                            bodyFont: { size: 15, weight: 'bold', family: 'Inter' },
                            callbacks: {
                                title: function(context) {
                                    return 'Ngày: ' + context[0].label;
                                },
                                label: function(context) {
                                    let value = new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(context.parsed.y);
                                    return ' Doanh thu: ' + value;
                                }
                            }
                        }
                    },
                    scales: {
                        x: { grid: { display: false, drawBorder: false }, ticks: { font: { family: 'Inter', size: 11 }, color: '#9ca3af' } },
                        y: { grid: { color: '#f3f4f6', drawBorder: false, borderDash: [5, 5] }, ticks: { font: { family: 'Inter', size: 11 }, color: '#9ca3af', callback: function(value) { if(value >= 1000000) return (value / 1000000) + ' Tr'; return value; } } }
                    }
                }
            });
        }

        // Doughnut Chart (Channels)
        const ctxType = document.getElementById('channelChart');
        if(ctxType) {
            const onlineCount = <%= chartData.onlineCount || 0 %>;
            const posCount = <%= chartData.posCount || 0 %>;
            new Chart(ctxType, {
                type: 'doughnut',
                data: {
                    labels: ['Online', 'POS'],
                    datasets: [{
                        data: [onlineCount, posCount],
                        backgroundColor: ['#e11d48', '#374151'],
                        borderWidth: 0,
                        hoverOffset: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '75%',
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: 'rgba(31, 41, 55, 0.95)',
                            titleColor: '#9ca3af',
                            bodyColor: '#ffffff',
                            borderColor: '#374151',
                            borderWidth: 1,
                            padding: 12,
                            displayColors: true,
                            boxPadding: 6,
                            usePointStyle: true,
                            bodyFont: { size: 14, family: 'Inter', weight: 'bold' },
                            callbacks: {
                                label: function(context) { 
                                    const total = context.dataset.data.reduce((a, b) => a + b, 0);
                                    const percentage = total > 0 ? Math.round((context.raw / total) * 100) : 0;
                                    return ` Kênh ${context.label}: ${context.raw} đơn (${percentage}%)`; 
                                }
                            }
                        }
                    }
                }
            });
        }
    });
</script>